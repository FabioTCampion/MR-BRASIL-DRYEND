Version  		| Date        			| Expert in charge  	| Changes applied
<xx.xx.xx>		| <dd.mm.yyyy>  		| <name>              | <changes>

===============================================================================================================================*)

METHOD _00_UpdateHardware
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
SLT1_P1_100_UG1();
SLT1_P1_100_UG2();
SLT1_P1_100_UG3();
SLT1_P1_100_UG4();
SLT1_P1_100_UG5();

SLT1_P1_200_UG1();
SLT1_P1_200_UG2();
SLT1_P1_200_UG3();
SLT1_P1_200_UG4();
SLT1_P1_200_UG5();
SLT1_P1_200_UG6();
SLT1_P1_200_UG7();
SLT1_P1_200_UG8();


STK_P2_050_DI1();
STK_P2_050_DI2();
STK_P2_050_DO1();
STK_P2_050_DO2();
	
STK_P2_050_AO1();	
STK_P2_050_AO2();
STK_P2_050_AO3();
STK_P2_050_AO4();

STK_P2_050_ENC1();
//Io-Link master
STK_050_BC2();
//Io-Link Slaves

STKU_050_DIO1();	//Ch 0 - IO-Link IP67 Input/Output module
STKU_050_DIO2(); //Ch 1 - IO-Link DIN Rail Input/Output module
STKU_050_DIO3(); //Ch 1 - IO-Link DIN Rail Input/Output module


STKL_050_DIO1();	//Ch 0 - IO-Link IP67 Input/Output module
STKL_050_DIO2(); //Ch 1 - IO-Link DIN Rail Input/Output module
STKL_100_B01(); //Ch 2 - IO-Link Pile height sensor	

//CANOpen slave	
STKU_P2_100_UG8(enable := TRUE); //Backstop servo drive

// EN: Lift servo drive. Quick stop is generated by the elevator control block.
// PT: Servo do elevador. O quick stop é gerado pelo bloco de controle do elevador.
STKU_P2_100_UG9(enable := TRUE);
]]></ST>
      </Implementation>
    </Method>
