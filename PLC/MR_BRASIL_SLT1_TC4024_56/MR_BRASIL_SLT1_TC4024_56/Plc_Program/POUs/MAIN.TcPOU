<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="MAIN" Id="{bcc5f24d-e98e-4f1e-8506-ae85e970a150}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM MAIN
VAR
	//==============================================================
	// EN: Main machine control function blocks
	// PT: Blocos principais de controle da máquina
	//==============================================================
	instFBSlitter1Control              : FB_SlitterControl;
	instFB_RotaryKnife                 : FB_RotaryKnife;
	// instFB_MetricsAndCalculation    : FB_MetricsAndCalculation;
	instFB_PaperDirectionControl       : FB_PaperDirectionControl;
	instFB_AutomaticOrderChange_V1     : FB_AutomaticOrderChange_V1;
	instFB_AlarmControl                : FB_AlarmControl;
	instFBSavePersistentData           : FB_SavePersistentData;

	//==============================================================
	// EN: Stacker control function blocks
	// PT: Blocos de controle dos empilhadores
	//==============================================================
	instFBLowerStackerControl          : FB_SimpleSheetStackerControl;
	instFBLowerStackerControlV1        : FB_SimpleSheetStackerControl_1;
	instFBUpperStackerControl          : FB_ComplexSheetStackerControl;

	//==============================================================
	// EN: Persistent data control status
	// PT: Estado do controle de dados persistentes
	//==============================================================
	bStart                             : BOOL;
	bError                             : BOOL;
	bBusy                              : BOOL;
	nErrorId                           : UDINT;
	fbR_Trig                           : R_TRIG;

	//==============================================================
	// EN: Machine interlock and control signals
	// PT: Sinais de intertravamento e controle da máquina
	//==============================================================
	slitterHomeComplete                : BOOL;
	aocReferenceSwitch                 : BOOL;
	lineSpeedUpFromAOC                 : BOOL;
	lineSpeedDownFromAOC               : BOOL;
	lineStopFromAOC                    : BOOL;
	executePositioningFromAOC          : BOOL;
	rotaryKnifeSpeedRefFromAOC         : LREAL;
	slitterSpeedRefFromAOC             : LREAL;
	lineStopFromRotaryKnife            : BOOL;
	lineStopFromSlitter                : BOOL;
	lineStopFromLowerStacker           : BOOL;
	aocRunning                         : BOOL;

	//==============================================================
	// EN: Program initialization
	// PT: Inicialização do programa
	//==============================================================
	firstScan                          : BOOL := TRUE;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[//==============================================================
// EN: Cyclic machine control sequence
// PT: Sequência cíclica de controle da máquina
//==============================================================
_00_UpdateHardware();
_01_SlitterControl();
_02_RotaryKnifeControl();
_04_AutomaticOrderChange();
_05_LineControl();
_06_AlarmsControl();
_07_LowerStackerControl();
_08_UpperStackerControl();

// EN: Publish the upper stacker alarms and include them in the general indication.
// PT: Publica os alarmes do stacker superior e os inclui na indicação geral.
hmiAlarms.upperStacker :=
	instFBUpperStackerControl.hmiAlarms;

hmiStatus.alarmActive :=
	hmiStatus.alarmActive OR
	instFBUpperStackerControl.alarmActive;

// EN: Update persistent data management.
// PT: Atualiza o gerenciamento dos dados persistentes.
instFBSavePersistentData();

// EN: Apply default commands during the first PLC scan.
// PT: Aplica os comandos padrão durante o primeiro ciclo do PLC.
IF firstScan THEN
	hmiCommands.lowerStacker.backstopAutoCmd := TRUE;
	hmiCommands.lowerStacker.conveyorLevelerAutoCmd := TRUE;

	hmiCommands.upperStacker.backstopAutoCmd := TRUE;
	hmiCommands.upperStacker.elevatorAutoCmd := TRUE;

END_IF

firstScan := FALSE;
]]></ST>
    </Implementation>
    <Method Name="_00_UpdateHardware" Id="{e4c53ce6-fd8e-4127-bdb2-fce90e3642e3}">
      <Declaration><![CDATA[(*==============================================================================================================================
CPNTeck - Automação industrial
(c)Copyright 2023 All Rights Reserved
