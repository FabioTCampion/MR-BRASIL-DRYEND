<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_IS620P_CO" Id="{dc3dfc8d-a429-435a-8fe9-4e49b291ea02}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_IS620P_CO

// =============================================================================
// EN: Generic CANopen velocity-control interface for the Inovance IS620P-CO.
//     The parent block is responsible for motion profiles, positioning logic,
//     machine limits and application safety decisions.
// PT: Interface genérica de controle de velocidade CANopen para o Inovance
//     IS620P-CO. O bloco pai é responsável pelos perfis de movimento, lógica de
//     posicionamento, limites da máquina e decisões de segurança da aplicação.
// =============================================================================

VAR_INPUT PERSISTENT
    // EN: Persistent device scaling, calibration and protection parameters.
    // PT: Parâmetros persistentes de escala, calibração e proteção do equipamento.
    deviceConfig : IS620P_CO_DEV_CONFIG;
END_VAR

VAR_INPUT
    // EN: Hardware outputs written cyclically from the PLC to the servo drive.
    // PT: Saídas de hardware escritas ciclicamente do PLC para o servo drive.
    PlcToHw AT %Q* : IS620P_CO_PLCTOHW_PDOS;

    // EN: Enables cyclic execution and output generation by this function block.
    // PT: Habilita a execução cíclica e a geração de saídas deste function block.
    enable : BOOL;

    // EN: Requests the CiA 402 Operation Enabled state.
    // PT: Solicita o estado CiA 402 Operation Enabled.
    enableDrive : BOOL;

    // EN: Rising edge requests a CiA 402 fault reset.
    // PT: A borda de subida solicita o reset de falha CiA 402.
    resetFault : BOOL;

    // EN: Requests the CiA 402 quick-stop transition with highest command priority.
    // PT: Solicita a transição de quick stop CiA 402 com maior prioridade de comando.
    quickStop : BOOL;

    // EN: Signed velocity reference generated by the parent block in millimeters per second.
    // PT: Referência de velocidade com sinal gerada pelo bloco pai em milímetros por segundo.
    velocityReferenceMmps : LREAL;

    // EN: Rising edge defines the current mechanical position as zero.
    // PT: A borda de subida define a posição mecânica atual como zero.
    zeroPosition : BOOL;

    // EN: Rising edge assigns desiredPositionMm to the current mechanical position.
    // PT: A borda de subida atribui desiredPositionMm à posição mecânica atual.
    setPosition : BOOL;

    // EN: Engineering position assigned when setPosition is triggered.
    // PT: Posição de engenharia atribuída quando setPosition é acionado.
    desiredPositionMm : LREAL;
END_VAR

VAR_OUTPUT
    // EN: Hardware inputs received cyclically from the drive and CANopen master.
    // PT: Entradas de hardware recebidas ciclicamente do drive e do mestre CANopen.
    HwToPlc AT %I* : IS620P_CO_HWTOPLC_PDOS;

    // EN: Generic communication and CiA 402 status information.
    // PT: Informações genéricas de comunicação e estado CiA 402.
    status : IS620P_CO_STATUS;

    // EN: Raw position value received from object 6064h.
    // PT: Valor bruto de posição recebido do objeto 6064h.
    rawPosition : DINT;

    // EN: Position feedback converted to millimeters before applying the offset.
    // PT: Realimentação de posição convertida para milímetros antes de aplicar o offset.
    rawPositionMm : LREAL;

    // EN: Calibrated position feedback in millimeters.
    // PT: Realimentação de posição calibrada em milímetros.
    actualPositionMm : LREAL;

    // EN: Raw velocity value received from object 606Ch.
    // PT: Valor bruto de velocidade recebido do objeto 606Ch.
    rawVelocity : DINT;

    // EN: Velocity feedback converted to millimeters per second.
    // PT: Realimentação de velocidade convertida para milímetros por segundo.
    actualVelocityMmps : LREAL;

    // EN: Velocity reference accepted after inversion and equipment limiting.
    // PT: Referência de velocidade aceita após inversão e limitação do equipamento.
    commandedVelocityMmps : LREAL;

    // EN: One-cycle confirmation pulse after a position capture is accepted.
    // PT: Pulso de confirmação de um ciclo após uma captura de posição ser aceita.
    positionSetDone : BOOL;

    // EN: One-cycle indication that a position capture request was rejected.
    // PT: Indicação de um ciclo de que uma solicitação de captura de posição foi rejeitada.
    positionSetRejected : BOOL;

    // EN: Active position offset for commissioning and diagnostics.
    // PT: Offset de posição ativo para comissionamento e diagnóstico.
    positionOffsetMm : LREAL;
END_VAR

VAR
    // EN: Internal communication validation result.
    // PT: Resultado interno da validação da comunicação.
    communicationOkInternal : BOOL;

    // EN: Internal CiA 402 state decoded from the status word.
    // PT: Estado interno CiA 402 decodificado a partir da palavra de estado.
    deviceStateInternal : E_IS620P_CO_STATE;

    // EN: Internal validation of scaling parameters.
    // PT: Validação interna dos parâmetros de escala.
    configurationValidInternal : BOOL;

    // EN: Previous reset command state used for rising-edge detection.
    // PT: Estado anterior do comando de reset usado para detecção de borda de subida.
    resetFaultOld : BOOL;

    // EN: Rising edge of the fault reset command.
    // PT: Borda de subida do comando de reset de falha.
    resetFaultRisingEdge : BOOL;

    // EN: Previous zero-position command state used for rising-edge detection.
    // PT: Estado anterior do comando de zerar posição usado para detecção de borda de subida.
    zeroPositionOld : BOOL;

    // EN: Rising edge of the zero-position command.
    // PT: Borda de subida do comando de zerar posição.
    zeroPositionRisingEdge : BOOL;

    // EN: Previous set-position command state used for rising-edge detection.
    // PT: Estado anterior do comando de definir posição usado para detecção de borda de subida.
    setPositionOld : BOOL;

    // EN: Rising edge of the set-position command.
    // PT: Borda de subida do comando de definir posição.
    setPositionRisingEdge : BOOL;

    // EN: Indicates that the current position feedback can be calibrated.
    // PT: Indica que a realimentação de posição atual pode ser calibrada.
    positionSetAllowed : BOOL;

    // EN: Velocity reference limited in engineering units.
    // PT: Referência de velocidade limitada em unidades de engenharia.
    limitedVelocityMmps : LREAL;

    // EN: Raw velocity reference after conversion to drive units.
    // PT: Referência bruta de velocidade após conversão para unidades do drive.
    targetVelocityRaw : DINT;

    // EN: Timer reserved for the CiA 402 drive-enable sequence.
    // PT: Temporizador reservado para a sequência de habilitação CiA 402 do drive.
    enableTimer : TON;

    // EN: Timer reserved for operation-mode confirmation.
    // PT: Temporizador reservado para confirmação do modo de operação.
    modeSelectionTimer : TON;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[// EN: Read and convert all hardware feedback before making control decisions.
// PT: Lê e converte todas as realimentações de hardware antes das decisões de controle.
_ReadHardwareInputs();

// EN: Decode the current CiA 402 state from the drive status word.
// PT: Decodifica o estado CiA 402 atual a partir da palavra de estado do drive.
deviceStateInternal := _DecodeDriveState(
    statusWordValue := HwToPlc.statusWord,
    communicationOk := communicationOkInternal
);

// EN: Process position calibration commands before publishing the current position.
// PT: Processa os comandos de calibração antes de publicar a posição atual.
_ProcessPositionCommands();

// EN: Generate the CiA 402 control word and operation-mode command.
// PT: Gera a palavra de controle CiA 402 e o comando do modo de operação.
_ControlDriveState();

// EN: Validate, limit and convert the velocity reference received from the parent block.
// PT: Valida, limita e converte a referência de velocidade recebida do bloco pai.
_ControlVelocity();

// EN: Publish the final generic device status at the end of the cycle.
// PT: Publica o estado genérico final do equipamento ao término do ciclo.
_UpdateStatus();]]></ST>
    </Implementation>
    <Method Name="_ReadHardwareInputs" Id="{ddf5eb12-28f0-4b59-8ab3-725167465138}">
      <Declaration><![CDATA[METHOD PRIVATE _ReadHardwareInputs
// =============================================================================
// EN: Reads communication information and converts position and velocity feedback.
// PT: Lê as informações de comunicação e converte as realimentações de posição e velocidade.
// =============================================================================
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// EN: NodeState 0 means no error. Value 64 also represents completed startup without a base error.
// PT: NodeState 0 significa sem erro. O valor 64 também representa startup concluído sem erro base.
communicationOkInternal := (HwToPlc.nodeState = 0) OR (HwToPlc.nodeState = 64);

// EN: Both conversion factors must be positive before motion references are accepted.
// PT: Ambos os fatores de conversão devem ser positivos antes de aceitar referências de movimento.
configurationValidInternal :=
    (deviceConfig.positionUnitsPerMm > 0.0) AND
    (deviceConfig.velocityUnitsPerMmps > 0.0) AND
    (deviceConfig.maximumVelocityMmps >= 0.0);

rawPosition := HwToPlc.actualPosition;
rawVelocity := HwToPlc.actualVelocity;

rawPositionMm := _ConvertRawPositionToMm(rawPositionValue := rawPosition);
actualPositionMm := rawPositionMm + deviceConfig.positionOffsetMm;
actualVelocityMmps := _ConvertRawVelocityToMmps(rawVelocityValue := rawVelocity);
positionOffsetMm := deviceConfig.positionOffsetMm;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_DecodeDriveState" Id="{62aa1c0c-314f-4c52-adac-239968470f77}">
      <Declaration><![CDATA[METHOD PRIVATE _DecodeDriveState : E_IS620P_CO_STATE
// =============================================================================
// EN: Decodes the CiA 402 Power Drive System state using the standard masks.
// PT: Decodifica o estado CiA 402 Power Drive System usando as máscaras padrão.
// =============================================================================
VAR_INPUT
    statusWordValue : UINT;
    communicationOk : BOOL;
END_VAR
VAR
    maskedState004F : UINT;
    maskedState006F : UINT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT communicationOk THEN
    _DecodeDriveState := E_IS620P_CO_STATE.CommunicationFault;
    RETURN;
END_IF;

maskedState004F := statusWordValue AND 16#004F;
maskedState006F := statusWordValue AND 16#006F;

IF maskedState004F = 16#0000 THEN
    _DecodeDriveState := E_IS620P_CO_STATE.NotReadyToSwitchOn;
ELSIF maskedState004F = 16#0040 THEN
    _DecodeDriveState := E_IS620P_CO_STATE.SwitchOnDisabled;
ELSIF maskedState006F = 16#0021 THEN
    _DecodeDriveState := E_IS620P_CO_STATE.ReadyToSwitchOn;
ELSIF maskedState006F = 16#0023 THEN
    _DecodeDriveState := E_IS620P_CO_STATE.SwitchedOn;
ELSIF maskedState006F = 16#0027 THEN
    _DecodeDriveState := E_IS620P_CO_STATE.OperationEnabled;
ELSIF maskedState006F = 16#0007 THEN
    _DecodeDriveState := E_IS620P_CO_STATE.QuickStopActive;
ELSIF maskedState004F = 16#000F THEN
    _DecodeDriveState := E_IS620P_CO_STATE.FaultReactionActive;
ELSIF maskedState004F = 16#0008 THEN
    _DecodeDriveState := E_IS620P_CO_STATE.Fault;
ELSE
    _DecodeDriveState := E_IS620P_CO_STATE.NotReadyToSwitchOn;
END_IF;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_ProcessPositionCommands" Id="{dddc7008-bbe9-4b1a-8308-67e3ff969012}">
      <Declaration><![CDATA[METHOD PRIVATE _ProcessPositionCommands
// =============================================================================
// EN: Captures a zero or an assigned engineering position by changing the persistent offset.
// PT: Captura zero ou uma posição de engenharia definida alterando o offset persistente.
// =============================================================================
]]></Declaration>
      <Implementation>
        <ST><![CDATA[positionSetDone := FALSE;
positionSetRejected := FALSE;

zeroPositionRisingEdge := zeroPosition AND NOT zeroPositionOld;
setPositionRisingEdge := setPosition AND NOT setPositionOld;

positionSetAllowed :=
    communicationOkInternal AND
    configurationValidInternal AND
    (ABS(actualVelocityMmps) <= ABS(deviceConfig.positionSetMaxVelocityMmps));

// EN: ZeroPosition has priority when both commands arrive in the same PLC cycle.
// PT: ZeroPosition possui prioridade quando ambos os comandos chegam no mesmo ciclo do PLC.
IF zeroPositionRisingEdge THEN
    IF positionSetAllowed THEN
        deviceConfig.positionOffsetMm := -rawPositionMm;
        deviceConfig.calibrationValid := TRUE;
        positionSetDone := TRUE;
    ELSE
        positionSetRejected := TRUE;
    END_IF;
ELSIF setPositionRisingEdge THEN
    IF positionSetAllowed THEN
        deviceConfig.positionOffsetMm := desiredPositionMm - rawPositionMm;
        deviceConfig.calibrationValid := TRUE;
        positionSetDone := TRUE;
    ELSE
        positionSetRejected := TRUE;
    END_IF;
END_IF;

zeroPositionOld := zeroPosition;
setPositionOld := setPosition;

// EN: Recalculate the published position immediately after an accepted capture.
// PT: Recalcula a posição publicada imediatamente após uma captura aceita.
actualPositionMm := rawPositionMm + deviceConfig.positionOffsetMm;
positionOffsetMm := deviceConfig.positionOffsetMm;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_ControlDriveState" Id="{ee25d611-1f8b-4bc6-9b6b-36412c401e15}">
      <Declaration><![CDATA[METHOD PRIVATE _ControlDriveState
// =============================================================================
// EN: Generates the CiA 402 control word and selects Profile Velocity mode.
// PT: Gera a palavra de controle CiA 402 e seleciona o modo Profile Velocity.
// =============================================================================
]]></Declaration>
      <Implementation>
        <ST><![CDATA[resetFaultRisingEdge := resetFault AND NOT resetFaultOld;
resetFaultOld := resetFault;

// EN: Keep mapped but unused profile-position references at safe values.
// PT: Mantém as referências mapeadas, porém não utilizadas, em valores seguros.
PlcToHw.targetPosition := 0;
PlcToHw.profileVelocity := 0;
PlcToHw.profileAcceleration := deviceConfig.profileAccelerationRaw;
PlcToHw.profileDeceleration := deviceConfig.profileDecelerationRaw;

IF enable THEN
    PlcToHw.modeCommand := 3;
ELSE
    PlcToHw.modeCommand := 0;
END_IF;

// EN: Monitor enable and mode-selection sequences without overriding the device state.
// PT: Monitora as sequências de habilitação e seleção de modo sem sobrescrever o estado do equipamento.
enableTimer(
    IN := enable AND enableDrive AND communicationOkInternal AND
          (deviceStateInternal <> E_IS620P_CO_STATE.OperationEnabled),
    PT := deviceConfig.enableTimeout
);

modeSelectionTimer(
    IN := enable AND enableDrive AND communicationOkInternal AND
          (HwToPlc.modeDisplay <> 3),
    PT := deviceConfig.modeSelectionTimeout
);

// EN: Priority: disabled, communication/configuration fault, quick stop, fault reset, normal state sequence.
// PT: Prioridade: desabilitado, falha de comunicação/configuração, quick stop, reset e sequência normal.
IF NOT enable THEN
    PlcToHw.controlWord := 16#0000;
ELSIF NOT communicationOkInternal OR NOT configurationValidInternal THEN
    PlcToHw.controlWord := 16#0000;
ELSIF quickStop THEN
    PlcToHw.controlWord := 16#0002;
ELSIF deviceStateInternal = E_IS620P_CO_STATE.Fault THEN
    IF resetFaultRisingEdge THEN
        PlcToHw.controlWord := 16#0080;
    ELSE
        PlcToHw.controlWord := 16#0000;
    END_IF;
ELSIF NOT enableDrive THEN
    PlcToHw.controlWord := 16#0006;
ELSE
    CASE deviceStateInternal OF
        E_IS620P_CO_STATE.SwitchOnDisabled:
            PlcToHw.controlWord := 16#0006;

        E_IS620P_CO_STATE.ReadyToSwitchOn:
            PlcToHw.controlWord := 16#0007;

        E_IS620P_CO_STATE.SwitchedOn,
        E_IS620P_CO_STATE.OperationEnabled,
        E_IS620P_CO_STATE.QuickStopActive:
            PlcToHw.controlWord := 16#000F;

        ELSE
            PlcToHw.controlWord := 16#0000;
    END_CASE;
END_IF;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_ControlVelocity" Id="{15684252-f451-48a7-994b-79aa45a477d1}">
      <Declaration><![CDATA[METHOD PRIVATE _ControlVelocity
// =============================================================================
// EN: Limits and converts the external velocity reference without generating a motion ramp.
// PT: Limita e converte a referência externa de velocidade sem gerar uma rampa de movimento.
// =============================================================================
]]></Declaration>
      <Implementation>
        <ST><![CDATA[limitedVelocityMmps := 0.0;
targetVelocityRaw := 0;
commandedVelocityMmps := 0.0;
PlcToHw.targetVelocity := 0;

IF enable AND
   enableDrive AND
   communicationOkInternal AND
   configurationValidInternal AND
   NOT quickStop AND
   (deviceStateInternal = E_IS620P_CO_STATE.OperationEnabled) AND
   (HwToPlc.modeDisplay = 3) THEN

    limitedVelocityMmps := LIMIT(
        -ABS(deviceConfig.maximumVelocityMmps),
        velocityReferenceMmps,
        ABS(deviceConfig.maximumVelocityMmps)
    );

    commandedVelocityMmps := limitedVelocityMmps;
    targetVelocityRaw := _ConvertVelocityToRaw(velocityMmps := limitedVelocityMmps);
    PlcToHw.targetVelocity := targetVelocityRaw;
END_IF;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_UpdateStatus" Id="{bb8096a3-c599-4a79-a083-b774c28c58ad}">
      <Declaration><![CDATA[METHOD PRIVATE _UpdateStatus
// =============================================================================
// EN: Publishes communication, configuration and CiA 402 state information.
// PT: Publica informações de comunicação, configuração e estado CiA 402.
// =============================================================================
]]></Declaration>
      <Implementation>
        <ST><![CDATA[status.communicationOk := communicationOkInternal;
status.configurationValid := configurationValidInternal;
status.ready :=
    communicationOkInternal AND
    configurationValidInternal AND
    (deviceStateInternal = E_IS620P_CO_STATE.OperationEnabled) AND
    (HwToPlc.modeDisplay = 3);
status.driveEnabled := deviceStateInternal = E_IS620P_CO_STATE.OperationEnabled;
status.quickStopActive := deviceStateInternal = E_IS620P_CO_STATE.QuickStopActive;
status.calibrated := deviceConfig.calibrationValid;
status.warning := (HwToPlc.statusWord AND 16#0080) <> 0;
status.fault :=
    (deviceStateInternal = E_IS620P_CO_STATE.Fault) OR
    (deviceStateInternal = E_IS620P_CO_STATE.FaultReactionActive);
status.enableTimeout := enableTimer.Q;
status.modeSelectionTimeout := modeSelectionTimer.Q;
status.nodeState := HwToPlc.nodeState;
status.diagnosticFlag := HwToPlc.diagFlag;
status.statusWord := HwToPlc.statusWord;
status.activeMode := HwToPlc.modeDisplay;
status.deviceState := deviceStateInternal;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_ConvertRawPositionToMm" Id="{0d519fdb-a541-43d7-a6e5-063d7d54c741}">
      <Declaration><![CDATA[METHOD PRIVATE _ConvertRawPositionToMm : LREAL
// =============================================================================
// EN: Converts raw position feedback to millimeters without applying the calibration offset.
// PT: Converte a posição bruta para milímetros sem aplicar o offset de calibração.
// =============================================================================
VAR_INPUT
    rawPositionValue : DINT;
END_VAR
VAR
    convertedPositionMm : LREAL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF deviceConfig.positionUnitsPerMm <= 0.0 THEN
    _ConvertRawPositionToMm := 0.0;
    RETURN;
END_IF;

convertedPositionMm :=
    DINT_TO_LREAL(rawPositionValue) / deviceConfig.positionUnitsPerMm;

IF deviceConfig.directionInverted THEN
    convertedPositionMm := -convertedPositionMm;
END_IF;

_ConvertRawPositionToMm := convertedPositionMm;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_ConvertRawVelocityToMmps" Id="{1c3db517-e46d-4637-acd3-ea298b46d8ed}">
      <Declaration><![CDATA[METHOD PRIVATE _ConvertRawVelocityToMmps : LREAL
// =============================================================================
// EN: Converts raw velocity feedback to millimeters per second.
// PT: Converte a velocidade bruta para milímetros por segundo.
// =============================================================================
VAR_INPUT
    rawVelocityValue : DINT;
END_VAR
VAR
    convertedVelocityMmps : LREAL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF deviceConfig.velocityUnitsPerMmps <= 0.0 THEN
    _ConvertRawVelocityToMmps := 0.0;
    RETURN;
END_IF;

convertedVelocityMmps :=
    DINT_TO_LREAL(rawVelocityValue) / deviceConfig.velocityUnitsPerMmps;

IF deviceConfig.directionInverted THEN
    convertedVelocityMmps := -convertedVelocityMmps;
END_IF;

_ConvertRawVelocityToMmps := convertedVelocityMmps;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_ConvertVelocityToRaw" Id="{32b92323-bd7a-4ef5-8401-b1d4b9754169}">
      <Declaration><![CDATA[METHOD PRIVATE _ConvertVelocityToRaw : DINT
// =============================================================================
// EN: Converts a velocity command in millimeters per second to the signed raw drive value.
// PT: Converte um comando em milímetros por segundo para o valor bruto com sinal do drive.
// =============================================================================
VAR_INPUT
    velocityMmps : LREAL;
END_VAR
VAR
    driveVelocityMmps : LREAL;
    rawVelocityLreal  : LREAL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF deviceConfig.velocityUnitsPerMmps <= 0.0 THEN
    _ConvertVelocityToRaw := 0;
    RETURN;
END_IF;

driveVelocityMmps := velocityMmps;
IF deviceConfig.directionInverted THEN
    driveVelocityMmps := -driveVelocityMmps;
END_IF;

rawVelocityLreal := driveVelocityMmps * deviceConfig.velocityUnitsPerMmps;

IF rawVelocityLreal > 2147483647.0 THEN
    _ConvertVelocityToRaw := 2147483647;
ELSIF rawVelocityLreal < -2147483648.0 THEN
    _ConvertVelocityToRaw := -2147483647 - 1;
ELSE
    _ConvertVelocityToRaw := LREAL_TO_DINT(rawVelocityLreal);
END_IF;]]></ST>
      </Implementation>
    </Method>
    <LineIds Name="FB_IS620P_CO">
      <LineId Id="2" Count="0" />
    </LineIds>
  </POU>
</TcPlcObject>
