  <POU Name="FB_ScorerHeight" Id="{02a244b8-a79b-4e14-9827-78669c61d068}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_ScorerHeight
VAR_INPUT

	EN					: BOOL;
	autoManual			: BOOL;

	manualIncrement		: BOOL;
	manualDecrement		: BOOL;
	circuitBreaker		: BOOL;
	limitMax			: BOOL;
	limitMin			: BOOL;
	scorerHeightPositionSensor	: WORD;
	fluteType			: STRING;
	scorerHeightArr		: ARRAY [1..5] OF REAL;	(*Scorer height setpoint*)


END_VAR
VAR_OUTPUT

	ENO						: BOOL;
	error					: BOOL;
	positionIncrement		: BOOL;
	positionDecrement		: BOOL;
	scorerHeightMM			: REAL;				(*Scorer height position actual value in milimiters*)
	scorerHeightDifMM		: REAL;	(*Diference btween setpoint and actual value*)

END_VAR
VAR
END_VAR]]></Declaration>
