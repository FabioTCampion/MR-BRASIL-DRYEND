Version  		| Date        			| Expert in charge  	| Changes applied
01.00.01		| 29.03.2023  		| Fabio Campion            | First released version



===============================================================================================================================*)

IF currentOrder.generatedOrder.numberOfKnifes = 2 THEN

	currentOrder.generatedOrder.knifeEnabledArr[01] := TRUE;
	currentOrder.generatedOrder.knifeEnabledArr[02] := FALSE;
	currentOrder.generatedOrder.knifeEnabledArr[03] := FALSE;
	currentOrder.generatedOrder.knifeEnabledArr[04] := FALSE;
	currentOrder.generatedOrder.knifeEnabledArr[05] := TRUE;

	currentOrder.generatedOrder.knifePositionReferenceArr[1] := knifePositionArr[1];
	currentOrder.generatedOrder.knifePositionReferenceArr[2] := knifePositionArr[1] + 160;
	currentOrder.generatedOrder.knifePositionReferenceArr[3] := knifePositionArr[1] + 160 + 160;
	currentOrder.generatedOrder.knifePositionReferenceArr[4] := knifePositionArr[2] - 160;
	currentOrder.generatedOrder.knifePositionReferenceArr[5] := knifePositionArr[2];

END_IF

IF currentOrder.generatedOrder.numberOfKnifes = 3 THEN


	IF knifePositionArr[2] > machineConfig.knifeMaxPostionArr[3] THEN
		
		currentOrder.generatedOrder.knifeEnabledArr[01] := TRUE;
		currentOrder.generatedOrder.knifeEnabledArr[02] := FALSE;
		currentOrder.generatedOrder.knifeEnabledArr[03] := FALSE;
		currentOrder.generatedOrder.knifeEnabledArr[04] := TRUE;
		currentOrder.generatedOrder.knifeEnabledArr[05] := TRUE;
	
		currentOrder.generatedOrder.knifePositionReferenceArr[1] := knifePositionArr[1];
		currentOrder.generatedOrder.knifePositionReferenceArr[2] := knifePositionArr[1] + 160;
		currentOrder.generatedOrder.knifePositionReferenceArr[3] := knifePositionArr[1] + 160 + 160;
		currentOrder.generatedOrder.knifePositionReferenceArr[4] := knifePositionArr[2];
		currentOrder.generatedOrder.knifePositionReferenceArr[5] := knifePositionArr[3];
	
	ELSE
		
		currentOrder.generatedOrder.knifeEnabledArr[01] := TRUE;
		currentOrder.generatedOrder.knifeEnabledArr[02] := FALSE;
		currentOrder.generatedOrder.knifeEnabledArr[03] := TRUE;
		currentOrder.generatedOrder.knifeEnabledArr[04] := FALSE;
		currentOrder.generatedOrder.knifeEnabledArr[05] := TRUE;
	
		currentOrder.generatedOrder.knifePositionReferenceArr[1] := knifePositionArr[1];
		currentOrder.generatedOrder.knifePositionReferenceArr[2] := knifePositionArr[1] + 160;
		currentOrder.generatedOrder.knifePositionReferenceArr[3] := knifePositionArr[2];
		currentOrder.generatedOrder.knifePositionReferenceArr[4] := knifePositionArr[3] - 160;
		currentOrder.generatedOrder.knifePositionReferenceArr[5] := knifePositionArr[3];
		
	END_IF
END_IF

IF currentOrder.generatedOrder.numberOfKnifes = 4 THEN

	IF knifePositionArr[3] > machineConfig.knifeMaxPostionArr[3] THEN
		
		currentOrder.generatedOrder.knifeEnabledArr[01] := TRUE;
		currentOrder.generatedOrder.knifeEnabledArr[02] := TRUE;
		currentOrder.generatedOrder.knifeEnabledArr[03] := FALSE;
		currentOrder.generatedOrder.knifeEnabledArr[04] := TRUE;
		currentOrder.generatedOrder.knifeEnabledArr[05] := TRUE;
	
		currentOrder.generatedOrder.knifePositionReferenceArr[1] := knifePositionArr[1];
		currentOrder.generatedOrder.knifePositionReferenceArr[2] := knifePositionArr[2];
		currentOrder.generatedOrder.knifePositionReferenceArr[3] := knifePositionArr[2] + 160;
		currentOrder.generatedOrder.knifePositionReferenceArr[4] := knifePositionArr[3];
		currentOrder.generatedOrder.knifePositionReferenceArr[5] := knifePositionArr[4];		
		
	ELSE
		
		currentOrder.generatedOrder.knifeEnabledArr[01] := TRUE;
		currentOrder.generatedOrder.knifeEnabledArr[02] := TRUE;
		currentOrder.generatedOrder.knifeEnabledArr[03] := TRUE;
		currentOrder.generatedOrder.knifeEnabledArr[04] := FALSE;
		currentOrder.generatedOrder.knifeEnabledArr[05] := TRUE;
	
		currentOrder.generatedOrder.knifePositionReferenceArr[1] := knifePositionArr[1];
		currentOrder.generatedOrder.knifePositionReferenceArr[2] := knifePositionArr[2];
		currentOrder.generatedOrder.knifePositionReferenceArr[3] := knifePositionArr[3];
		currentOrder.generatedOrder.knifePositionReferenceArr[4] := knifePositionArr[4] - 160;
		currentOrder.generatedOrder.knifePositionReferenceArr[5] := knifePositionArr[4];		
		
	END_IF

	
	
	
	
END_IF

IF currentOrder.generatedOrder.numberOfKnifes = 5 THEN

	currentOrder.generatedOrder.knifeEnabledArr[01] := TRUE;
	currentOrder.generatedOrder.knifeEnabledArr[02] := TRUE;
	currentOrder.generatedOrder.knifeEnabledArr[03] := TRUE;
	currentOrder.generatedOrder.knifeEnabledArr[04] := TRUE;
	currentOrder.generatedOrder.knifeEnabledArr[05] := TRUE;

	currentOrder.generatedOrder.knifePositionReferenceArr[1] := knifePositionArr[1];
	currentOrder.generatedOrder.knifePositionReferenceArr[2] := knifePositionArr[2];
	currentOrder.generatedOrder.knifePositionReferenceArr[3] := knifePositionArr[3];
	currentOrder.generatedOrder.knifePositionReferenceArr[4] := knifePositionArr[4];
	currentOrder.generatedOrder.knifePositionReferenceArr[5] := knifePositionArr[5];

END_IF]]></ST>
      </Implementation>
    </Action>
