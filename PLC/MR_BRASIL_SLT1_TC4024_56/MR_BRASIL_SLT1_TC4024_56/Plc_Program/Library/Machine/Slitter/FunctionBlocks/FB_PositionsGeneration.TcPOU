    <Action Name="ACT_KnifePositionSelection" Id="{0691d953-079b-454f-bf35-20fd03ccdc6c}">
      <Implementation>
        <ST><![CDATA[(*==============================================================================================================================
CPNTeck - Automação industrial
(c)Copyright 2022 All Rights Reserved
_______________________________________________________________________________________________________________________________
Library: N/A
Tested with: CX5140
Engineering: Twincat 2
Restrictions: -
Requirements: N/A
Functionality:
    Distribute knife positions from toolPositionArr[] into knifePositionArr[] according to:
      - Sheet type (0 / 2 / 4 scorers) => step size (1 / 3 / 5)
      - E_LevelSelector => UpperOnly / LowerOnly / Both
Support: fabio@cpnteck.com.br
Note: Parameter comments are only available in language 'English (United States)'
_______________________________________________________________________________________________________________________________
Change log table:
Version        | Date       | Expert in charge | Changes applied
01.00.01       | 29.03.2023 | Fabio Campion    | First released version
01.00.02       | 30.12.2025 | Fabio Campion    | Add E_LevelSelector selection (upper/lower/both) + fix index handling
===============================================================================================================================*)
{region "Knife Position Selection — Reset arrays"}

(* Reset the knife enabled/position arrays (knives are 1..7 in your project) *)
FOR knifeEnabledIndex := 1 TO 7 BY 1 DO
    currentOrder.generatedOrder.knifeEnabledArr[knifeEnabledIndex] := FALSE;
    knifePositionArr[knifeEnabledIndex] := 0;
    currentOrder.generatedOrder.knifePositionReferenceArr[knifeEnabledIndex] := 0;
END_FOR;

(* Reset distribution indexes *)
knifeDistributionIndex := 1;  // Index into toolPositionArr[]
knifeOutIdx            := 1;  // Index into knifePositionArr[]

{endregion}


{region "Knife Position Selection — Determine active levels (E_LevelSelector)"}

userOrder1    := FALSE;
useOrder2 := FALSE;

CASE currentOrder.levelSelector OF
    E_LevelSelector.eUpperOnly:
        userOrder1    := TRUE;
        useOrder2 := FALSE;

    E_LevelSelector.eLowerOnly:
        userOrder1    := TRUE;
        useOrder2 := FALSE;

    E_LevelSelector.eBoth:
        userOrder1    := TRUE;
        useOrder2 := TRUE;

ELSE
    // Defensive fallback: keep legacy behavior (Top only)
    userOrder1    := TRUE;
    useOrder2 := FALSE;
END_CASE

{endregion}


{region "Knife Position Selection — TOP distribution"}

IF userOrder1 THEN

    topStep := 1;
    CASE currentOrder.order1.sheetType OF
        SHEET_WITH_NO_SCORER:   topStep := 1;
        SHEET_WITH_TWO_SCORER:  topStep := 3;
        SHEET_WITH_FOUR_SCORER: topStep := 5;
    ELSE
        topStep := 1;
    END_CASE

    // For each produced sheet, take one knife position then jump by step
    FOR knifePositionTopIndex := 1 TO currentOrder.order1.sheetQuantity BY 1 DO
        knifePositionArr[knifeOutIdx] := toolPositionArr[knifeDistributionIndex];
        knifeOutIdx := knifeOutIdx + 1;
        knifeDistributionIndex := knifeDistributionIndex + topStep;
    END_FOR

    // Final knife after last top box (end of top order)
    knifePositionArr[knifeOutIdx] := toolPositionArr[knifeDistributionIndex];
    knifeOutIdx := knifeOutIdx + 1;

END_IF

{endregion}


{region "Knife Position Selection — BOTTOM distribution"}

IF useOrder2 THEN

    bottomStep := 1;
    CASE currentOrder.order2.sheetType OF
        SHEET_WITH_NO_SCORER:   bottomStep := 1;
        SHEET_WITH_TWO_SCORER:  bottomStep := 3;
        SHEET_WITH_FOUR_SCORER: bottomStep := 5;
    ELSE
        bottomStep := 1;
    END_CASE

    // If TOP and BOTTOM are enabled, the start knife of bottom equals the last knife of top.
    // Therefore, DO NOT write the shared boundary again.
    IF userOrder1 THEN

        // BOTH enabled: write only END-OF-SHEET knives for bottom
        FOR knifePositionBottomIndex := 1 TO currentOrder.order2.sheetQuantity BY 1 DO
            knifeDistributionIndex := knifeDistributionIndex + bottomStep;          // move to end-of-sheet
            knifePositionArr[knifeOutIdx] := toolPositionArr[knifeDistributionIndex];
            knifeOutIdx := knifeOutIdx + 1;
        END_FOR

    ELSE

        // BOTTOM only: legacy behavior (start + final)
        FOR knifePositionBottomIndex := 1 TO currentOrder.order2.sheetQuantity BY 1 DO
            knifePositionArr[knifeOutIdx] := toolPositionArr[knifeDistributionIndex];
            knifeOutIdx := knifeOutIdx + 1;
            knifeDistributionIndex := knifeDistributionIndex + bottomStep;
        END_FOR

        // Final knife after last bottom box
        knifePositionArr[knifeOutIdx] := toolPositionArr[knifeDistributionIndex];
        knifeOutIdx := knifeOutIdx + 1;

    END_IF

END_IF

ACT_KnifePositionDistribution();
	 
{endregion}


]]></ST>
      </Implementation>
    </Action>
    <Action Name="ACT_ScorerPositionDistribution" Id="{f682c022-9042-44a3-bec0-01ef0aa9a1db}">
      <Implementation>
        <ST><![CDATA[(*===============================================================================================================================
CPNTeck - Automação Industrial
(c)Copyright 2022-2025 All Rights Reserved
_______________________________________________________________________________________________________________________________
Functionality: Scorer Distribution Logic (Merged Version)
Target: MRBRASIL Logic with COCELPA Variable Naming
_______________________________________________________________________________________________________________________________
Change log table:
Version      | Date          | Expert in charge | Changes applied
01.00.05     | 17.02.2026   | Gemini AI        | Merged MRBRASIL logic into COCELPA naming structure
                                               | (Uses .order1/.order2 and active Home positioning)
===============================================================================================================================*)

// Verifica se ambos os pedidos não possuem vincadores
IF currentOrder.order1.sheetType = SHEET_WITH_NO_SCORER AND currentOrder.order2.sheetType = SHEET_WITH_NO_SCORER THEN
    // Lógica MRBRASIL: Envia para home E desabilita
    FOR i := 1 TO 8 DO
        currentOrder.generatedOrder.scorerPositionReferenceArr[i] := machineConfig.homePositionScorer[i];
        currentOrder.generatedOrder.scorerEnabledArr[i] := FALSE;
    END_FOR

ELSE
    // Default: Reset preventivo para Home (Comportamento MRBRASIL)
    FOR i := 1 TO 8 DO
        currentOrder.generatedOrder.scorerPositionReferenceArr[i] := machineConfig.homePositionScorer[i];
        currentOrder.generatedOrder.scorerEnabledArr[i] := FALSE;
    END_FOR

    //──────────────────────────────────────────────────────────────────────────────
    // Top Order Logic (Usando .order1 da COCELPA)
    //──────────────────────────────────────────────────────────────────────────────
    CASE currentOrder.order1.sheetQuantity OF
        1:
            CASE currentOrder.order1.sheetType OF
                SHEET_WITH_TWO_SCORER:
                    // Option 1: Scorer 3 e 4
                    IF NOT (scorerPositionArr[1] > machineConfig.scorerMaxPostionArr[3] OR
                        scorerPositionArr[2] > machineConfig.scorerMaxPostionArr[4] OR
                        scorerPositionArr[1] < machineConfig.scorerMinPostionArr[3] OR
                        scorerPositionArr[2] < machineConfig.scorerMinPostionArr[4]) THEN
                        currentOrder.generatedOrder.scorerPositionReferenceArr[3] := scorerPositionArr[1];
                        currentOrder.generatedOrder.scorerPositionReferenceArr[4] := scorerPositionArr[2];
                        currentOrder.generatedOrder.scorerEnabledArr[3] := TRUE;
                        currentOrder.generatedOrder.scorerEnabledArr[4] := TRUE;
                
                    // Option 2: Scorer 5 e 6
                    ELSIF NOT (scorerPositionArr[1] > machineConfig.scorerMaxPostionArr[5] OR
                        scorerPositionArr[2] > machineConfig.scorerMaxPostionArr[6] OR
                        scorerPositionArr[1] < machineConfig.scorerMinPostionArr[5] OR
                        scorerPositionArr[2] < machineConfig.scorerMinPostionArr[6]) THEN
                        currentOrder.generatedOrder.scorerPositionReferenceArr[5] := scorerPositionArr[1];
                        currentOrder.generatedOrder.scorerPositionReferenceArr[6] := scorerPositionArr[2];
                        currentOrder.generatedOrder.scorerEnabledArr[5] := TRUE;
                        currentOrder.generatedOrder.scorerEnabledArr[6] := TRUE;
                
                    // Option 3: Scorer 3 e 5
                    ELSIF NOT (scorerPositionArr[1] > machineConfig.scorerMaxPostionArr[3] OR
                        scorerPositionArr[2] > machineConfig.scorerMaxPostionArr[5] OR
                        scorerPositionArr[1] < machineConfig.scorerMinPostionArr[3] OR
                        scorerPositionArr[2] < machineConfig.scorerMinPostionArr[5]) THEN
                        currentOrder.generatedOrder.scorerPositionReferenceArr[3] := scorerPositionArr[1];
                        currentOrder.generatedOrder.scorerPositionReferenceArr[5] := scorerPositionArr[2];
                        currentOrder.generatedOrder.scorerEnabledArr[3] := TRUE;
                        currentOrder.generatedOrder.scorerEnabledArr[5] := TRUE;
                
                    // Option 4: Scorer 4 e 6
                    ELSIF NOT (scorerPositionArr[1] > machineConfig.scorerMaxPostionArr[4] OR
                        scorerPositionArr[2] > machineConfig.scorerMaxPostionArr[6] OR
                        scorerPositionArr[1] < machineConfig.scorerMinPostionArr[4] OR
                        scorerPositionArr[2] < machineConfig.scorerMinPostionArr[6]) THEN
                        currentOrder.generatedOrder.scorerPositionReferenceArr[4] := scorerPositionArr[1];
                        currentOrder.generatedOrder.scorerPositionReferenceArr[6] := scorerPositionArr[2];
                        currentOrder.generatedOrder.scorerEnabledArr[4] := TRUE;
                        currentOrder.generatedOrder.scorerEnabledArr[6] := TRUE;
                
                    // Option 5: Scorer 1 e 2 (+ aux 150mm)
                    ELSIF NOT (scorerPositionArr[1] > machineConfig.scorerMaxPostionArr[1] OR
                        scorerPositionArr[2] > machineConfig.scorerMaxPostionArr[2] OR
                        scorerPositionArr[1] + 150 > machineConfig.scorerMaxPostionArr[3] OR
                        scorerPositionArr[2] + 150 > machineConfig.scorerMaxPostionArr[4] OR
                        scorerPositionArr[1] < machineConfig.scorerMinPostionArr[1] OR
                        scorerPositionArr[2] < machineConfig.scorerMinPostionArr[2]) THEN
                        currentOrder.generatedOrder.scorerPositionReferenceArr[1] := scorerPositionArr[1];
                        currentOrder.generatedOrder.scorerPositionReferenceArr[2] := scorerPositionArr[2];
                        currentOrder.generatedOrder.scorerPositionReferenceArr[3] := scorerPositionArr[1] + 160;
                        currentOrder.generatedOrder.scorerPositionReferenceArr[4] := scorerPositionArr[2] + 160;
                        currentOrder.generatedOrder.scorerEnabledArr[1] := TRUE;
                        currentOrder.generatedOrder.scorerEnabledArr[2] := TRUE;
                
                    // Option 6: Scorer 1 e 3
                    ELSIF NOT (scorerPositionArr[1] > machineConfig.scorerMaxPostionArr[1] OR
                        scorerPositionArr[2] > machineConfig.scorerMaxPostionArr[3] OR
                        scorerPositionArr[1] < machineConfig.scorerMinPostionArr[1] OR
                        scorerPositionArr[2] < machineConfig.scorerMinPostionArr[3]) THEN
                        currentOrder.generatedOrder.scorerPositionReferenceArr[1] := scorerPositionArr[1];
                        currentOrder.generatedOrder.scorerPositionReferenceArr[3] := scorerPositionArr[2];
                        currentOrder.generatedOrder.scorerEnabledArr[1] := TRUE;
                        currentOrder.generatedOrder.scorerEnabledArr[3] := TRUE;
                
                    // Option 7: Scorer 2 e 4
                    ELSIF NOT (scorerPositionArr[1] > machineConfig.scorerMaxPostionArr[2] OR
                        scorerPositionArr[2] > machineConfig.scorerMaxPostionArr[4] OR
                        scorerPositionArr[1] < machineConfig.scorerMinPostionArr[2] OR
                        scorerPositionArr[2] < machineConfig.scorerMinPostionArr[4]) THEN
                        currentOrder.generatedOrder.scorerPositionReferenceArr[2] := scorerPositionArr[1];
                        currentOrder.generatedOrder.scorerPositionReferenceArr[4] := scorerPositionArr[2];
                        currentOrder.generatedOrder.scorerEnabledArr[2] := TRUE;
                        currentOrder.generatedOrder.scorerEnabledArr[4] := TRUE;
                    END_IF;

                SHEET_WITH_FOUR_SCORER:
                    FOR i := 1 TO 4 DO
                        currentOrder.generatedOrder.scorerPositionReferenceArr[i] := scorerPositionArr[i];
                        currentOrder.generatedOrder.scorerEnabledArr[i] := TRUE;
                    END_FOR;
            END_CASE;

        2:
            CASE currentOrder.order1.sheetType OF
                SHEET_WITH_TWO_SCORER:
                    FOR i := 1 TO 4 DO
                        currentOrder.generatedOrder.scorerPositionReferenceArr[i] := scorerPositionArr[i];
                        currentOrder.generatedOrder.scorerEnabledArr[i] := TRUE;
                    END_FOR;
                SHEET_WITH_FOUR_SCORER:
                    FOR i := 1 TO 8 DO
                        currentOrder.generatedOrder.scorerPositionReferenceArr[i] := scorerPositionArr[i];
                        currentOrder.generatedOrder.scorerEnabledArr[i] := TRUE;
                    END_FOR;
            END_CASE;

        3:
            FOR i := 1 TO 6 DO
                currentOrder.generatedOrder.scorerPositionReferenceArr[i + 1] := scorerPositionArr[i];
                currentOrder.generatedOrder.scorerEnabledArr[i + 1] := TRUE;
            END_FOR;

        4, 5:
            FOR i := 1 TO 8 DO
                currentOrder.generatedOrder.scorerPositionReferenceArr[i] := scorerPositionArr[i];
                currentOrder.generatedOrder.scorerEnabledArr[i] := TRUE;
            END_FOR;
    END_CASE;

    //──────────────────────────────────────────────────────────────────────────────
    // Bottom Order Logic (Usando .order2 da COCELPA)
    //──────────────────────────────────────────────────────────────────────────────
    IF currentOrder.order2.sheetQuantity > 0 THEN
        // Se order1 não usa vincadores, order2 pode começar do índice 1
        IF currentOrder.order1.sheetQuantity > 0 AND currentOrder.order1.sheetType = SHEET_WITH_NO_SCORER THEN
            CASE currentOrder.order2.sheetQuantity OF
                1:
                    CASE currentOrder.order2.sheetType OF
                        SHEET_WITH_TWO_SCORER:
                            // Tenta posicionar conforme limites (Lógica MRBRASIL aplicada à order2)
                            IF NOT (scorerPositionArr[1] > machineConfig.scorerMaxPostionArr[3] OR
                                scorerPositionArr[2] > machineConfig.scorerMaxPostionArr[4] OR
                                scorerPositionArr[1] < machineConfig.scorerMinPostionArr[3] OR
                                scorerPositionArr[2] < machineConfig.scorerMinPostionArr[4]) THEN
                                currentOrder.generatedOrder.scorerPositionReferenceArr[3] := scorerPositionArr[1];
                                currentOrder.generatedOrder.scorerPositionReferenceArr[4] := scorerPositionArr[2];
                                currentOrder.generatedOrder.scorerEnabledArr[3] := TRUE;
                                currentOrder.generatedOrder.scorerEnabledArr[4] := TRUE;
                            ELSIF NOT (scorerPositionArr[1] > machineConfig.scorerMaxPostionArr[5] OR
                                scorerPositionArr[2] > machineConfig.scorerMaxPostionArr[6] OR
                                scorerPositionArr[1] < machineConfig.scorerMinPostionArr[5] OR
                                scorerPositionArr[2] < machineConfig.scorerMinPostionArr[6]) THEN
                                currentOrder.generatedOrder.scorerPositionReferenceArr[5] := scorerPositionArr[1];
                                currentOrder.generatedOrder.scorerPositionReferenceArr[6] := scorerPositionArr[2];
                                currentOrder.generatedOrder.scorerEnabledArr[5] := TRUE;
                                currentOrder.generatedOrder.scorerEnabledArr[6] := TRUE;
                            END_IF;
                        SHEET_WITH_FOUR_SCORER:
                            FOR i := 1 TO 4 DO
                                currentOrder.generatedOrder.scorerPositionReferenceArr[i] := scorerPositionArr[i];
                                currentOrder.generatedOrder.scorerEnabledArr[i] := TRUE;
                            END_FOR;
                    END_CASE;

                2:
                    FOR i := 1 TO 4 DO
                        currentOrder.generatedOrder.scorerPositionReferenceArr[i + 4] := scorerPositionArr[i];
                        currentOrder.generatedOrder.scorerEnabledArr[i + 4] := TRUE;
                    END_FOR;

                3:
                    FOR i := 1 TO 6 DO
                        currentOrder.generatedOrder.scorerPositionReferenceArr[i] := scorerPositionArr[i];
                        currentOrder.generatedOrder.scorerEnabledArr[i] := TRUE;
                    END_FOR;

                4, 5:
                    FOR i := 1 TO 8 DO
                        currentOrder.generatedOrder.scorerPositionReferenceArr[i] := scorerPositionArr[i];
                        currentOrder.generatedOrder.scorerEnabledArr[i] := TRUE;
                    END_FOR;
            END_CASE;

        ELSE
            // Se order1 já está ocupando ferramentas, order2 começa do índice 5
            CASE currentOrder.order2.sheetQuantity OF
                1:
                    CASE currentOrder.order2.sheetType OF
                        SHEET_WITH_TWO_SCORER:
                            currentOrder.generatedOrder.scorerPositionReferenceArr[5] := scorerPositionArr[numberOfScorersTopOrder + 1];
                            currentOrder.generatedOrder.scorerPositionReferenceArr[6] := scorerPositionArr[numberOfScorersTopOrder + 2];
                            currentOrder.generatedOrder.scorerEnabledArr[5] := TRUE;
                            currentOrder.generatedOrder.scorerEnabledArr[6] := TRUE;
                        SHEET_WITH_FOUR_SCORER:
                            FOR i := 5 TO 8 DO
                                currentOrder.generatedOrder.scorerPositionReferenceArr[i] := scorerPositionArr[i - 4];
                                currentOrder.generatedOrder.scorerEnabledArr[i] := TRUE;
                            END_FOR;
                    END_CASE;

                2:
                    FOR i := 5 TO 8 DO
                        currentOrder.generatedOrder.scorerPositionReferenceArr[i] := scorerPositionArr[i - 4];
                        currentOrder.generatedOrder.scorerEnabledArr[i] := TRUE;
                    END_FOR;

                3:
                    FOR i := 5 TO 8 DO
                        currentOrder.generatedOrder.scorerPositionReferenceArr[i] := scorerPositionArr[i - 2];
                        currentOrder.generatedOrder.scorerEnabledArr[i] := TRUE;
                    END_FOR;

                4, 5:
                    FOR i := 5 TO 8 DO
                        currentOrder.generatedOrder.scorerPositionReferenceArr[i] := scorerPositionArr[i];
                        currentOrder.generatedOrder.scorerEnabledArr[i] := TRUE;
                    END_FOR;
            END_CASE;
        END_IF;
    END_IF;
END_IF;

// Validação final (Limits check)
_checkOrderLimits();]]></ST>
      </Implementation>
    </Action>
    <Action Name="ACT_ScorerPositionSelection" Id="{14131191-f43e-4ad4-9138-b6130970c9a3}">
      <Implementation>
        <ST><![CDATA[
(*==============================================================================================================================
CPNTeck - Automação industrial
(c)Copyright 2022 All Rights Reserved
_______________________________________________________________________________________________________________________________
Library: N/A 
Tested with: CX5140
Engineering: Twincat 3
Restrictions: -
Requirements: N/A
Functionality: This function block offers basic functionalities for distribute the positions generated from the program to the scoring toll
Support: fabio@cpnteck.com.br
Note: Parameter comments are only available in language 'English (United States)'
_______________________________________________________________________________________________________________________________
Change log table:

Version  		| Date        			| Expert in charge  	| Changes applied
01.00.01		| 29.03.2023  		| Fabio Campion            | First released version



===============================================================================================================================*)

(*Reset the scorer enabled array*)
FOR scorerEnabledIndex := 1 TO 20 BY 1 DO

	currentOrder.generatedOrder.scorerEnabledArr[scorerEnabledIndex] := FALSE;
	scorerPositionArr[scorerEnabledIndex] := 0;
	currentOrder.generatedOrder.scorerPositionReferenceArr[scorerEnabledIndex] := 0;

END_FOR;


scorerDistributionIndex := 1;
toolDistributionIndex := 2;
scorerExecTimes := 0;

(*Calculate the number of scorers to be used in the production*)

ACT_CalculateNumberOfScorers();


(*Distribute the scorer positions*)
IF currentOrder.generatedOrder.numberOfScorers > 0 THEN

	(*Distribute the scorer position for sheets with no scorer (Only count the sheets)*)
	IF currentOrder.order1.sheetType = SHEET_WITH_NO_SCORER THEN

		FOR scorerPositionTopIndex := 1 TO currentOrder.order1.sheetQuantity BY 1 DO

			toolDistributionIndex := toolDistributionIndex + 1;

		END_FOR

	END_IF

	(*Distribute the scorer position for sheets with two scorer*)
	IF currentOrder.order1.sheetType = SHEET_WITH_TWO_SCORER THEN

		scorerExecTimes := 0;

		FOR scorerPositionTopIndex := 1 TO currentOrder.order1.sheetQuantity BY 1 DO

			scorerExecTimes := scorerExecTimes + 1;

			scorerPositionArr[scorerDistributionIndex] := toolPositionArr[toolDistributionIndex];
			scorerDistributionIndex := scorerDistributionIndex + 1;
			toolDistributionIndex := toolDistributionIndex + 1;

			scorerPositionArr[scorerDistributionIndex] := toolPositionArr[toolDistributionIndex];
			scorerDistributionIndex := scorerDistributionIndex + 1;
			toolDistributionIndex := toolDistributionIndex + 2;

		END_FOR

	END_IF

	(*Distribute the scorer position for sheets with four scorer*)
	IF currentOrder.order1.sheetType = SHEET_WITH_FOUR_SCORER THEN

		scorerExecTimes :=0;

		FOR scorerPositionTopIndex := 1 TO currentOrder.order1.sheetQuantity BY 1 DO


			scorerPositionArr[scorerDistributionIndex] := toolPositionArr[toolDistributionIndex];
			scorerDistributionIndex := scorerDistributionIndex + 1;
			toolDistributionIndex := toolDistributionIndex + 1;

			scorerPositionArr[scorerDistributionIndex] := toolPositionArr[toolDistributionIndex];
			scorerDistributionIndex := scorerDistributionIndex + 1;
			toolDistributionIndex := toolDistributionIndex + 1;

			scorerPositionArr[scorerDistributionIndex] := toolPositionArr[toolDistributionIndex];
			scorerDistributionIndex := scorerDistributionIndex + 1;
			toolDistributionIndex := toolDistributionIndex + 1;

			scorerPositionArr[scorerDistributionIndex] := toolPositionArr[toolDistributionIndex];
			scorerDistributionIndex := scorerDistributionIndex + 1;
			toolDistributionIndex := toolDistributionIndex + 2;
			

		END_FOR

	END_IF

	(*Distribute the scorer position for sheets with two scorer - bottom orderr*)
	IF currentOrder.order2.sheetType = SHEET_WITH_TWO_SCORER THEN

		scorerExecTimes := 0;

		FOR scorerPositionBottomIndex := 1 TO currentOrder.order2.sheetQuantity BY 1 DO

			scorerExecTimes := scorerExecTimes + 1;

			scorerPositionArr[scorerDistributionIndex] := toolPositionArr[toolDistributionIndex];
			scorerDistributionIndex := scorerDistributionIndex + 1;
			toolDistributionIndex := toolDistributionIndex + 1;

			scorerPositionArr[scorerDistributionIndex] := toolPositionArr[toolDistributionIndex];
			scorerDistributionIndex := scorerDistributionIndex + 1;
			toolDistributionIndex := toolDistributionIndex + 2;

		END_FOR

	END_IF

	(*Distribute the scorer position for sheets with four scorer - bottom orderr*)
	IF currentOrder.order2.sheetType = SHEET_WITH_FOUR_SCORER THEN

		scorerExecTimes := 0;

		FOR scorerPositionBottomIndex := 1 TO currentOrder.order2.sheetQuantity BY 1 DO

			scorerPositionArr[scorerDistributionIndex] := toolPositionArr[toolDistributionIndex];
			scorerDistributionIndex := scorerDistributionIndex + 1;
			toolDistributionIndex := toolDistributionIndex + 1;

			scorerPositionArr[scorerDistributionIndex] := toolPositionArr[toolDistributionIndex];
			scorerDistributionIndex := scorerDistributionIndex + 1;
			toolDistributionIndex := toolDistributionIndex + 1;

			scorerPositionArr[scorerDistributionIndex] := toolPositionArr[toolDistributionIndex];
			scorerDistributionIndex := scorerDistributionIndex + 1;
			toolDistributionIndex := toolDistributionIndex + 1;

			scorerPositionArr[scorerDistributionIndex] := toolPositionArr[toolDistributionIndex];
			scorerDistributionIndex := scorerDistributionIndex + 1;
			toolDistributionIndex := toolDistributionIndex + 2;

		END_FOR

	END_IF

END_IF

//ACT_ScorerPositionDistribution();
_scorerPositionDistribution_1();

]]></ST>
      </Implementation>
    </Action>
