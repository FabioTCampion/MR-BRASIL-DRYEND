//IF executePositioning AND NOT executePositioningOld THEN

	instFbCurrentOrderPositionsGeneration(execute := TRUE,
		machineConfig := machineConfig,
		currentOrder := currentOrder);
			
	IF NOT currentOrder.generatedOrder.statusWord.orderNotOk THEN
		
		instTONExecutePositioningDelay.IN := TRUE;
		positioningStarted	:= TRUE;

	END_IF

END_IF

executePositioningOld := executePositioning;

instTONExecutePositioningDelay(PT:=T#1S);



//Knife 1 - Axis control function block call
//__________________________________________________________________________
instFB_AxisControlKnife1_Axis(
    enable := TRUE,
	fastStop := haltAxis,
    enableAxis := enableAxis,
    resetAxis := resetCmd,
	posAbsolute := instTONExecutePositioningDelay.Q,
	posRelative	:= hmiCommands.slitter1.knifePosCorrectionArr[1].execute,
	jogForward := hmiCommands.slitter1.knifeJogArr[1].jogFw AND NOT homeSensorKnife2 AND homeFinished,
	jogBackward	:= hmiCommands.slitter1.knifeJogArr[1].jogRev AND NOT homeSensorKnife1 AND homeFinished,
    homingSensor := homeSensorKnife1,
    axis := knife1_Axis,
    master := knife1_Axis,
    configuration := knife1_AxisConfiguration
);

