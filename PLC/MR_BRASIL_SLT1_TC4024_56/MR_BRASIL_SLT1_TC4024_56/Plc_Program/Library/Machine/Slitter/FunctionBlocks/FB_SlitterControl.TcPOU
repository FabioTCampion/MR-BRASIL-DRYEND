    <Method Name="_slitterDisplacement" Id="{59e17e64-bca6-4d34-b5cc-8563a8055129}">
      <Declaration><![CDATA[METHOD PRIVATE _slitterDisplacement
VAR_INPUT
END_VAR
(*
    moveSlitterOperatorSideLimit : BOOL;
    moveSlitterMotorSideLimit    : BOOL;

*)]]></Declaration>
      <Implementation>
        <ST><![CDATA[    // Slitter movement controls
moveSlitterOperatorSide :=	moveSlitterOperatorSideCmd AND NOT moveSlitterMotorSideCmd AND moveSlitterOperatorSideLimit AND safetyOK;
moveSlitterMotorSide :=	moveSlitterMotorSideCmd   AND NOT moveSlitterOperatorSideCmd AND moveSlitterMotorSideLimit AND safetyOK;

moveSlitterOperatorSideLamp := moveSlitterOperatorSide;
moveSlitterMotorSideLamp    := moveSlitterMotorSide;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_slitterPaperDirectionControl" Id="{dead6df0-9cc5-4cb0-8dab-0f169082ec75}">
      <Declaration><![CDATA[METHOD _slitterPaperDirectionControl
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Call the Function Block (Execute when the positioning finishes)

//Check for rising edge
instRTrigToolsInPosition(CLK := bAllKnivesInPos);


//Confirm the current order position before set the flap positions
IF hmiCommands.slitter1.flapsSetAuto AND NOT flapsSetAutoOld THEN
	
	
	instFbCurrentOrderPositionsGeneration(execute := TRUE,
		machineConfig := machineConfig,
		currentOrder := currentOrder);
	
END_IF
flapsSetAutoOld := hmiCommands.slitter1.flapsSetAuto;

instFB_PaperDirectionControl(
	executeCmd := instRTrigToolsInPosition.Q OR hmiCommands.slitter1.flapsSetAuto,
	allUPCmd := hmiCommands.slitter1.flapsAllUP,
	allDownCmd := hmiCommands.slitter1.flapsAllDown,
	invertDirection := hmiCommands.slitter1.flapsInvertDirection,
    currentOrder  := currentOrder, 
    machineConfig := machineConfig,
	flapsManualCmdArr := flapsManualCmdArr
);


// Map internal array to physical output variables
paperDirectionFlap01 := NOT instFB_PaperDirectionControl.flapSolenoidArr[1];
paperDirectionFlap02 := NOT instFB_PaperDirectionControl.flapSolenoidArr[2];
paperDirectionFlap03 := NOT instFB_PaperDirectionControl.flapSolenoidArr[3];
paperDirectionFlap04 := NOT instFB_PaperDirectionControl.flapSolenoidArr[4];
paperDirectionFlap05 := NOT instFB_PaperDirectionControl.flapSolenoidArr[5];
paperDirectionFlap06 := NOT instFB_PaperDirectionControl.flapSolenoidArr[6];
paperDirectionFlap07 := NOT instFB_PaperDirectionControl.flapSolenoidArr[7];
paperDirectionFlap08 := NOT instFB_PaperDirectionControl.flapSolenoidArr[8];
paperDirectionFlap09 := NOT instFB_PaperDirectionControl.flapSolenoidArr[9];
paperDirectionFlap10 := NOT instFB_PaperDirectionControl.flapSolenoidArr[10];
paperDirectionFlap11 := NOT instFB_PaperDirectionControl.flapSolenoidArr[11];
paperDirectionFlap12 := NOT instFB_PaperDirectionControl.flapSolenoidArr[12];

]]></ST>
      </Implementation>
    </Method>
    <Method Name="_startStopCutting" Id="{f61a76db-af64-43ea-a15e-4a4e4e496bdf}">
      <Declaration><![CDATA[METHOD PRIVATE _startStopCutting
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF startCuttingCmd THEN
	
	startCutting := TRUE;

END_IF

IF stopCuttingCmd THEN
	
	startCutting := FALSE;;

END_IF


startCuttingLamp := startCutting;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_startTractionMotor" Id="{f6d921f0-6e94-4d9f-81bb-0b55aae7222a}">
      <Declaration><![CDATA[METHOD _startTractionMotor
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF startTractionMotorCmd AND safetyOK THEN
	
    // Motor commands
    knifeMotorStart         := TRUE;
    scorerMotorStart        := TRUE;
	tractionEnabledLamp		:= TRUE;
ELSE
	
    // Motor commands
    knifeMotorStart         := FALSE;
    scorerMotorStart        := FALSE;
	tractionEnabledLamp		:= FALSE;	
	
END_IF

	
	IF NOT aocRunning THEN
	
			slitterKnifeDriveRef := LIMIT(machineConfig.minLineSpeed,
										  lineSpeedMPM,
										  999) * machineConfig.knifeSpeedOffset;	
			
			slitterScorerDriveRef := LIMIT(machineConfig.minLineSpeed,
										  lineSpeedMPM,
										  999) * machineConfig.scorerSpeedOffset;		
		
		ELSE
		
			slitterKnifeDriveRef := LIMIT(machineConfig.minLineSpeed,
										  aocSpeedMPM,
										  999) * machineConfig.knifeSpeedOffset;	
			
			slitterScorerDriveRef := LIMIT(machineConfig.minLineSpeed,
										  aocSpeedMPM,
										  999) * machineConfig.scorerSpeedOffset;			
		
		END_IF


    // Zero references when drives are not commanded to run to prevent stale setpoints
IF NOT knifeMotorStart THEN
	slitterKnifeDriveRef := 0.0;
END_IF;

IF NOT scorerMotorStart THEN
	slitterScorerDriveRef := 0.0;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_toolEnabledLamp" Id="{21d40d44-5b93-41ee-96bb-ec1adbc84686}">
      <Declaration><![CDATA[METHOD PRIVATE _toolEnabledLamp
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[knife1EnabledLamp :=  knife1Enabled;
knife2EnabledLamp :=  knife2Enabled;
knife3EnabledLamp :=  knife3Enabled;
knife4EnabledLamp :=  knife4Enabled;
knife5EnabledLamp :=  knife5Enabled;

scorer1EnabledLamp := scorer1Enabled;
scorer2EnabledLamp := scorer2Enabled;
scorer3EnabledLamp := scorer3Enabled;
scorer4EnabledLamp := scorer4Enabled;
scorer5EnabledLamp := scorer5Enabled;
scorer6EnabledLamp := scorer6Enabled;
scorer7EnabledLamp := scorer7Enabled;
scorer8EnabledLamp := scorer8Enabled;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_toolsUpDownControl" Id="{97d78b3b-64ef-4b19-b6f0-624c17a18a5b}">
      <Declaration><![CDATA[METHOD PRIVATE _toolsUpDownControl
VAR_INPUT
END_VAR
(*
	knife1Enabled						: BOOL;	//Knife 1 - Solenoid enabled
	knife2Enabled						: BOOL;	//Knife 1 - Solenoid enabled
	knife3Enabled						: BOOL;	//Knife 1 - Solenoid enabled
	knife4Enabled						: BOOL;	//Knife 1 - Solenoid enabled
	knife5Enabled						: BOOL;	//Knife 1 - Solenoid enabled

	scorer1Enabled						: BOOL;	//Scorer 1 - Solenoid enabled
	scorer2Enabled						: BOOL;	//Scorer 2 - Solenoid enabled
	scorer3Enabled						: BOOL;	//Scorer 3 - Solenoid enabled
	scorer4Enabled						: BOOL;	//Scorer 4 - Solenoid enabled
	scorer5Enabled						: BOOL;	//Scorer 5 - Solenoid enabled
	scorer6Enabled						: BOOL;	//Scorer 6 - Solenoid enabled
	scorer7Enabled						: BOOL;	//Scorer 7 - Solenoid enabled
	scorer8Enabled						: BOOL;	//Scorer 8 - Solenoid enabled*)
VAR

END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// ===================== KNIFES 1..5 =====================
IF knife1EnabledCmd AND NOT knife1EnabledCmdOld THEN
    IF currentOrder.generatedOrder.knifeEnabledArr[1] THEN
        currentOrder.generatedOrder.knifeEnabledArr[1] := FALSE;
    ELSE
        currentOrder.generatedOrder.knifeEnabledArr[1] := TRUE;
    END_IF
END_IF
knife1EnabledCmdOld := knife1EnabledCmd;

IF knife2EnabledCmd AND NOT knife2EnabledCmdOld THEN
    IF currentOrder.generatedOrder.knifeEnabledArr[2] THEN
        currentOrder.generatedOrder.knifeEnabledArr[2] := FALSE;
    ELSE
        currentOrder.generatedOrder.knifeEnabledArr[2] := TRUE;
    END_IF
END_IF
knife2EnabledCmdOld := knife2EnabledCmd;

IF knife3EnabledCmd AND NOT knife3EnabledCmdOld THEN
    IF currentOrder.generatedOrder.knifeEnabledArr[3] THEN
        currentOrder.generatedOrder.knifeEnabledArr[3] := FALSE;
    ELSE
        currentOrder.generatedOrder.knifeEnabledArr[3] := TRUE;
    END_IF
END_IF
knife3EnabledCmdOld := knife3EnabledCmd;

IF knife4EnabledCmd AND NOT knife4EnabledCmdOld THEN
    IF currentOrder.generatedOrder.knifeEnabledArr[4] THEN
        currentOrder.generatedOrder.knifeEnabledArr[4] := FALSE;
    ELSE
        currentOrder.generatedOrder.knifeEnabledArr[4] := TRUE;
    END_IF
END_IF
knife4EnabledCmdOld := knife4EnabledCmd;

IF knife5EnabledCmd AND NOT knife5EnabledCmdOld THEN
    IF currentOrder.generatedOrder.knifeEnabledArr[5] THEN
        currentOrder.generatedOrder.knifeEnabledArr[5] := FALSE;
    ELSE
        currentOrder.generatedOrder.knifeEnabledArr[5] := TRUE;
    END_IF
END_IF
knife5EnabledCmdOld := knife5EnabledCmd;


// ===================== SCORERS 1..8 =====================
IF scorer1EnabledCmd AND NOT scorer1EnabledCmdOld THEN
    IF currentOrder.generatedOrder.scorerEnabledArr[1] THEN
        currentOrder.generatedOrder.scorerEnabledArr[1] := FALSE;
    ELSE
        currentOrder.generatedOrder.scorerEnabledArr[1] := TRUE;
    END_IF
END_IF
scorer1EnabledCmdOld := scorer1EnabledCmd;

IF scorer2EnabledCmd AND NOT scorer2EnabledCmdOld THEN
    IF currentOrder.generatedOrder.scorerEnabledArr[2] THEN
        currentOrder.generatedOrder.scorerEnabledArr[2] := FALSE;
    ELSE
        currentOrder.generatedOrder.scorerEnabledArr[2] := TRUE;
    END_IF
END_IF
scorer2EnabledCmdOld := scorer2EnabledCmd;

IF scorer3EnabledCmd AND NOT scorer3EnabledCmdOld THEN
    IF currentOrder.generatedOrder.scorerEnabledArr[3] THEN
        currentOrder.generatedOrder.scorerEnabledArr[3] := FALSE;
    ELSE
        currentOrder.generatedOrder.scorerEnabledArr[3] := TRUE;
    END_IF
END_IF
scorer3EnabledCmdOld := scorer3EnabledCmd;

IF scorer4EnabledCmd AND NOT scorer4EnabledCmdOld THEN
    IF currentOrder.generatedOrder.scorerEnabledArr[4] THEN
        currentOrder.generatedOrder.scorerEnabledArr[4] := FALSE;
    ELSE
        currentOrder.generatedOrder.scorerEnabledArr[4] := TRUE;
    END_IF
END_IF
scorer4EnabledCmdOld := scorer4EnabledCmd;

IF scorer5EnabledCmd AND NOT scorer5EnabledCmdOld THEN
    IF currentOrder.generatedOrder.scorerEnabledArr[5] THEN
        currentOrder.generatedOrder.scorerEnabledArr[5] := FALSE;
    ELSE
        currentOrder.generatedOrder.scorerEnabledArr[5] := TRUE;
    END_IF
END_IF
scorer5EnabledCmdOld := scorer5EnabledCmd;

IF scorer6EnabledCmd AND NOT scorer6EnabledCmdOld THEN
    IF currentOrder.generatedOrder.scorerEnabledArr[6] THEN
        currentOrder.generatedOrder.scorerEnabledArr[6] := FALSE;
    ELSE
        currentOrder.generatedOrder.scorerEnabledArr[6] := TRUE;
    END_IF
END_IF
scorer6EnabledCmdOld := scorer6EnabledCmd;

IF scorer7EnabledCmd AND NOT scorer7EnabledCmdOld THEN
    IF currentOrder.generatedOrder.scorerEnabledArr[7] THEN
        currentOrder.generatedOrder.scorerEnabledArr[7] := FALSE;
    ELSE
        currentOrder.generatedOrder.scorerEnabledArr[7] := TRUE;
    END_IF
END_IF
scorer7EnabledCmdOld := scorer7EnabledCmd;

IF scorer8EnabledCmd AND NOT scorer8EnabledCmdOld THEN
    IF currentOrder.generatedOrder.scorerEnabledArr[8] THEN
        currentOrder.generatedOrder.scorerEnabledArr[8] := FALSE;
    ELSE
        currentOrder.generatedOrder.scorerEnabledArr[8] := TRUE;
    END_IF
END_IF
scorer8EnabledCmdOld := scorer8EnabledCmd;





//-------------------------------------------------------------------------------------------------
// Detect if any knife or scorer axis is currently executing a motion command or positioning delay
//-------------------------------------------------------------------------------------------------
positioningRunning := 
    (instFB_AxisControlKnife1_Axis.commandBusy OR
    instFB_AxisControlKnife2_Axis.commandBusy OR
    instFB_AxisControlKnife3_Axis.commandBusy OR
    instFB_AxisControlKnife4_Axis.commandBusy OR
    instFB_AxisControlKnife5_Axis.commandBusy OR
    instFB_AxisControlScorer1_Axis.commandBusy OR
    instFB_AxisControlScorer2_Axis.commandBusy OR
    instFB_AxisControlScorer3_Axis.commandBusy OR
    instFB_AxisControlScorer4_Axis.commandBusy OR
    instFB_AxisControlScorer5_Axis.commandBusy OR
    instFB_AxisControlScorer6_Axis.commandBusy OR
    instFB_AxisControlScorer7_Axis.commandBusy OR  
    instFB_AxisControlScorer8_Axis.commandBusy) AND
    positioningStarted;

	
	inTargetPosition := knife1_Axis.Status.NotMoving AND
						knife2_Axis.Status.NotMoving AND
						knife3_Axis.Status.NotMoving AND
						knife4_Axis.Status.NotMoving AND
						knife5_Axis.Status.NotMoving AND						
						scorer1_Axis.Status.NotMoving AND
						scorer2_Axis.Status.NotMoving AND
						scorer3_Axis.Status.NotMoving AND	 
						scorer4_Axis.Status.NotMoving AND	 
						scorer5_Axis.Status.NotMoving AND	 
						scorer6_Axis.Status.NotMoving AND	 
						scorer7_Axis.Status.NotMoving AND	 
						scorer8_Axis.Status.NotMoving;	 
	 
	
bAllKnivesInPos := NOT positioningRunning AND
						NOT positioningStarted AND
						knife1_Axis.Status.InTargetPosition AND
						knife2_Axis.Status.InTargetPosition AND
						knife3_Axis.Status.InTargetPosition AND
						knife4_Axis.Status.InTargetPosition AND
						knife5_Axis.Status.InTargetPosition;	
						
						
//-------------------------------------------------------------------------------------------------
// Enable signal for knives: Active only if tool is enabled AND machine is cutting AND not positioning
// Home override also enables it
//-------------------------------------------------------------------------------------------------
knife1Enabled := (currentOrder.generatedOrder.knifeEnabledArr[1] AND startCutting AND NOT positioningRunning) AND NOT homeRunning AND NOT positioningStarted AND inTargetPosition;
knife2Enabled := (currentOrder.generatedOrder.knifeEnabledArr[2] AND startCutting AND NOT positioningRunning) AND NOT homeRunning AND NOT positioningStarted AND inTargetPosition;
knife3Enabled := (currentOrder.generatedOrder.knifeEnabledArr[3] AND startCutting AND NOT positioningRunning) AND NOT homeRunning AND NOT positioningStarted AND inTargetPosition;
knife4Enabled := (currentOrder.generatedOrder.knifeEnabledArr[4] AND startCutting AND NOT positioningRunning) AND NOT homeRunning AND NOT positioningStarted AND inTargetPosition;
knife5Enabled := (currentOrder.generatedOrder.knifeEnabledArr[5] AND startCutting AND NOT positioningRunning) AND NOT homeRunning AND NOT positioningStarted AND inTargetPosition;

//-------------------------------------------------------------------------------------------------
// Enable signal for scorers: Same logic as for knives
//-------------------------------------------------------------------------------------------------
scorer1Enabled := (currentOrder.generatedOrder.scorerEnabledArr[1] AND startCutting AND NOT positioningRunning) AND NOT homeRunning AND NOT positioningStarted AND inTargetPosition;
scorer2Enabled := (currentOrder.generatedOrder.scorerEnabledArr[2] AND startCutting AND NOT positioningRunning) AND NOT homeRunning AND NOT positioningStarted AND inTargetPosition;
scorer3Enabled := (currentOrder.generatedOrder.scorerEnabledArr[3] AND startCutting AND NOT positioningRunning) AND NOT homeRunning AND NOT positioningStarted AND inTargetPosition;
scorer4Enabled := (currentOrder.generatedOrder.scorerEnabledArr[4] AND startCutting AND NOT positioningRunning) AND NOT homeRunning AND NOT positioningStarted AND inTargetPosition;
scorer5Enabled := (currentOrder.generatedOrder.scorerEnabledArr[5] AND startCutting AND NOT positioningRunning) AND NOT homeRunning AND NOT positioningStarted AND inTargetPosition;
scorer6Enabled := (currentOrder.generatedOrder.scorerEnabledArr[6] AND startCutting AND NOT positioningRunning) AND NOT homeRunning AND NOT positioningStarted AND inTargetPosition;
scorer7Enabled := (currentOrder.generatedOrder.scorerEnabledArr[7] AND startCutting AND NOT positioningRunning) AND NOT homeRunning AND NOT positioningStarted AND inTargetPosition;
scorer8Enabled := (currentOrder.generatedOrder.scorerEnabledArr[8] AND startCutting AND NOT positioningRunning) AND NOT homeRunning AND NOT positioningStarted AND inTargetPosition;
]]></ST>
      </Implementation>
    </Method>
