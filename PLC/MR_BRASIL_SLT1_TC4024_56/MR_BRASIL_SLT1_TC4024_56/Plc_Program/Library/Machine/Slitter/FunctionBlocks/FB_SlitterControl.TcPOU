<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_SlitterControl" Id="{0d2226ac-abc3-47ea-99cf-db2ca94f7b30}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_SlitterControl
VAR_INPUT
    // General control commands
    enableAxis              : BOOL;  // Enable/disable positioning axis motors
    startCuttingCmd            : BOOL;  // Start slitter cutting process\
    stopCuttingCmd            : BOOL;  // Stop slitter cutting process\
		
    executePositioning      : BOOL;  // Execute positioning sequence
    changeOrder             : BOOL;  // Execute Automatic Order Change (AOC)
    executeHome             : BOOL;  // Execute slitter homing
    generatePositions       : BOOL;  // Generate knife/scorer positions
    resetCmd                : BOOL;  // Reset commands and states
    autoManualCommand       : BOOL;  // Mode selection [FALSE = Auto / TRUE = Manual]
	
	startTractionMotorCmd	: BOOL;


	lineSpeedMPM			: REAL;
	aocSpeedMPM				: REAL;
	aocRunning				: BOOL;


    outfeedRoll_ManCmd      : BOOL; // Manual Mode activation command
    
    outfeedRoll_UpCmd       : BOOL; // Manual command to raise the roll
    outfeedRoll_DownCmd     : BOOL; // Manual command to lower the roll

	
	safetyFeedback			: BOOL;
	
	paperPresenceSensor				: BOOL;
	measuringWheelPaperPresenceSensor		: BOOL;
	rotaryShearCutPulse					: BOOL;	
	measuringWheelPulseSensor		: BOOL;	
	
	    // Knife solenoid enable outputs
    knife1EnabledCmd           : BOOL;
    knife2EnabledCmd           : BOOL;
    knife3EnabledCmd           : BOOL;
    knife4EnabledCmd           : BOOL;
    knife5EnabledCmd           : BOOL;

    // Scorer solenoid enable outputs
    scorer1EnabledCmd          : BOOL;
    scorer2EnabledCmd          : BOOL;
    scorer3EnabledCmd          : BOOL;
    scorer4EnabledCmd          : BOOL;
    scorer5EnabledCmd          : BOOL;
    scorer6EnabledCmd          : BOOL;
    scorer7EnabledCmd          : BOOL;
    scorer8EnabledCmd          : BOOL;

    // Knife home sensors
	
    homeSensorKnife1        : BOOL;
    homeSensorKnife2        : BOOL;
    homeSensorKnife3        : BOOL;
    homeSensorKnife4        : BOOL;
    homeSensorKnife5        : BOOL;
    
    // Scorer home sensors
    homeSensorScorer1       : BOOL;
    homeSensorScorer2       : BOOL;
    homeSensorScorer3       : BOOL;
    homeSensorScorer4       : BOOL;
    homeSensorScorer5       : BOOL;
    homeSensorScorer6       : BOOL;
    homeSensorScorer7       : BOOL;
    homeSensorScorer8       : BOOL;
	
    // Knife sharpening
	
	knifeSharpeningAutoMan		: BOOL;	//Knife sharpening (0 = Manual / 1 = Auto)
    knife1SharpeningCmd        : BOOL;
    knife2SharpeningCmd        : BOOL;
    knife3SharpeningCmd        : BOOL;
    knife4SharpeningCmd        : BOOL;
    knife5SharpeningCmd        : BOOL;	

    knife1LubrificationCmd        : BOOL;
    knife2LubrificationCmd        : BOOL;
    knife3LubrificationCmd        : BOOL;
    knife4LubrificationCmd        : BOOL;
    knife5LubrificationCmd        : BOOL;		

	startExhaustMotorCmd				: BOOL;
	stopExhaustMotorCmd				: BOOL;

	
	scorerHeightIncCmd		: BOOL;	
	scorerHeightDecCmd		: BOOL;	
	
	scorerTypeWCmd	: BOOL;
	scorerTypeNCmd	: BOOL;	
	scorerTypeDCmd	: BOOL;	
	
	scorerTypeWSensor	: BOOL;
	scorerTypeNSensor	: BOOL;	
	scorerTypeDSensor	: BOOL;	
	

	doubleFacerSpeedIncCmd			: BOOL;	
	doubleFacerSpeedDecCmd			: BOOL;	
	doubleFacerStopCmd			: BOOL;
	
    // Slitter movement controls
    moveSlitterOperatorSideCmd : BOOL;
    moveSlitterMotorSideCmd    : BOOL;
    moveSlitterOperatorSideLimit : BOOL;
    moveSlitterMotorSideLimit    : BOOL;	

	
	slitterCenterGuideRollCmd		: BOOL;
	
	rotaryKnifeInfeedUpperDamper1Cmd : BOOL;
	rotaryKnifeInfeedUpperDamper2Cmd : BOOL;
	
	rotaryKnifeInfeedLowerDamper1Cmd : BOOL;
	rotaryKnifeInfeedLowerDamper2Cmd : BOOL;
	
	pilotRollUpDownCmd			: BOOL;
	
	
    // Paper direction flaps
	
	paperDirectionFlapAutoMan	: BOOL; // Paper direction flap (0=Manual / 1=Auto)
    paperDirectionFlap01Cmd    : BOOL;
    paperDirectionFlap02Cmd    : BOOL;
    paperDirectionFlap03Cmd    : BOOL;
    paperDirectionFlap04Cmd    : BOOL;
    paperDirectionFlap05Cmd    : BOOL;
    paperDirectionFlap06Cmd    : BOOL;
    paperDirectionFlap07Cmd    : BOOL;
    paperDirectionFlap08Cmd    : BOOL;
    paperDirectionFlap09Cmd    : BOOL;
    paperDirectionFlap10Cmd    : BOOL;
    paperDirectionFlap11Cmd    : BOOL;
    paperDirectionFlap12Cmd    : BOOL;

	flapsManualCmdArr	: ARRAY [1..27] OF hmiCommandsFlaps_TypeStruct;
	
	
	    // Paper scrap controls
    paperTrimOperatorSideOpenCmd  : BOOL;
    paperTrimOperatorSideCloseCmd : BOOL;
    paperTrimMotorSideOpenCmd     : BOOL;
    paperTrimMotorSideCloseCmd    : BOOL;
	
    // Limit sensors
    limitSensorKnife3_4     : BOOL;  // Between knife 3 and knife 4
    limitSensorScorer4_6    : BOOL;  // Between scorer 4 and scorer 6
    limitSensorScorer3_5    : BOOL;  // Between scorer 3 and scorer 5
	
	
	knifeManualSharpeningCmdArr		: ARRAY [1..20] OF BOOL;	(*This array is used to sharpen the knife manualy*)
	knifeManualLubrificationCmdArr		: ARRAY [1..20] OF BOOL;	(*This array is used to lubrificate the knife manualy*)

    // Machine configuration
    machineConfig           : slitterConfig_TypeStruct;
END_VAR

VAR_IN_OUT
    // Knife axes references
    knife1_Axis             : AXIS_REF;
    knife2_Axis             : AXIS_REF;
    knife3_Axis             : AXIS_REF;
    knife4_Axis             : AXIS_REF;
    knife5_Axis             : AXIS_REF;

    // Scorer axes references
    scorer1_Axis            : AXIS_REF;
    scorer2_Axis            : AXIS_REF;
    scorer3_Axis            : AXIS_REF;
    scorer4_Axis            : AXIS_REF;
    scorer5_Axis            : AXIS_REF;
    scorer6_Axis            : AXIS_REF;
    scorer7_Axis            : AXIS_REF;
    scorer8_Axis            : AXIS_REF;
    
    // Orders
    currentOrder            : Order_TypeStruct;
    nextOrder               : Order_TypeStruct;
END_VAR

VAR_OUTPUT
    EN                      : BOOL;  // Function block enabled

	safetyOK				: BOOL;
	safetyOKLamp			: BOOL;
	
	startCutting            : BOOL;  // Start slitter cutting process\
	startCuttingLamp        : BOOL;  // Start slitter cutting process\
	
	scoreEnabled			: BOOL;
	scoreEnabledLamp		: BOOL;



    // Knife solenoid enable outputs
    knife1Enabled           : BOOL;
    knife2Enabled           : BOOL;
    knife3Enabled           : BOOL;
    knife4Enabled           : BOOL;
    knife5Enabled           : BOOL;

    // Scorer solenoid enable outputs
    scorer1Enabled          : BOOL;
    scorer2Enabled          : BOOL;
    scorer3Enabled          : BOOL;
    scorer4Enabled          : BOOL;
    scorer5Enabled          : BOOL;
    scorer6Enabled          : BOOL;
    scorer7Enabled          : BOOL;
    scorer8Enabled          : BOOL;

    // Knife enabled indicator lamps
    knife1EnabledLamp       : BOOL;
    knife2EnabledLamp       : BOOL;
    knife3EnabledLamp       : BOOL;
    knife4EnabledLamp       : BOOL;
    knife5EnabledLamp       : BOOL;

    // Scorer enabled indicator lamps
    scorer1EnabledLamp      : BOOL;
    scorer2EnabledLamp      : BOOL;
    scorer3EnabledLamp      : BOOL;
    scorer4EnabledLamp      : BOOL;
    scorer5EnabledLamp      : BOOL;
    scorer6EnabledLamp      : BOOL;
    scorer7EnabledLamp      : BOOL;
    scorer8EnabledLamp      : BOOL;

    // Knife lubrication
    knifeLubrificationPump  : BOOL;  // Main lubrication pump
    knife1Lubrification     : BOOL;
    knife2Lubrification     : BOOL;
    knife3Lubrification     : BOOL;
    knife4Lubrification     : BOOL;
    knife5Lubrification     : BOOL;

    // Knife sharpening
    knife1Sharpening        : BOOL;
    knife2Sharpening        : BOOL;
    knife3Sharpening        : BOOL;
    knife4Sharpening        : BOOL;
    knife5Sharpening        : BOOL;

    knife1SharpeningLamp        : BOOL;
    knife2SharpeningLamp        : BOOL;
    knife3SharpeningLamp        : BOOL;
    knife4SharpeningLamp        : BOOL;
    knife5SharpeningLamp        : BOOL;	

	slitterCenterGuideRoll		: BOOL;

	
	rotaryKnifeInfeedUpperDamper1 : BOOL;
	rotaryKnifeInfeedUpperDamper2 : BOOL;
	
	rotaryKnifeInfeedLowerDamper1 : BOOL;
	rotaryKnifeInfeedLowerDamper2 : BOOL;
	
	pilotRollUpDown			: BOOL;	

    outfeedRoll_Up       : BOOL; // Raise the roll
    outfeedRoll_Down     : BOOL; // Lower the roll	
	
    // Paper direction flaps
    paperDirectionFlap01    : BOOL;
    paperDirectionFlap02    : BOOL;
    paperDirectionFlap03    : BOOL;
    paperDirectionFlap04    : BOOL;
    paperDirectionFlap05    : BOOL;
    paperDirectionFlap06    : BOOL;
    paperDirectionFlap07    : BOOL;
    paperDirectionFlap08    : BOOL;
    paperDirectionFlap09    : BOOL;
    paperDirectionFlap10    : BOOL;
    paperDirectionFlap11    : BOOL;
    paperDirectionFlap12    : BOOL;

    // Slitter movement controls
    moveSlitterOperatorSide : BOOL;
    moveSlitterMotorSide    : BOOL;
    moveSlitterOperatorSideLamp : BOOL;
    moveSlitterMotorSideLamp    : BOOL;	
	

    // Paper scrap controls
    paperTrimOperatorSideOpen  : BOOL;
    paperTrimOperatorSideClose : BOOL;
    paperTrimMotorSideOpen     : BOOL;
    paperTrimMotorSideClose    : BOOL;

	

	scorerHeightInc		: BOOL;	
	scorerHeightDec		: BOOL;	
	scorerHeightMotorStart : BOOL;
	scorerHeightMotorSlow : BOOL;
	scorerHeightMotorFast : BOOL;
	
	
	
	scorerTypeWLamp		: BOOL;
	scorerTypeNLamp		: BOOL;	
	scorerTypeDLamp		: BOOL;		
	
	
    // Motor commands
	tractionEnabledLamp		: BOOL;
    knifeMotorStart         : BOOL;
    scorerMotorStart        : BOOL;
	slitterKnifeDriveRef           : REAL;  // Knife motor start command / Partida motor facas	
    slitterScorerDriveRef          : REAL;  // Scorer motor start command / Partida motor vincos	
		
	
	startExhaustMotor				: BOOL;
	startExhaustMotorLamp			: BOOL;
	
	
	arrKnifeRunningMetersForSharpening		: ARRAY [1..5] OF INT;	(*This array is used to reset the lifetime meters that the knife runs*)
	arrKnifeRunningMetersForLubfrication		: ARRAY [1..5] OF INT;	(*This array is used to reset the lifetime meters that the knife runs*)
	
	hmiStatus				: slitterStatus_TypeStruct;
	
	
END_VAR

VAR PERSISTENT
	
	inst_FB_KnifeSharpening  : ARRAY [1..5] OF FB_KnifeSharpening;
	inst_FB_KnifeLubrification : ARRAY [1..5] OF	FB_KnifeLubrification;

END_VAR


VAR
    // Knife axis control instances
    instFB_AxisControlKnife1_Axis : FB_SimpleAxisControl;
    instFB_AxisControlKnife2_Axis : FB_SimpleAxisControl;
    instFB_AxisControlKnife3_Axis : FB_SimpleAxisControl;
    instFB_AxisControlKnife4_Axis : FB_SimpleAxisControl;
    instFB_AxisControlKnife5_Axis : FB_SimpleAxisControl;

    // Scorer axis control instances
    instFB_AxisControlScorer1_Axis : FB_SimpleAxisControl;
    instFB_AxisControlScorer2_Axis : FB_SimpleAxisControl;
    instFB_AxisControlScorer3_Axis : FB_SimpleAxisControl;
    instFB_AxisControlScorer4_Axis : FB_SimpleAxisControl;
    instFB_AxisControlScorer5_Axis : FB_SimpleAxisControl;
    instFB_AxisControlScorer6_Axis : FB_SimpleAxisControl;
    instFB_AxisControlScorer7_Axis : FB_SimpleAxisControl;
    instFB_AxisControlScorer8_Axis : FB_SimpleAxisControl;
    
    // Knife axis configurations
    knife1_AxisConfiguration : LAxisCtrl_typeAxisConfig;
    knife2_AxisConfiguration : LAxisCtrl_typeAxisConfig;
    knife3_AxisConfiguration : LAxisCtrl_typeAxisConfig;
    knife4_AxisConfiguration : LAxisCtrl_typeAxisConfig;
    knife5_AxisConfiguration : LAxisCtrl_typeAxisConfig;

    // Scorer axis configurations
    scorer1_AxisConfiguration : LAxisCtrl_typeAxisConfig;
    scorer2_AxisConfiguration : LAxisCtrl_typeAxisConfig;
    scorer3_AxisConfiguration : LAxisCtrl_typeAxisConfig;
    scorer4_AxisConfiguration : LAxisCtrl_typeAxisConfig;
    scorer5_AxisConfiguration : LAxisCtrl_typeAxisConfig;
    scorer6_AxisConfiguration : LAxisCtrl_typeAxisConfig;
    scorer7_AxisConfiguration : LAxisCtrl_typeAxisConfig;
    scorer8_AxisConfiguration : LAxisCtrl_typeAxisConfig;
    
    // Knife sharpening and lubrication instances
    instSharpeningKnifeArr  : ARRAY [1..20] OF FB_KnifeSharpening_old;
    instKnifeLubrificationArr : ARRAY [1..20] OF FB_KnifeLubrification;

    // Timers
    instSlitterMotoringTP   : TP;    // Slitter motoring stop timer
    instFbCurrentOrderPositionsGeneration : FB_PositionsGeneration;
    instFbToggleStartKnife  : TOGGLE;
    instFbTPStopKnifeMotor  : TP;
    instFbToggleStartScorer : TOGGLE;
    instFbTPStopScorerMotor : TP;
    instFbScorerHeight      : FB_ScorerHeight;
    instTonDelay            : TON;
    instTONExecutePositioningDelay : TON;
    instTPHaltAxis          : TP;

    // Positioning status
    positioningRunning                  : BOOL;
    positioningFinished                 : BOOL;
    innerScorerPositioningRunning       : BOOL;
    outerScorerPositioningRunning       : BOOL;
    knifePositioningRunning             : BOOL;
    innerScorerPositioningFinished      : BOOL;
    outerScorerPositioningFinished      : BOOL;
    knifePositioningFinished            : BOOL;

    // Error flags
    knifeAxisError                      : BOOL;
    innerScorerError                    : BOOL;
    outerScorerError                    : BOOL;
    positioningAxisError                 : BOOL;

    // Motor running flags
    knifeMotorRun                       : BOOL;
    scorerMotorRun                      : BOOL;

    // State tracking
    executePositioningOld               : BOOL;
    changeOrderOld                      : BOOL;
    executeHomeOld                      : BOOL;
    homeRunning                         : BOOL;
    positioningStarted                  : BOOL;
    haltAxis                            : BOOL;
    homeFinished                        : BOOL;

    // Positioning range checks
    knifePositionSetpointOutOfRange     : BOOL;
    innerScorerPositionSetpointOutOfRange : BOOL;
    outerScorerPositionSetpointOutOfRange : BOOL;

    // Aux timers
    auxiliarTP1                         : TP;
	knife1EnabledCmdOld: BOOL;
	knife2EnabledCmdOld: BOOL;
	knife3EnabledCmdOld: BOOL;
	knife4EnabledCmdOld: BOOL;
	knife5EnabledCmdOld: BOOL;

	scorer1EnabledCmdOld: BOOL;
	scorer2EnabledCmdOld: BOOL;
	scorer3EnabledCmdOld: BOOL;
	scorer4EnabledCmdOld: BOOL;
	scorer5EnabledCmdOld: BOOL;
	scorer6EnabledCmdOld: BOOL;
	scorer7EnabledCmdOld: BOOL;
	scorer8EnabledCmdOld: BOOL;
	
	
	inTargetPosition: BOOL;
	
	scorerTypeWCmdOld	: BOOL;
	scorerTypeNCmdOld	: BOOL;	
	scorerTypeDCmdOld	: BOOL;	
	
	instKnifeSharpeningCLK_PRG: CLK_PRG;
	instKnifeLubrificationCLK_PRG: CLK_PRG;
	instTOFScorerSensorDelay: TOF;
	scorerHeightPositioningRunning: BOOL;
	scorerHeightPositioningState: INT;
	inst_GEN_PULSE_1S: GEN_PULSE;
	clock_Pulse_1S: BOOL;
	instFB_PaperDirectionControl : FB_PaperDirectionControl;	
	instRTrigToolsInPosition: R_TRIG;

	
	flapsSetAutoOld: BOOL;
	bAllKnivesInPos: BOOL;
	displayFlapsIndex: INT;
	displayKnifesIndex: INT;
	knifeRunningMetersArr: INT;
	outfeedRoll_DownCmdOld: BOOL;
	outfeedRoll_UpCmdOld: BOOL;
	instTONOutfeedRollDelay: TON;
	
	
	generatePositionsTest: BOOL;
	generatePositionsTestOld: BOOL;
END_VAR

VAR CONSTANT
    AXIS_TYPE_KNIFE         : INT := 1;
    AXIS_TYPE_INNER_SCORER  : INT := 2;
    AXIS_TYPE_OUTER_SCORER  : INT := 3;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[(*Update axis status at the beginning of every cicle*)
knife1_Axis();
knife2_Axis();
knife3_Axis();
knife4_Axis();
knife5_Axis();

scorer1_Axis();
scorer2_Axis();
scorer3_Axis();
scorer4_Axis();
scorer5_Axis();
scorer6_Axis();
scorer7_Axis();
scorer8_Axis();

(*Update inverter status at the beginning of every cicle*)


(*Call program subroutines*)

_axisControl();
_toolsUpDownControl();
_slitterDisplacement();
//_knifeSharpening_old();
_knifeSharpening();

_paperTrim();
_safetyCircuit();
_startStopCutting();
_scorerHeightControl();
_exhaustMotor();
_startTractionMotor();
_knifeSharpening_old();
_knifeLubrification();
//_paperDirectionFlaps();
_slitterPaperDirectionControl();

_slitterCenterPaperGuideRoll();
_09_OutFeedRoll();

ACT_AlarmActive();
ACT_Alarms();
ACT_AuxiliaryCommands();
ACT_ProgramCurrentOrder();

ACT_GeneratePositions();
_haltTheAxis();
_homeFinished();
_08_HmiStatusDisplay();

_toolEnabledLamp();

EN := TRUE;

IF generatePositionsTest AND NOT generatePositionsTestOld THEN
	
	
	instFbCurrentOrderPositionsGeneration(execute := TRUE,
		machineConfig := machineConfig,
		currentOrder := currentOrder);
	
END_IF

generatePositionsTestOld := generatePositionsTest;

]]></ST>
    </Implementation>
    <Method Name="_08_HmiStatusDisplay" Id="{eadcc785-17dc-4f5c-bc20-a5e7c9aaf116}">
      <Declaration><![CDATA[METHOD _08_HmiStatusDisplay
]]></Declaration>
      <Implementation>
        <ST><![CDATA[

FOR displayFlapsIndex := 1 TO 27 DO
	
	
	hmiStatus.flapSolenoidArr[displayFlapsIndex] :=	instFB_PaperDirectionControl.flapSolenoidArr[displayFlapsIndex];

END_FOR


FOR displayKnifesIndex := 1 TO 5 DO
	
	
	hmiStatus.knifeRunningMetersArr[displayKnifesIndex] := inst_FB_KnifeSharpening[displayKnifesIndex].knifeRunningMeters;
	hmiStatus.knifeRunningMetersTotalArr[displayKnifesIndex] := inst_FB_KnifeSharpening[displayKnifesIndex].knifeRunningMetersTotal;
	
	hmiStatus.lubrificationRunningMetersArr[displayKnifesIndex] := inst_FB_KnifeLubrification[displayKnifesIndex].knifeRunningMeters;
	
	
END_FOR]]></ST>
      </Implementation>
    </Method>
    <Method Name="_09_OutFeedRoll" Id="{c2e477c8-1a46-4e37-b449-9cb462ed76d1}">
      <Declaration><![CDATA[METHOD _09_OutFeedRoll : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// ==========================================================================
// OUTFEED ROLL CONTROL LOGIC
// Location: Slitter Scorer Outfeed (Cardboard)
// ==========================================================================

// Update delay timer for automatic paper detection
instTONOutfeedRollDelay(IN := paperPresenceSensor, PT := T#15S);

// Logic Calculation Section
IF outfeedRoll_ManCmd THEN
    
    // Manual Toggle: Raise roll on rising edge of Up command
    IF outfeedRoll_UpCmd AND NOT outfeedRoll_UpCmdOld THEN
        outfeedRoll_Up   := TRUE;
        outfeedRoll_Down := FALSE;
    END_IF
    
    // Manual Toggle: Lower roll on rising edge of Down command
    IF outfeedRoll_DownCmd AND NOT outfeedRoll_DownCmdOld THEN
        outfeedRoll_Up   := FALSE;
        outfeedRoll_Down := TRUE;
    END_IF	

ELSE
    // AUTOMATIC MODE
    // Lower roll only if paper is present and the stable-presence delay has expired
    IF paperPresenceSensor AND instTONOutfeedRollDelay.Q THEN
        outfeedRoll_Up   := FALSE;
        outfeedRoll_Down := TRUE;
    ELSE
        // Default position: Keep roll raised
        outfeedRoll_Up   := TRUE;
        outfeedRoll_Down := FALSE;
    END_IF	

END_IF

// ==========================================================================
// SAFETY INTERLOCK & OUTPUT MAPPING
// ==========================================================================
// If safety feedback is lost, force both outputs to FALSE (Disable Movement)
IF NOT safetyFeedback THEN
    outfeedRoll_Up   := FALSE;
    outfeedRoll_Down := FALSE;
END_IF

// Store states for manual edge detection in next scan cycle
outfeedRoll_UpCmdOld   := outfeedRoll_UpCmd;
outfeedRoll_DownCmdOld := outfeedRoll_DownCmd;


]]></ST>
      </Implementation>
    </Method>
    <Method Name="_axisControl" Id="{e1192684-5bc3-4d29-9741-90c2ec4d908a}">
      <Declaration><![CDATA[METHOD _axisControl
VAR_INPUT
END_VAR
(*

	limitSensorKnife3_4					: BOOL;
	limitSensorScorer4_6					: BOOL;
	limitSensorScorer3_5					: BOOL;
*)]]></Declaration>
      <Implementation>
        <ST><![CDATA[(*==============================================================================================================================
Improved Knife Homing Sequence - CPNTeck Automation
===============================================================================================================================*)

(* Detect rising edge of executeHome *)
IF executeHome AND NOT executeHomeOld THEN
    homeRunning := TRUE;
    instTonDelay(IN := FALSE); // Reset timer
END_IF
executeHomeOld := executeHome;

(* Main Homing Logic *)
IF homeRunning THEN
    instTonDelay(IN := TRUE, PT := T#60S); // Start the 10s timer

    // Start homing Knife 1 and 5 after 1ms
    IF instTonDelay.ET > T#0S AND instTonDelay.ET <= T#10S THEN
        instFB_AxisControlKnife1_Axis.homing := TRUE;
        instFB_AxisControlKnife5_Axis.homing := TRUE;
		
		instFB_AxisControlScorer1_Axis.homing := TRUE;
		instFB_AxisControlScorer7_Axis.homing := TRUE;
		instFB_AxisControlScorer2_Axis.homing := TRUE;
		instFB_AxisControlScorer8_Axis.homing := TRUE;
		
		
    END_IF

    // Start homing Knife 2 and 4 after 3s
    IF instTonDelay.ET > T#10S AND instTonDelay.ET <= T#20S THEN
        instFB_AxisControlKnife2_Axis.homing := TRUE;
        instFB_AxisControlKnife4_Axis.homing := TRUE;
		
		instFB_AxisControlScorer4_Axis.homing := TRUE;
		instFB_AxisControlScorer6_Axis.homing := TRUE;
		instFB_AxisControlScorer3_Axis.homing := TRUE;
		instFB_AxisControlScorer5_Axis.homing := TRUE;
		
    END_IF

    // Start homing Knife 3 after 6s
    IF instTonDelay.ET > T#30S THEN
        instFB_AxisControlKnife3_Axis.homing := TRUE;
    END_IF

    // Finish sequence when timer completes
    IF instTonDelay.Q THEN
        homeRunning := FALSE;

        (* Reset all homing commands *)
        instFB_AxisControlKnife1_Axis.homing := FALSE;
        instFB_AxisControlKnife2_Axis.homing := FALSE;
        instFB_AxisControlKnife3_Axis.homing := FALSE;
        instFB_AxisControlKnife4_Axis.homing := FALSE;
        instFB_AxisControlKnife5_Axis.homing := FALSE;
		
		instFB_AxisControlScorer1_Axis.homing := FALSE;
		instFB_AxisControlScorer2_Axis.homing := FALSE;
		instFB_AxisControlScorer3_Axis.homing := FALSE;
		instFB_AxisControlScorer4_Axis.homing := FALSE;
		instFB_AxisControlScorer5_Axis.homing := FALSE;
		instFB_AxisControlScorer6_Axis.homing := FALSE;
		instFB_AxisControlScorer7_Axis.homing := FALSE;
		instFB_AxisControlScorer8_Axis.homing := FALSE;

        instTonDelay(IN := FALSE); // Stop the timer
    END_IF

ELSE
(*	
    (* Not running, ensure homing off and timer stopped *)
    instFB_AxisControlKnife1_Axis.homing := FALSE;
    instFB_AxisControlKnife2_Axis.homing := FALSE;
    instFB_AxisControlKnife3_Axis.homing := FALSE;
    instFB_AxisControlKnife4_Axis.homing := FALSE;
    instFB_AxisControlKnife5_Axis.homing := FALSE;
	
	instFB_AxisControlScorer1_Axis.homing := FALSE;
	instFB_AxisControlScorer2_Axis.homing := FALSE;
	instFB_AxisControlScorer3_Axis.homing := FALSE;
	instFB_AxisControlScorer4_Axis.homing := FALSE;
	instFB_AxisControlScorer5_Axis.homing := FALSE;
	instFB_AxisControlScorer6_Axis.homing := FALSE;
	instFB_AxisControlScorer7_Axis.homing := FALSE;
	instFB_AxisControlScorer8_Axis.homing := FALSE;	
    instTonDelay(IN := FALSE);
*)	
END_IF
//----------------------------------------------------------------------------------------------
// Knife Axis parameters setup
//----------------------------------------------------------------------------------------------

//Knife 1 - Axis home parameters
knife1_AxisConfiguration.homing.position := machineConfig.homePositionKnife[1];
knife1_AxisConfiguration.homing.offsetPosition := machineConfig.homePositionKnife[1];
knife1_AxisConfiguration.homing.homeExecutionTimeLimit := T#5M;

//Knife 1 - Axis positioning abosulute parameters
knife1_AxisConfiguration.posAbsolute.position := currentOrder.generatedOrder.knifePositionReferenceArr[1] + machineConfig.knifePositionCorrectionArr[1];
knife1_AxisConfiguration.posAbsolute.velocity := machineConfig.toolFastPositioningVelocity;
knife1_AxisConfiguration.posAbsolute.acceleration := machineConfig.toolFastPositioningAccel;
knife1_AxisConfiguration.posAbsolute.deceleration := machineConfig.toolFastPositioningDecel;
knife1_AxisConfiguration.posAbsolute.jerk := machineConfig.toolFastPositioningJerk;


//Knife 1 - Axis positioning relative parameters
knife1_AxisConfiguration.posRelative.distance := hmiCommands.slitter1.knifePosCorrectionArr[1].positionCorrection;
knife1_AxisConfiguration.posRelative.direction := 0;
knife1_AxisConfiguration.posRelative.velocity := machineConfig.toolSlowPositioningVelocity;
knife1_AxisConfiguration.posRelative.acceleration := machineConfig.toolSlowPositioningAccel;
knife1_AxisConfiguration.posRelative.deceleration := machineConfig.toolFastPositioningAccel;
