	paperDirectionFlap02 := paperDirectionFlap02Cmd;
	paperDirectionFlap03 := paperDirectionFlap03Cmd;
	paperDirectionFlap04 := paperDirectionFlap04Cmd;
	paperDirectionFlap05 := paperDirectionFlap05Cmd;
	paperDirectionFlap06 := paperDirectionFlap06Cmd;
	paperDirectionFlap07 := paperDirectionFlap07Cmd;
	paperDirectionFlap08 := paperDirectionFlap08Cmd;
	paperDirectionFlap09 := paperDirectionFlap09Cmd;
	paperDirectionFlap10 := paperDirectionFlap10Cmd;
	paperDirectionFlap11 := paperDirectionFlap11Cmd;
	paperDirectionFlap12 := paperDirectionFlap12Cmd;
	
ELSE
	;
END_IF



rotaryKnifeInfeedUpperDamper1 := rotaryKnifeInfeedUpperDamper1Cmd;
rotaryKnifeInfeedUpperDamper2 := rotaryKnifeInfeedUpperDamper2Cmd;

rotaryKnifeInfeedLowerDamper1 := rotaryKnifeInfeedLowerDamper1Cmd;
rotaryKnifeInfeedLowerDamper2 := rotaryKnifeInfeedLowerDamper2Cmd;

pilotRollUpDown := pilotRollUpDownCmd;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_paperTrim" Id="{1f55aa53-b94e-44fc-a83c-7cd72b2818a7}">
      <Declaration><![CDATA[METHOD PRIVATE _paperTrim
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[


	    // Paper scrap controls
    paperTrimOperatorSideOpen  := paperTrimOperatorSideOpenCmd AND NOT paperTrimOperatorSideCloseCmd AND safetyOK;
    paperTrimOperatorSideClose := paperTrimOperatorSideCloseCmd AND NOT paperTrimOperatorSideOpenCmd AND safetyOK;
    paperTrimMotorSideOpen     := paperTrimMotorSideOpenCmd AND NOT paperTrimMotorSideCloseCmd AND safetyOK;
    paperTrimMotorSideClose    := paperTrimMotorSideCloseCmd AND NOT paperTrimMotorSideOpenCmd AND safetyOK;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_safetyCircuit" Id="{a6e67707-d51c-4f9e-b592-d25f2edec5be}">
      <Declaration><![CDATA[METHOD _safetyCircuit : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[safetyOK := safetyFeedback;


safetyOKLamp := NOT safetyOK;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_scorerHeightControl" Id="{5dd6a4a4-c896-4d2d-b771-fb233797b7c6}">
      <Declaration><![CDATA[METHOD PRIVATE _scorerHeightControl

VAR CONSTANT

    STATE_MANUAL : INT := 0;

    STATE_GOTO_D : INT := 1;
    STATE_WAIT_D : INT := 2;

    STATE_GOTO_W : INT := 3;
    STATE_WAIT_W : INT := 4;

    STATE_GOTO_N : INT := 5;
    STATE_WAIT_N : INT := 6;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
{===== Rising-edge commands =====}
IF scorerTypeDCmd AND NOT scorerTypeDCmdOld THEN
    scorerHeightPositioningState := STATE_GOTO_D;
END_IF;
scorerTypeDCmdOld := scorerTypeDCmd;

IF scorerTypeWCmd AND NOT scorerTypeWCmdOld THEN
    scorerHeightPositioningState := STATE_GOTO_W;
END_IF;
scorerTypeWCmdOld := scorerTypeWCmd;   // <-- fixed (was assigning N old flag before)

IF scorerTypeNCmd AND NOT scorerTypeNCmdOld THEN
    scorerHeightPositioningState := STATE_GOTO_N;
END_IF;
scorerTypeNCmdOld := scorerTypeNCmd;


IF NOT safetyOK THEN
	
	scorerHeightPositioningState := 0;

END_IF


{===== State machine =====}
CASE scorerHeightPositioningState OF

    // -------------------------------------------------------------
    // 0) MANUAL CONTROL
    //    Pass-through of manual jog commands to the motor.
    // -------------------------------------------------------------
    STATE_MANUAL:
        scorerHeightPositioningRunning := FALSE;

        // Manual jog direction
        scorerHeightInc := scorerHeightIncCmd;
        scorerHeightDec := scorerHeightDecCmd;

        // Manual speed (both TRUE here = slow; adjust if you have a separate speed scheme)
        scorerHeightMotorStart := (scorerHeightInc OR scorerHeightDec) AND safetyOK;
        scorerHeightMotorSlow  := (scorerHeightInc OR scorerHeightDec) AND safetyOK;
        scorerHeightMotorFast  := FALSE;



    // -------------------------------------------------------------
    // 1) SELECT D — START MOVE (fast up)
    // -------------------------------------------------------------
    STATE_GOTO_D:
        scorerHeightPositioningRunning := TRUE;

        // Lamps while moving: blink only the requested type
        scorerTypeDLamp := FALSE;   // will blink in WAIT state
        scorerTypeWLamp := FALSE;
        scorerTypeNLamp := FALSE;

        // Start motion
        scorerHeightMotorStart := TRUE;
        scorerHeightMotorFast  := TRUE;
        scorerHeightMotorSlow  := FALSE;

        // Direction to reach the D height (set per your mechanics)
        scorerHeightInc := TRUE;
        scorerHeightDec := FALSE;

        // Start settle timer (TOF)
        instTOFScorerSensorDelay(IN := TRUE);

        // Next
        scorerHeightPositioningState := STATE_WAIT_D;


    // -------------------------------------------------------------
    // 2) SELECT D — WAIT FOR SENSOR AFTER DELAY
    // -------------------------------------------------------------
    STATE_WAIT_D:
        instTOFScorerSensorDelay.IN := FALSE;     // start counting off-delay
        scorerTypeDLamp := clock_Pulse_1S;        // blink while seeking

        // Accept sensor only after the off-delay has elapsed (Q = FALSE)
        IF scorerTypeDSensor AND NOT instTOFScorerSensorDelay.Q THEN
            // Stop motion
            scorerHeightMotorStart := FALSE;
            scorerHeightMotorFast  := FALSE;
            scorerHeightMotorSlow  := FALSE;

            scorerHeightInc := FALSE;
            scorerHeightDec := FALSE;

            // Solid lamp for selected type
            scorerTypeDLamp := TRUE;
            scorerTypeWLamp := FALSE;
            scorerTypeNLamp := FALSE;

            // Return to manual
            scorerHeightPositioningState := STATE_MANUAL;
        END_IF;


    // -------------------------------------------------------------
    // 3) SELECT W — START MOVE (fast up)
    // -------------------------------------------------------------
    STATE_GOTO_W:
        scorerHeightPositioningRunning := TRUE;

        scorerTypeDLamp := FALSE;
        scorerTypeWLamp := FALSE;   // will blink in WAIT state
        scorerTypeNLamp := FALSE;

        scorerHeightMotorStart := TRUE;
        scorerHeightMotorFast  := TRUE;
        scorerHeightMotorSlow  := FALSE;

        scorerHeightInc := TRUE;    // adjust direction if your mechanics require
        scorerHeightDec := FALSE;

        instTOFScorerSensorDelay(IN := TRUE);

        scorerHeightPositioningState := STATE_WAIT_W;


    // -------------------------------------------------------------
    // 4) SELECT W — WAIT FOR SENSOR AFTER DELAY
    // -------------------------------------------------------------
    STATE_WAIT_W:
        instTOFScorerSensorDelay.IN := FALSE;
        scorerTypeWLamp := clock_Pulse_1S;

        IF scorerTypeWSensor AND NOT instTOFScorerSensorDelay.Q THEN
            scorerHeightMotorStart := FALSE;
            scorerHeightMotorFast  := FALSE;
            scorerHeightMotorSlow  := FALSE;

            scorerHeightInc := FALSE;
            scorerHeightDec := FALSE;

            scorerTypeDLamp := FALSE;
            scorerTypeWLamp := TRUE;
            scorerTypeNLamp := FALSE;

            scorerHeightPositioningState := STATE_MANUAL;
        END_IF;


    // -------------------------------------------------------------
    // 5) SELECT N — START MOVE (fast up)
    // -------------------------------------------------------------
    STATE_GOTO_N:
        scorerHeightPositioningRunning := TRUE;

        scorerTypeDLamp := FALSE;
        scorerTypeWLamp := FALSE;
        scorerTypeNLamp := FALSE;   // will blink in WAIT state

        scorerHeightMotorStart := TRUE;
        scorerHeightMotorFast  := TRUE;
        scorerHeightMotorSlow  := FALSE;

        scorerHeightInc := TRUE;    // adjust if needed
        scorerHeightDec := FALSE;

        instTOFScorerSensorDelay(IN := TRUE);

        scorerHeightPositioningState := STATE_WAIT_N;


    // -------------------------------------------------------------
    // 6) SELECT N — WAIT FOR SENSOR AFTER DELAY
    // -------------------------------------------------------------
    STATE_WAIT_N:
        instTOFScorerSensorDelay.IN := FALSE;
        scorerTypeNLamp := clock_Pulse_1S;

        IF scorerTypeNSensor AND NOT instTOFScorerSensorDelay.Q THEN
            scorerHeightMotorStart := FALSE;
            scorerHeightMotorFast  := FALSE;
            scorerHeightMotorSlow  := FALSE;

            scorerHeightInc := FALSE;
            scorerHeightDec := FALSE;

            scorerTypeDLamp := FALSE;
            scorerTypeWLamp := FALSE;
            scorerTypeNLamp := TRUE;

            scorerHeightPositioningState := STATE_MANUAL;
        END_IF;


    // -------------------------------------------------------------
    // SAFETY FALLBACK
    // -------------------------------------------------------------
    ELSE
        // Any undefined state: stop and drop back to manual
        scorerHeightMotorStart := FALSE;
        scorerHeightMotorFast  := FALSE;
        scorerHeightMotorSlow  := FALSE;

        scorerHeightInc := FALSE;
        scorerHeightDec := FALSE;

        scorerHeightPositioningState := STATE_MANUAL;
END_CASE;


{===== Timers / Blink generator configuration =====}
instTOFScorerSensorDelay(PT := T#3S);  // settle / anti-bounce window
inst_GEN_PULSE_1S(ENQ := TRUE, PTH := T#1S, PTL := T#1S, Q => clock_Pulse_1S);


]]></ST>
      </Implementation>
    </Method>
    <Method Name="_slitterCenterPaperGuideRoll" Id="{d764c5d3-05b5-4774-9394-3ee6015983fb}">
