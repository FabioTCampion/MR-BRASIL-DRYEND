	posRelative	:= hmiCommands.slitter1.scorerPosCorrectionArr[3].execute,
	jogForward := hmiCommands.slitter1.scorerJogArr[3].jogFw AND NOT (scorer3_Axis.NcToPlc.ActPos > machineConfig.scorerMaxPostionArr[3]) AND NOT limitSensorScorer3_5 AND homeFinished,
	jogBackward	:= hmiCommands.slitter1.scorerJogArr[3].jogRev AND NOT homeSensorScorer3 AND homeFinished,
    homingSensor := homeSensorScorer3,
    axis := scorer3_Axis,
    master := scorer3_Axis,
    configuration := scorer3_AxisConfiguration
);

//Scorer 4
//__________________________________________________________________________

instFB_AxisControlScorer4_Axis(
    enable := TRUE,
	fastStop := haltAxis,	
	
    enableAxis := enableAxis,
    resetAxis := resetCmd,
	posAbsolute := instTONExecutePositioningDelay.Q,
	posRelative	:= hmiCommands.slitter1.scorerPosCorrectionArr[4].execute,
	jogForward := hmiCommands.slitter1.scorerJogArr[4].jogFw AND NOT (scorer4_Axis.NcToPlc.ActPos > machineConfig.scorerMaxPostionArr[4]) AND NOT limitSensorScorer4_6 AND homeFinished,
	jogBackward	:= hmiCommands.slitter1.scorerJogArr[4].jogRev AND NOT homeSensorScorer4 AND homeFinished,
    homingSensor := homeSensorScorer4,
    axis := scorer4_Axis,
    master := scorer4_Axis,
    configuration := scorer4_AxisConfiguration
);

//Scorer 5
//__________________________________________________________________________

instFB_AxisControlScorer5_Axis(
    enable := TRUE,
	fastStop := haltAxis,	
	
    enableAxis := enableAxis,
    resetAxis := resetCmd,
	posAbsolute := instTONExecutePositioningDelay.Q,
	posRelative	:= hmiCommands.slitter1.scorerPosCorrectionArr[5].execute,
	jogForward := hmiCommands.slitter1.scorerJogArr[5].jogFw AND NOT homeSensorScorer5 AND homeFinished,
	jogBackward	:= hmiCommands.slitter1.scorerJogArr[5].jogRev AND NOT (scorer5_Axis.NcToPlc.ActPos < machineConfig.scorerMinPostionArr[5]) AND NOT limitSensorScorer3_5 AND homeFinished,
    homingSensor := homeSensorScorer5,
    axis := scorer5_Axis,
    master := scorer5_Axis,
    configuration := scorer5_AxisConfiguration
);

//Scorer 6
//__________________________________________________________________________

instFB_AxisControlScorer6_Axis(
    enable := TRUE,
	fastStop := haltAxis,	
	
    enableAxis := enableAxis,
    resetAxis := resetCmd,
	posAbsolute := instTONExecutePositioningDelay.Q,
	posRelative	:= hmiCommands.slitter1.scorerPosCorrectionArr[6].execute,
	jogForward := hmiCommands.slitter1.scorerJogArr[6].jogFw AND NOT homeSensorScorer6 AND homeFinished,
	jogBackward	:= hmiCommands.slitter1.scorerJogArr[6].jogRev AND NOT (scorer6_Axis.NcToPlc.ActPos < machineConfig.scorerMinPostionArr[6]) AND NOT limitSensorScorer4_6 AND homeFinished,
    homingSensor := homeSensorScorer6,
    axis := scorer6_Axis,
    master := scorer6_Axis,
    configuration := scorer6_AxisConfiguration
);

//Scorer 7
//__________________________________________________________________________

instFB_AxisControlScorer7_Axis(
    enable := TRUE,
	fastStop := haltAxis,	
	
    enableAxis := enableAxis,
    resetAxis := resetCmd,
	posAbsolute := instTONExecutePositioningDelay.Q,
	posRelative	:= hmiCommands.slitter1.scorerPosCorrectionArr[7].execute,
	jogForward := hmiCommands.slitter1.scorerJogArr[7].jogFw AND NOT homeSensorScorer7 AND homeFinished,
	jogBackward	:= hmiCommands.slitter1.scorerJogArr[7].jogRev AND NOT homeSensorScorer5 AND homeFinished,
    homingSensor := homeSensorScorer7,
    axis := scorer7_Axis,
    master := scorer7_Axis,
    configuration := scorer7_AxisConfiguration
);

//Scorer 8
//__________________________________________________________________________

instFB_AxisControlScorer8_Axis(
    enable := TRUE,
	fastStop := haltAxis,	
	
    enableAxis := enableAxis,
    resetAxis := resetCmd,
	posAbsolute := instTONExecutePositioningDelay.Q,
	posRelative	:= hmiCommands.slitter1.scorerPosCorrectionArr[8].execute,
	jogForward := hmiCommands.slitter1.scorerJogArr[8].jogFw AND NOT homeSensorScorer8 AND homeFinished,
	jogBackward	:= hmiCommands.slitter1.scorerJogArr[8].jogRev AND NOT homeSensorScorer6 AND homeFinished,
    homingSensor := homeSensorScorer8,
    axis := scorer8_Axis,
    master := scorer8_Axis,
    configuration := scorer8_AxisConfiguration
);

IF instTONExecutePositioningDelay.Q THEN
	
	instTONExecutePositioningDelay.IN := FALSE;
	positioningStarted	:= FALSE;


END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="_exhaustMotor" Id="{2ee4ddf3-8bc4-4d97-827f-7c4a6ea5da19}">
      <Declaration><![CDATA[METHOD PRIVATE _exhaustMotor
VAR_INPUT
END_VAR
(*
	startExhaustMotorCmd				: BOOL;
	stopExhaustMotorCmd				: BOOL;

*)]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF startExhaustMotorCmd AND safetyOK THEN
	
	startExhaustMotor := TRUE;


END_IF

IF stopExhaustMotorCmd THEN
	
	startExhaustMotor := FALSE;

END_IF



startExhaustMotorLamp := startExhaustMotor;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_haltTheAxis" Id="{4895dac7-ac9a-4dc9-885c-9a23317a1dd8}">
      <Declaration><![CDATA[METHOD PRIVATE _haltTheAxis
VAR_INPUT
END_VAR
(*

	homeSensorKnife1					: BOOL; // Knife 1 - Home sensor
	homeSensorKnife2					: BOOL; // Knife 2 - Home sensor
	homeSensorKnife3					: BOOL; // Knife 3 - Home sensor
	homeSensorKnife4					: BOOL; // Knife 4 - Home sensor
	homeSensorKnife5					: BOOL; // Knife 5 - Home sensor
	
	homeSensorScorer1					: BOOL; // Scorer 1 - Home sensor
	homeSensorScorer2					: BOOL; // Scorer 1 - Home sensor
	homeSensorScorer3					: BOOL; // Scorer 1 - Home sensor
	homeSensorScorer4					: BOOL; // Scorer 1 - Home sensor
	homeSensorScorer5					: BOOL; // Scorer 1 - Home sensor
	homeSensorScorer6					: BOOL; // Scorer 1 - Home sensor
	homeSensorScorer7					: BOOL; // Scorer 1 - Home sensor
	homeSensorScorer8					: BOOL; // Scorer 1 - Home sensor
*)

(*

	limitSensorKnife3_4					: BOOL;
	limitSensorScorer4_6					: BOOL;
	limitSensorScorer3_5					: BOOL;
*)]]></Declaration>
      <Implementation>
        <ST><![CDATA[//-------------------------------------------------------------------------------------------------
// Halt Axis Logic: Prevent motion if any tool is detected on home sensor during active positioning
//-------------------------------------------------------------------------------------------------

// Activate the halt trigger if positioning is in progress 
// and any knife or scorer is detected in the home sensor
IF positioningRunning AND (
     homeSensorKnife1 OR
     homeSensorKnife2 OR
     homeSensorKnife3 OR
     homeSensorKnife4 OR
     homeSensorKnife5 OR
     homeSensorScorer1 OR
     homeSensorScorer2 OR
     homeSensorScorer3 OR
     homeSensorScorer4 OR
     homeSensorScorer5 OR
     homeSensorScorer6 OR
     homeSensorScorer7 OR
     homeSensorScorer8 OR
	 limitSensorKnife3_4 OR
	 limitSensorScorer3_5 OR
 	 limitSensorScorer4_6 
	 
) THEN
    instTPHaltAxis.IN := TRUE;
ELSE
    instTPHaltAxis.IN := FALSE;
END_IF

// Timer pulse for halting signal - triggers TRUE for 1 second
instTPHaltAxis(PT := T#1S);

// Output signal to halt all axes
haltAxis := instTPHaltAxis.Q;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_homeFinished" Id="{0c157c0f-c699-4ce0-991a-295f71967faa}">
      <Declaration><![CDATA[METHOD _homeFinished
VAR_INPUT
END_VAR

]]></Declaration>
      <Implementation>
        <ST><![CDATA[homeFinished := knife1_Axis.Status.Homed AND knife2_Axis.Status.Homed AND knife3_Axis.Status.Homed AND knife4_Axis.Status.Homed AND knife5_Axis.Status.Homed AND scorer1_Axis.Status.Homed AND scorer2_Axis.Status.Homed AND scorer3_Axis.Status.Homed AND scorer4_Axis.Status.Homed AND scorer5_Axis.Status.Homed AND scorer6_Axis.Status.Homed AND scorer7_Axis.Status.Homed AND scorer8_Axis.Status.Homed; ]]></ST>
      </Implementation>
    </Method>
    <Method Name="_knifeLubrification" Id="{e0cd00dd-e166-4dc7-8025-e09509c2c9ca}">
      <Declaration><![CDATA[METHOD PRIVATE _knifeLubrification
VAR_INPUT
END_VAR


(*
	knifeRunningMetersForSharpening		: ARRAY [1..5] OF INT;	(*This array is used to reset the lifetime meters that the knife runs*)
	knifeRunningMetersForLubfrication		: ARRAY [1..5] OF INT;	(*This array is used to reset the lifetime meters that the knife runs*)
	

*)]]></Declaration>
      <Implementation>
        <ST><![CDATA[
knifeLubrificationPump := startCutting;


instKnifeLubrificationCLK_PRG(PT:= T#1S, Q=> );


inst_FB_KnifeLubrification[1](
	machineRunning:= startTractionMotorCmd AND startCutting,
	manualLubrification := knife1LubrificationCmd, 
	measuringWheelSensor:= measuringWheelPulseSensor, 
	knifeEnabled:= knife1Enabled, 
	lubrificationSetpoint := machineConfig.knifeLubrificationDistance, 
	lubrificationTime:= machineConfig.knifeLubrificationTime, 
	lubrificationSolenoid=> knife1Lubrification);
	
inst_FB_KnifeLubrification[2](
	machineRunning:= startTractionMotorCmd AND startCutting,
	manualLubrification := knife2LubrificationCmd,  
	measuringWheelSensor:= measuringWheelPulseSensor, 
	knifeEnabled:= knife2Enabled, 
	lubrificationSetpoint := machineConfig.knifeLubrificationDistance, 
	lubrificationTime:= machineConfig.knifeLubrificationTime, 
	lubrificationSolenoid=> knife2Lubrification);
	
inst_FB_KnifeLubrification[3](
	machineRunning:= startTractionMotorCmd AND startCutting, 
	manualLubrification := knife3LubrificationCmd, 
	measuringWheelSensor:= measuringWheelPulseSensor, 
	knifeEnabled:= knife3Enabled, 
	lubrificationSetpoint := machineConfig.knifeLubrificationDistance, 
	lubrificationTime:= machineConfig.knifeLubrificationTime, 
	lubrificationSolenoid=> knife3Lubrification);	
	
inst_FB_KnifeLubrification[4](
	machineRunning:= startTractionMotorCmd AND startCutting, 
	manualLubrification := knife4LubrificationCmd, 	
	measuringWheelSensor:= measuringWheelPulseSensor, 
	knifeEnabled:= knife4Enabled, 
	lubrificationSetpoint := machineConfig.knifeLubrificationDistance, 
	lubrificationTime:= machineConfig.knifeLubrificationTime, 
	lubrificationSolenoid=> knife4Lubrification);		
	
	
inst_FB_KnifeLubrification[5](
	machineRunning:= startTractionMotorCmd AND startCutting, 
	manualLubrification := knife5LubrificationCmd,  
	measuringWheelSensor:= measuringWheelPulseSensor, 
	knifeEnabled:= knife5Enabled,
	lubrificationSetpoint := machineConfig.knifeLubrificationDistance, 
	lubrificationTime:= machineConfig.knifeLubrificationTime, 
	lubrificationSolenoid=> knife5Lubrification);		
	
arrKnifeRunningMetersForLubfrication[1] := inst_FB_KnifeLubrification[1].knifeRunningMeters;	
arrKnifeRunningMetersForLubfrication[2] := inst_FB_KnifeLubrification[2].knifeRunningMeters;	
arrKnifeRunningMetersForLubfrication[3] := inst_FB_KnifeLubrification[3].knifeRunningMeters;	
arrKnifeRunningMetersForLubfrication[4] := inst_FB_KnifeLubrification[4].knifeRunningMeters;	
arrKnifeRunningMetersForLubfrication[5] := inst_FB_KnifeLubrification[5].knifeRunningMeters;	
	
	
	
	
	
	
	
	
	
	
	
	
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_knifeSharpening" Id="{933692d1-8c0c-41f2-8056-4ffb2be3772f}">
      <Declaration><![CDATA[METHOD PRIVATE _knifeSharpening
VAR_INPUT
END_VAR
(*
	knifeRunningMetersForSharpening		: ARRAY [1..5] OF INT;	(*This array is used to reset the lifetime meters that the knife runs*)
	knifeRunningMetersForLubfrication		: ARRAY [1..5] OF INT;	(*This array is used to reset the lifetime meters that the knife runs*)
	

*)]]></Declaration>
      <Implementation>
        <ST><![CDATA[//=================================================================================================
// KNIFE SHARPENING FB CALLS (1..7)
//=================================================================================================

inst_FB_KnifeSharpening[1](
    machineRunning        := knifeMotorStart,
    manualSharpening      := knifeManualSharpeningCmdArr[1],
    measuringWheelSensor  := measuringWheelPulseSensor,
    knifeEnabled          := currentOrder.generatedOrder.knifeEnabledArr[1],
    sharpeningSetpoint    := machineConfig.knifeSharpeningDistance,
    sharpeningTime        := machineConfig.knifeSharpeningTimeMS,
    sharpeningSolenoid    => knife1Sharpening
);

inst_FB_KnifeSharpening[2](
    machineRunning        := knifeMotorStart,
    manualSharpening      := knifeManualSharpeningCmdArr[2],
    measuringWheelSensor  := measuringWheelPulseSensor,
    knifeEnabled          := currentOrder.generatedOrder.knifeEnabledArr[2],
    sharpeningSetpoint    := machineConfig.knifeSharpeningDistance,
    sharpeningTime        := machineConfig.knifeSharpeningTimeMS,
    sharpeningSolenoid    => knife2Sharpening
);

inst_FB_KnifeSharpening[3](
    machineRunning        := knifeMotorStart,
    manualSharpening      := knifeManualSharpeningCmdArr[3],
    measuringWheelSensor  := measuringWheelPulseSensor,
    knifeEnabled          := currentOrder.generatedOrder.knifeEnabledArr[3],
    sharpeningSetpoint    := machineConfig.knifeSharpeningDistance,
    sharpeningTime        := machineConfig.knifeSharpeningTimeMS,
    sharpeningSolenoid    => knife3Sharpening
);

inst_FB_KnifeSharpening[4](
    machineRunning        := knifeMotorStart,
    manualSharpening      := knifeManualSharpeningCmdArr[4],
    measuringWheelSensor  := measuringWheelPulseSensor,
    knifeEnabled          := currentOrder.generatedOrder.knifeEnabledArr[4],
    sharpeningSetpoint    := machineConfig.knifeSharpeningDistance,
    sharpeningTime        := machineConfig.knifeSharpeningTimeMS,
    sharpeningSolenoid    => knife4Sharpening
);

inst_FB_KnifeSharpening[5](
    machineRunning        := knifeMotorStart,
    manualSharpening      := knifeManualSharpeningCmdArr[5],
    measuringWheelSensor  := measuringWheelPulseSensor,
    knifeEnabled          := currentOrder.generatedOrder.knifeEnabledArr[5],
    sharpeningSetpoint    := machineConfig.knifeSharpeningDistance,
    sharpeningTime        := machineConfig.knifeSharpeningTimeMS,
    sharpeningSolenoid    => knife5Sharpening
);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_knifeSharpening_old" Id="{1c6db233-b107-4363-b24f-e38bde61806e}">
      <Declaration><![CDATA[METHOD PRIVATE _knifeSharpening_old
VAR_INPUT
END_VAR
(*
	knifeRunningMetersForSharpening		: ARRAY [1..5] OF INT;	(*This array is used to reset the lifetime meters that the knife runs*)
	knifeRunningMetersForLubfrication		: ARRAY [1..5] OF INT;	(*This array is used to reset the lifetime meters that the knife runs*)
	
	paperPresenceSensor				: BOOL;
	measuringWheelPaperPresenceSensor		: BOOL;
	rotaryShearCutPulse					: BOOL;	
	measuringWheelPulseSensor		: BOOL;	

*)]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT knifeSharpeningAutoMan THEN
	
	knife1Sharpening := knife1SharpeningCmd;
	knife2Sharpening := knife2SharpeningCmd;
	knife3Sharpening := knife3SharpeningCmd;
	knife4Sharpening := knife4SharpeningCmd;
	knife5Sharpening := knife5SharpeningCmd;
	
	knife1SharpeningLamp := knife1Sharpening;
	knife2SharpeningLamp := knife2Sharpening;
	knife3SharpeningLamp := knife3Sharpening;
	knife4SharpeningLamp := knife4Sharpening;
	knife5SharpeningLamp := knife5Sharpening;	

ELSE	
;


instKnifeSharpeningCLK_PRG(PT:= T#1S, Q=> );


inst_FB_KnifeSharpening[1](
	machineRunning:= startTractionMotorCmd AND startCutting, 
	manualSharpening:= knife1SharpeningCmd, 
	measuringWheelSensor:= measuringWheelPulseSensor, 
	knifeEnabled:= knife1Enabled, 
	sharpeningSetpoint:= machineConfig.knifeSharpeningDistance, 
	sharpeningTime:= machineConfig.knifeSharpeningTime, 
	sharpeningSolenoid=> knife1Sharpening);


inst_FB_KnifeSharpening[2](
	machineRunning:= startTractionMotorCmd AND startCutting, 
	manualSharpening:= knife2SharpeningCmd, 
	measuringWheelSensor:= measuringWheelPulseSensor, 
	knifeEnabled:= knife2Enabled, 
	sharpeningSetpoint:= machineConfig.knifeSharpeningDistance, 
	sharpeningTime:= machineConfig.knifeSharpeningTime, 
	sharpeningSolenoid=> knife2Sharpening);	
	
inst_FB_KnifeSharpening[3](
	machineRunning:= startTractionMotorCmd AND startCutting, 
	manualSharpening:= knife3SharpeningCmd, 
	measuringWheelSensor:= measuringWheelPulseSensor, 
	knifeEnabled:= knife3Enabled, 
	sharpeningSetpoint:= machineConfig.knifeSharpeningDistance, 
	sharpeningTime:= machineConfig.knifeSharpeningTime, 
	sharpeningSolenoid=> knife3Sharpening);	

inst_FB_KnifeSharpening[4](
	machineRunning:= startTractionMotorCmd AND startCutting, 
	manualSharpening:= knife4SharpeningCmd, 
	measuringWheelSensor:= measuringWheelPulseSensor, 
	knifeEnabled:= knife4Enabled, 
	sharpeningSetpoint:= machineConfig.knifeSharpeningDistance, 
	sharpeningTime:= machineConfig.knifeSharpeningTime, 
	sharpeningSolenoid=> knife4Sharpening);	


inst_FB_KnifeSharpening[5](
	machineRunning:= startTractionMotorCmd AND startCutting, 
	manualSharpening:= knife5SharpeningCmd, 
	measuringWheelSensor:= measuringWheelPulseSensor, 
	knifeEnabled:= knife5Enabled, 
	sharpeningSetpoint:= machineConfig.knifeSharpeningDistance, 
	sharpeningTime:= machineConfig.knifeSharpeningTime, 
	sharpeningSolenoid=> knife5Sharpening);		

END_IF


arrKnifeRunningMetersForSharpening[1] := inst_FB_KnifeSharpening[1].knifeRunningMeters;
arrKnifeRunningMetersForSharpening[2] := inst_FB_KnifeSharpening[2].knifeRunningMeters;
arrKnifeRunningMetersForSharpening[3] := inst_FB_KnifeSharpening[3].knifeRunningMeters;
arrKnifeRunningMetersForSharpening[4] := inst_FB_KnifeSharpening[4].knifeRunningMeters;
arrKnifeRunningMetersForSharpening[5] := inst_FB_KnifeSharpening[5].knifeRunningMeters;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_paperDirectionFlaps" Id="{23094cc9-3692-4024-9b19-83810c07a30b}">
      <Declaration><![CDATA[METHOD PRIVATE _paperDirectionFlaps
VAR_INPUT
END_VAR
(*

