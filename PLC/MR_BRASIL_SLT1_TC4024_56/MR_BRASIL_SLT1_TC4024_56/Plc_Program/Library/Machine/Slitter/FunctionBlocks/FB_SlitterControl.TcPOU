    <Action Name="ACT_ProgramCurrentOrder" Id="{63d8961f-72c0-495e-92b0-22ac344d9722}">
      <Implementation>
        <ST><![CDATA[
(*==============================================================================================================================
CPNTeck - Automação industrial
(c)Copyright 2023 All Rights Reserved
_______________________________________________________________________________________________________________________________
Library: N/A 
Tested with: CX5140
Engineering: Twincat 2
Restrictions: -
Requirements: N/A
Functionality: This function is used program the current order and change the order
Support: fabio@cpnteck.com.br
Note: Parameter comments are only available in language 'English (United States)'
_______________________________________________________________________________________________________________________________
Change log table:

Version  		| Date        			| Expert in charge  	| Changes applied
01.00.01		| 29.03.2023  		| Fabio Campion            | First released version
*)


IF changeOrder AND NOT changeOrderOld THEN

	currentOrder := nextOrder;

END_IF

changeOrderOld := changeOrder;]]></ST>
      </Implementation>
    </Action>
