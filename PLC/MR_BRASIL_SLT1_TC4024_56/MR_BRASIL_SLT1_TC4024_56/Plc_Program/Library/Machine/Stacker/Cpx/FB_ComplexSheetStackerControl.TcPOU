<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_ComplexSheetStackerControl" Id="{48f3d714-da40-448b-b8a6-71c59012c754}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_ComplexSheetStackerControl
VAR_INPUT

    //==============================================================
    // Group command inputs
    //==============================================================
    startCmd                            : BOOL;
    stopCmd                             : BOOL;
    resetCmd                            : BOOL;
	blockConveyorCmd					: BOOL;

    //==============================================================
    // Speed reference inputs
    //==============================================================
    lineSpeedMPM                        : REAL;

    // EN: Current sheet length [mm].
    // PT: Comprimento atual da chapa [mm].
    sheetLengthMm                       : REAL;


    //==============================================================
    // Package command input
    //==============================================================
    // EN: Maintained automatic unload request from the production metrics.
    //     It is accepted only once and is rearmed after the command turns FALSE.
    // PT: Pedido automático mantido de descarga vindo das métricas de produção.
    //     É aceito apenas uma vez e rearmado após o comando ficar FALSE.
    packageCompleteCmd                  : BOOL;

    // EN: Rising edge requests a complete discharge cycle for batch change.
    // PT: Borda de subida solicita um ciclo completo de descarte para troca de lote.
    changeBatchCmd                      : BOOL;

	// EN: Local unload request accepted on the rising edge.
	// PT: Pedido local de descarga aceito na borda de subida.
	stackerUnloadCmd                     : BOOL;

	sheetConveyorsSpeedUpCmd : BOOL;

    //==============================================================
    // Machine configuration
    //==============================================================
    machineConfig                       : ComplexStackerConfig_TypeStruct;


    //==============================================================
    // Safety input
    //==============================================================
    safetyCircuitOk                     : BOOL;


    //==============================================================
    // Synchronized conveyor drive status inputs
    //==============================================================
    sheetConveyor1DriveOk               : BOOL;
    sheetConveyor2DriveOk               : BOOL;
    sheetConveyor3DriveOk               : BOOL;
    sheetConveyor4DriveOk               : BOOL;
    elevatorDriveOk              : BOOL;


    //==============================================================
    // Auxiliary drive status inputs
    //==============================================================
    backstopDriveOk                     : BOOL;

	//==============================================================
	// Sheet stack discharge conveyor drive status input
	//==============================================================
    sheetStackDischargeConveyorDriveOk                 : BOOL;

	//==============================================================
	// EN: Stack buffer conveyor drive status inputs
	// PT: Entradas de estado dos acionamentos das esteiras buffer
	//==============================================================
	stackBufferConveyor1DriveOk            : BOOL;
	stackBufferConveyor2DriveOk            : BOOL;
	stackBufferConveyor3DriveOk            : BOOL;

	//==============================================================
	// EN: Stack detection sensors
	// PT: Sensores de detecção das pilhas
	//==============================================================
	stackBufferConveyor1StackPresentSensor : BOOL;
	stackBufferConveyor2StackPresentSensor : BOOL;
	stackBufferConveyor3StackPresentSensor : BOOL;
	elevatorStackPresentSensor             : BOOL;
	elevatorStackExitClearSensor           : BOOL;
	backstopMaterialInterlockSensor         : BOOL;
	backstopStackLevelSensor                : BOOL;

	
    //==============================================================
    // Position / measurement inputs
    //==============================================================
    stackHeightMm                       : REAL;
    backstopPositionMm                  : REAL;
    elevatorPositionMm           : REAL;


	//==============================================================
	// Elevator command inputs
	//==============================================================
	// EN: Starts elevator homing cycle.
	// PT: Inicia o ciclo de homing do elevador.
	elevatorHomeCmd              : BOOL;
	
	// EN: Enables elevator automatic mode. Auto-home is requested on
	//     startCmd and automatic leveling uses the stack level sensor.
	// PT: Habilita o modo automático do elevador. O auto-home é solicitado
	//     no startCmd e o nivelamento automático usa o sensor de nível da pilha.
	elevatorAutoCmd              : BOOL;
	
	// EN: Jog-up command in manual mode or during automatic leveling.
	// PT: Comando de jog para subir no manual ou durante o nivelamento automático.
	elevatorUpCmd                : BOOL;
	
	// EN: Jog-down command in manual mode or during automatic leveling.
	// PT: Comando de jog para descer no manual ou durante o nivelamento automático.
	elevatorDownCmd              : BOOL;


    //==============================================================
    // Elevator limit inputs
    //==============================================================
    elevatorUpperSafetyLimit     : BOOL;
    elevatorLowerSafetyLimit     : BOOL;

    elevatorUpperLimit           : BOOL;
    elevatorLowerLimit           : BOOL;


    //==============================================================
    // Backstop command inputs
    //==============================================================
    // EN: Starts the backstop homing cycle.
    // PT: Inicia o ciclo de homing do backstop.
    backstopHomeCmd                     : BOOL;
	
    // EN: Starts the backstop homing cycle.
    // PT: Inicia o ciclo de homing do backstop.
    backstopExecutePositioningCmd			 : BOOL;
    // EN: Enables automatic positioning according to sheet length.
    // PT: Habilita posicionamento automático conforme comprimento da chapa.
    backstopAutoCmd                     : BOOL;

    // EN: Manual open command.
    // PT: Comando manual para abrir.
    backstopOpenCmd                     : BOOL;

    // EN: Manual close command.
    // PT: Comando manual para fechar.
    backstopCloseCmd                    : BOOL;


    //==============================================================
    // Backstop limit inputs
    //==============================================================
    backstopSafeMaxLimit                    : BOOL;	
    backstopMaxLimit                 	   	: BOOL;
    backstopMinLimit                   		: BOOL;
    backstopSafeMinLimit                    : BOOL;


    //==============================================================
    // Sheet handling command inputs
    //==============================================================
	sheetStackDischargeConveyorManualRunCmd : BOOL;
    noCrushRollersDownCmd                 	: BOOL;

	// EN: Runs all three stack buffer conveyors.
	// PT: Aciona as três esteiras buffer de pilhas.
	stackBufferConveyorsRunCmd               : BOOL;

	// EN: Enables automatic operation of the sheet stack alignment brush.
	// PT: Habilita a operação automática da escova de alinhamento da pilha.
	sheetStackAlignmentBrushEnableCmd        : BOOL;

	//==============================================================
	// Input / Entrada
	//==============================================================
	paperPressAutoManCmd : BOOL;

	// EN: Enables automatic operation of the exhaust fan installed
	//     on sheet conveyor 1.
	// PT: Habilita a operação automática do exaustor instalado
	//     na esteira de chapas 1.
	sheetConveyor1ExhaustFanCmd : BOOL;

	//==============================================================
	// EN: Independent sheet brush commands
	// PT: Comandos independentes das escovas de chapas
	//==============================================================
	sheetBrush1Cmd       : BOOL;
	sheetBrush2Cmd       : BOOL;
	sheetBrush3Cmd       : BOOL;
	sheetBrush4Cmd       : BOOL;
	sheetBrushAutoManCmd : BOOL;
	
	safetyFeedBack1 	: BOOL;
	safetyFeedBack2 	: BOOL;
	safetyFeedBack3 	: BOOL;
	safetyFeedBack4 	: BOOL;
	safetyFeedBack5 	: BOOL;
	safetyFeedBack6 	: BOOL;
	safetyFeedBack7 	: BOOL;
	safetyFeedBack8 	: BOOL;	
	safetyFeedBack9 	: BOOL;	
	safetyFeedBack10 	: BOOL;		
			

END_VAR


VAR_OUTPUT

	hmiAlarms : hmiAlarmsComplexStacker_TypeStruct;
	hmiStatus : hmiStatusComplexStacker_TypeStruct;
	stackerRunning : BOOL;
	alarmActive	: BOOL;
	stopMachinePulse : BOOL;
	reset 	: BOOL;

	// EN: TRUE during an accepted unload sequence or while a stacker axis
	//     executes homing. Intended to command an external warning siren.
	// PT: TRUE durante uma sequência de descarga aceita ou enquanto um eixo
	//     do stacker executa homing. Destinada ao comando de uma sirene externa.
	stackerBuzzer1 : BOOL;
	stackerBuzzer2 : BOOL;
	// EN: One-scan pulse generated when a local unload request is accepted.
	//     It can be used to reset the external pile quantity in Metrics.
	// PT: Pulso de um ciclo gerado quando um pedido local de descarga é aceito.
	//     Pode ser usado para resetar a quantidade externa da pilha no Metrics.
	stackerUnloadAccepted : BOOL;

	// EN: 20 ms pulse used to reset the external stack counter.
	// PT: Pulso de 20 ms usado para resetar o contador externo de pilhas.
	externalCounterReset : BOOL;

    //==============================================================
    // Synchronized conveyor drive outputs
    //==============================================================
    sheetConveyor1Run                   : BOOL;
    sheetConveyor2Run                   : BOOL;
    sheetConveyor3Run                   : BOOL;
    sheetConveyor4Run                   : BOOL;

	// EN: Sheet conveyor 1 exhaust fan run command.
	// PT: Comando de acionamento do exaustor da esteira de chapas 1.
	sheetConveyor1ExhaustFanRun           : BOOL;
	
	//==============================================================
	// Elevator drive outputs
	//==============================================================
	// EN: Elevator up run command.
	// PT: Comando para subir o elevador.
	elevatorRunUp                : BOOL;
	
	// EN: Elevator down run command.
	// PT: Comando para descer o elevador.
	elevatorRunDown              : BOOL;
	
	//==============================================================
	// Elevator magnetic brake output
	//==============================================================
	// EN: Magnetic brake release output. TRUE = brake released.
	// PT: Saída de liberação do freio magnético. TRUE = freio liberado.
	elevatorBrakeRelease         : BOOL;	

	// EN: Enables the elevator servo together with the stacker control.
	//     The servo remains enabled while stopped with zero speed reference.
	// PT: Habilita o servo do elevador junto com o controle do stacker.
	//     O servo permanece habilitado quando parado com referência zero.
	elevatorDriveEnable          : BOOL;

    //==============================================================
    // Backstop drive outputs
    //==============================================================
    // EN: Backstop forward run command. Positive/opening direction.
    // PT: Comando frente do backstop. Direção positiva/abrir.
    backstopRunFw                       : BOOL;

    // EN: Backstop reverse run command. Negative/closing direction.
    // PT: Comando reverso do backstop. Direção negativa/fechar.
    backstopRunRev                      : BOOL;

    // EN: Enables the backstop servo together with the stacker control.
    // PT: Habilita o servo do backstop junto com o controle do stacker.
    backstopDriveEnable                 : BOOL;

	//==============================================================
	// Sheet stack discharge conveyor outputs
	//==============================================================
	// EN: Sheet stack discharge conveyor run command.
	// PT: Comando de giro da esteira de descarga da pilha.
	sheetStackDischargeConveyorRun          : BOOL;

	//==============================================================
	// EN: Stack buffer conveyor run outputs
	// PT: Saídas de acionamento das esteiras buffer de pilhas
	//==============================================================
	stackBufferConveyor1Run                 : BOOL;
	stackBufferConveyor2Run                 : BOOL;
	stackBufferConveyor3Run                 : BOOL;




    //==============================================================
    // Synchronized conveyor speed reference outputs
    //==============================================================
    sheetConveyor1SpeedRefMPM           : REAL;
    sheetConveyor2SpeedRefMPM           : REAL;
    sheetConveyor3SpeedRefMPM           : REAL;
    sheetConveyor4SpeedRefMPM           : REAL;

    // EN: Signed elevator speed reference [mm/s]. Positive moves up
    //     and negative moves down.
    // PT: Referência de velocidade com sinal do elevador [mm/s].
    //     Positivo sobe e negativo desce.
    elevatorSpeedRefMmps                 : REAL;
	// EN: Sheet stack discharge conveyor speed reference [m/min].
	// PT: Referência de velocidade da esteira de descarga da pilha [m/min].
	sheetStackDischargeConveyorSpeedRefMPM  : REAL;

	// EN: Stack buffer conveyor speed references [m/min].
	// PT: Referências de velocidade das esteiras buffer [m/min].
	stackBufferConveyor1SpeedRefMPM         : REAL;
	stackBufferConveyor2SpeedRefMPM         : REAL;
	stackBufferConveyor3SpeedRefMPM         : REAL;

	// EN: TRUE while all three stack buffer positions are occupied.
	// PT: TRUE enquanto as três posições buffer estiverem ocupadas.
	stackBufferFull                         : BOOL;

	// EN: Requests the parent controller to reduce the machine speed.
	// PT: Solicita ao controlador pai a redução da velocidade da máquina.
	lineSpeedReductionRequest               : BOOL;

    //==============================================================
    // Backstop speed reference output
    //==============================================================
    // EN: Signed backstop speed reference [mm/s]. Positive opens and negative closes.
    // PT: Referência de velocidade com sinal do backstop [mm/s]. Positivo abre e negativo fecha.
    backstopSpeedRefMmps                : REAL;
	
	
	
    backstopPlateUpSolenoid                : BOOL;


    //==============================================================
    // Backstop encoder set outputs
    //==============================================================
    // EN: Pulse output to set/reset backstop encoder position.
    // PT: Pulso de saída para setar/resetar a posição do encoder do backstop.
    backstopSetEncoderPosition          : BOOL;

    // EN: Position value to set in the encoder block [mm].
    // PT: Valor de posição a ser gravado no bloco do encoder [mm].
    backstopSetEncoderPositionMm        : REAL;


    //==============================================================
    // Pneumatic valve outputs
    //==============================================================
    brakeValve                          : BOOL;

    sheetBrush1Valve                    : BOOL;
    sheetBrush2Valve                    : BOOL;
    sheetBrush3Valve                    : BOOL;
    sheetBrush4Valve                    : BOOL;

    brakeBrushValve                     : BOOL;
    backstopUpValve                     : BOOL;
    noCrushRollersUpDownValve               : BOOL;

	// EN: Sheet stack alignment brush command. TRUE = lowered/engaged;
	//     FALSE = raised/disengaged.
	// PT: Comando da escova de alinhamento da pilha. TRUE = abaixada/acionada;
	//     FALSE = levantada/desacionada.
	sheetStackAlignmentBrush              : BOOL;

	paperPressSolenoid : BOOL;
    //==============================================================
    // General status outputs
    //==============================================================
    deviceState                         : STRING(30);

    faultActive                         : BOOL;
    synchronizedConveyorsRunning        : BOOL;


    //==============================================================
    // Sheet stack separation status outputs
    //==============================================================
    sheetStackSeparationState           : STRING(30);
    sheetStackSeparationStateCode       : INT;

    sheetStackSeparationReady           : BOOL;
    sheetStackSeparationActive          : BOOL;

    // EN: One-scan pulse when sheet stack separation starts.
    // PT: Pulso de um ciclo quando inicia a separação da pilha de chapas.
    sheetStackSeparationStarted         : BOOL;

    // EN: One-scan pulse when sheet stack separation finishes.
    // PT: Pulso de um ciclo quando finaliza a separação da pilha de chapas.
    sheetStackSeparationFinished        : BOOL;

    // EN: Brake active during sheet stack separation.
    // PT: Freio ativo durante a separação da pilha de chapas.
    sheetStackBrakeActive               : BOOL;


    //==============================================================
    // Sheet conveyor 2 separation status outputs
    //==============================================================
    sheetConveyor2SeparationActive      : BOOL;

    // EN: One-scan pulse when conveyor 2 separation tracking starts.
    // PT: Pulso de um ciclo quando inicia o rastreamento de separação da esteira 2.
    sheetConveyor2SeparationStarted     : BOOL;

    // EN: One-scan pulse when conveyor 2 separation tracking finishes.
    // PT: Pulso de um ciclo quando finaliza o rastreamento de separação da esteira 2.
    sheetConveyor2SeparationFinished    : BOOL;

    sheetConveyor2HighSpeedActive       : BOOL;

    // EN: Current conveyor 2 separation tracking distance [m].
    // PT: Distância atual rastreada na separação da esteira 2 [m].
    sheetConveyor2TrackingDistanceM     : REAL;

    // EN: Conveyor 2 separation target distance [m].
    // PT: Distância alvo de separação da esteira 2 [m].
    sheetConveyor2TargetDistanceM       : REAL;


    //==============================================================
    // Sheet conveyor 3 separation status outputs
    //==============================================================
    sheetConveyor3SeparationActive      : BOOL;

    // EN: One-scan pulse when conveyor 3 separation tracking starts.
    // PT: Pulso de um ciclo quando inicia o rastreamento de separação da esteira 3.
    sheetConveyor3SeparationStarted     : BOOL;

    // EN: One-scan pulse when conveyor 3 separation tracking finishes.
    // PT: Pulso de um ciclo quando finaliza o rastreamento de separação da esteira 3.
    sheetConveyor3SeparationFinished    : BOOL;

    sheetConveyor3HighSpeedActive       : BOOL;

    // EN: Current conveyor 3 separation tracking distance [m].
    // PT: Distância atual rastreada na separação da esteira 3 [m].
    sheetConveyor3TrackingDistanceM     : REAL;

    // EN: Conveyor 3 separation target distance [m].
    // PT: Distância alvo de separação da esteira 3 [m].
    sheetConveyor3TargetDistanceM       : REAL;

    //==============================================================
    // Sheet conveyor 4 separation status outputs
    //==============================================================
    sheetConveyor4SeparationActive      : BOOL;
    sheetConveyor4SeparationStarted     : BOOL;
    sheetConveyor4SeparationFinished    : BOOL;
    sheetConveyor4HighSpeedActive       : BOOL;
    sheetConveyor4TrackingDistanceM     : REAL;
    sheetConveyor4TargetDistanceM       : REAL;

	//==============================================================
	// Elevator encoder set outputs
	//==============================================================
	// EN: Pulse output to set/reset elevator encoder position.
	// PT: Pulso de saída para setar/resetar a posição do encoder do elevador.
	elevatorSetEncoderPosition   : BOOL;
	
	// EN: Position value to set in the elevator encoder block [mm].
	// PT: Valor de posição a ser gravado no bloco do encoder do elevador [mm].
	elevatorSetEncoderPositionMm : REAL;
	
	
	//==============================================================
	// Elevator status outputs
	//==============================================================
	elevatorState                : STRING(30);
	
	elevatorHomed                : BOOL;
	elevatorInPosition           : BOOL;

	// EN: TRUE when the homed elevator is at or below the configured
	//     minimum position considering the position tolerance.
	// PT: TRUE quando o elevador referenciado está na posição mínima
	//     configurada ou abaixo dela, considerando a tolerância.
	elevatorAtMinPosition        : BOOL;

	// EN: TRUE when the homed elevator is at or above the configured
	//     maximum position considering the position tolerance.
	// PT: TRUE quando o elevador referenciado está na posição máxima
	//     configurada ou acima dela, considerando a tolerância.
	elevatorAtMaxPosition        : BOOL;

	// EN: TRUE while manual jog speed is reduced near the endpoint
	//     toward which the elevator is moving.
	// PT: TRUE enquanto a velocidade do jog manual estiver reduzida próximo
	//     da extremidade para a qual o elevador está se movimentando.
	elevatorManualLowSpeedZoneActive : BOOL;

	elevatorFault                : BOOL;
	elevatorFaultCode            : INT;
	
	// EN: Current calculated elevator target position [mm].
	// PT: Posição alvo calculada atual do elevador [mm].
	elevatorTargetPositionMm     : REAL;
	
	// EN: Current elevator position error [mm].
	// PT: Erro atual de posição do elevador [mm].
	elevatorPositionErrorMm      : REAL;

    //==============================================================
    // Backstop status outputs
    //==============================================================
    backstopState                       : STRING(30);

    backstopHomed                       : BOOL;
    backstopInPosition                  : BOOL;
    backstopFault                       : BOOL;
    backstopFaultCode                   : INT;

    // EN: Current calculated target position [mm].
    // PT: Posição alvo calculada atualmente [mm].
    backstopTargetPositionMm            : REAL;

    // EN: Current position error [mm].
    // PT: Erro atual de posição [mm].
    backstopPositionErrorMm             : REAL;
	
	//==============================================================
	// Sheet stack discharge conveyor control state
	//==============================================================
	sheetStackDischargeConveyorState               : STRING(30);
	sheetStackDischargeConveyorFault               : BOOL;
	sheetStackDischargeConveyorFaultCode           : INT;
	
	//==============================================================
	// Sheet stack discharge sequence status outputs
	//==============================================================
	sheetStackDischargeState                : STRING(30);
	sheetStackDischargeStateCode            : INT;
	
	sheetStackDischargePending              : BOOL;
	sheetStackDischargeActive               : BOOL;
	sheetStackDischargeStarted              : BOOL;
	sheetStackDischargeFinished             : BOOL;
	
	sheetStackDischargeFault                : BOOL;
	sheetStackDischargeFaultCode            : INT;
	
	//==============================================================
	// Sheet stack discharge last cycle diagnostic outputs
	//==============================================================
	sheetStackDischargeLastCycleOk          : BOOL;
	sheetStackDischargeLastResultCode       : INT;
	sheetStackDischargeLastFaultStepCode    : INT;
	sheetStackDischargeLastFaultCode        : INT;	

	// EN: Requests a CiA 402 quick stop while the servo disable delay is active.
	// PT: Solicita o quick stop CiA 402 durante o atraso de desabilitação do servo.
	elevatorQuickStop                       : BOOL;

END_VAR

VAR
	
	//==============================================================
	// Stop machine pulse control
	//==============================================================
	stopMachineFaultCondition     : BOOL;
	stopMachineFaultConditionOld  : BOOL;
	rStopMachineFaultCondition    : BOOL;
	
	tpStopMachinePulse            : TP;
	
	//==============================================================
	// Backstop manual intervention memory
	//==============================================================
	backstopManualInterventionActive     : BOOL;
	backstopManualInterventionPositionMm : REAL;
	
	//==============================================================
	// Sheet stack discharge backstop latched targets
	//==============================================================
	backstopProgrammedDischargeTargetMm : REAL;
	backstopDischargeOpenBasePositionMm : REAL;
	backstopDischargeOpenTargetMm       : REAL;
	
	//==============================================================
	// Backstop automatic positioning command control
	//==============================================================
	backstopExecutePositioningCmdOld    : BOOL;
	rBackstopExecutePositioning         : BOOL;
	
	backstopTargetOverrideOld           : BOOL;
	backstopTargetOverrideFallingEdge   : BOOL;
	
	backstopPositioningRequestActive    : BOOL;
	backstopLatchedTargetPositionMm     : REAL;
	backstopProgrammedTargetPositionMm  : REAL;
	
	//==============================================================
	// Backstop manual intervention memory
	//==============================================================
	// EN: Used by automatic discharge sequence to avoid closing onto material
	//     after operator manual intervention.

	//==============================================================
	// Backstop encoder set pulse
	//==============================================================
	backstopSetEncoderPositionTrigger  : BOOL;
	tpBackstopSetEncoderPosition       : TP;

	//==============================================================
	// Sheet stack discharge backstop latched targets
	//==============================================================

    //==============================================================
    // Group state machine
    //==============================================================
    syncConveyorsState                  : INT;


    //==============================================================
    // Package separation state machine
    //==============================================================
    packageSeparationState              : INT;


    //==============================================================
    // Backstop state machine
    //==============================================================
    backstopControlState                : INT;


    //==============================================================
    // Edge detection
    //==============================================================
    startCmdOld                         : BOOL;
    stopCmdOld                          : BOOL;

	// EN: Locks the maintained automatic request after it is accepted.
	// PT: Bloqueia o pedido automático mantido após ele ser aceito.
	packageCompleteCmdAcceptedLatch       : BOOL;
	changeBatchCmdOld                     : BOOL;
	changeBatchRequestPending             : BOOL;
	changeBatchCycleActive                : BOOL;

	// EN: Local unload command rising-edge detection.
	// PT: Detecção de borda de subida do comando local de descarga.
	stackerUnloadCmdOld                   : BOOL;
	rStackerUnloadCmd                     : BOOL;

	// EN: Internal one-scan event generated for any accepted unload source.
	// PT: Evento interno de um scan gerado para qualquer fonte de descarga aceita.
	dischargeRequestAccepted              : BOOL;

    backstopHomeCmdOld                  : BOOL;


    //==============================================================
    // Internal conditions
    //==============================================================
    allSynchronizedDrivesOk             : BOOL;
    anyFault                            : BOOL;
    speedControlEnabled                 : BOOL;
    rampReset                           : BOOL;


    //==============================================================
    // Sheet length conversion
    //==============================================================
    // EN: Internal sheet length converted from mm to m.
    // PT: Comprimento interno da chapa convertido de mm para m.
    sheetLengthM                        : REAL;


    //==============================================================
    // Normal speed calculation
    //==============================================================
    effectiveLineSpeedMPM                : REAL;
    normalStackerSpeedMPM               : REAL;

    sheetConveyor1NormalSpeedMPM        : REAL;
    sheetConveyor2NormalSpeedMPM        : REAL;
    sheetConveyor3NormalSpeedMPM        : REAL;
    sheetConveyor4NormalSpeedMPM        : REAL;
    elevatorNormalSpeedMPM       : REAL;


    //==============================================================
    // Package gap speed calculation
    //==============================================================
    sheetConveyor1GapSpeedMPM           : REAL;
    sheetConveyor2GapSpeedMPM           : REAL;
    sheetConveyor3GapSpeedMPM           : REAL;
    sheetConveyor4GapSpeedMPM           : REAL;


    //==============================================================
    // Speed targets
    //==============================================================
    sheetConveyor1TargetSpeedMPM        : REAL;
    sheetConveyor2TargetSpeedMPM        : REAL;
    sheetConveyor3TargetSpeedMPM        : REAL;
    sheetConveyor4TargetSpeedMPM        : REAL;
    elevatorTargetSpeedMPM       : REAL;


    //==============================================================
    // Package gap distance calculation
    //==============================================================
    packageGapDistanceTargetM           : REAL;

    sheetConveyor2OpeningSpeedMPM       : REAL;
    sheetConveyor3OpeningSpeedMPM       : REAL;
    sheetConveyor4OpeningSpeedMPM       : REAL;

    sheetConveyor2OpeningDistanceM      : REAL;
    sheetConveyor3OpeningDistanceM      : REAL;
    sheetConveyor4OpeningDistanceM      : REAL;


	//==============================================================
	// Elevator state machine
	//==============================================================
	elevatorControlState         : INT;
	
	
	//==============================================================
	// Elevator edge detection
	//==============================================================
	elevatorHomeCmdOld           : BOOL;
	rElevatorHome                : BOOL;
	
	
	//==============================================================
	// Elevator encoder set pulse
	//==============================================================
	elevatorSetEncoderPositionTrigger   : BOOL;
	tpElevatorSetEncoderPosition        : TP;
	
	
	//==============================================================
	// Elevator control calculation
	//==============================================================
	elevatorAutoTargetPositionMm        : REAL;
	elevatorRawSpeedRefMmps             : REAL;
	
	// EN: Internal signed speed command. Positive = up, negative = down.
	// PT: Comando interno de velocidade com sinal. Positivo = subir, negativo = descer.
	elevatorSignedSpeedRefMmps          : REAL;
	
	elevatorAbsPositionErrorMm          : REAL;
	
	
	//==============================================================
	// Elevator movement permissions
	//==============================================================
	elevatorUpAllowed                   : BOOL;
	elevatorDownAllowed                 : BOOL;
	
	elevatorDriveEnableRequest          : BOOL;
	elevatorMoveRequest                 : BOOL;
	elevatorBrakeReleaseRequest         : BOOL;
	
	
	//==============================================================
	// Elevator homing
	//==============================================================
	elevatorHomeLimitReached            : BOOL;
	elevatorHomeDownAllowed             : BOOL;
	elevatorHomeReleaseAllowed          : BOOL;
	elevatorManualCommandArmed          : BOOL;
	elevatorManualCommandRequest        : BOOL;
	elevatorReadyForAutomaticCycle      : BOOL;

	// EN: Keeps the discharge conveyor active from the lower home limit until
	//     the minimum run time and platform-clear conditions are confirmed.
	// PT: Mantém a esteira de descarga ativa desde o limite inferior do home até
	//     confirmar o tempo mínimo de giro e as condições de plataforma livre.
	elevatorHomeDischargeConveyorRunRequest : BOOL;
	elevatorHomeDischargeComplete            : BOOL;
	
	
	//==============================================================
	// Elevator timers
	//==============================================================
	tonElevatorHomingTimeout            : TON;
	tonElevatorHomeSettleDelay          : TON;
	tonElevatorHomeDischargeMinimumRun  : TON;
	tonElevatorLevelingSpeed2Delay      : TON;

	// EN: Filters a brief backstop material interlock during an upward request.
	// PT: Filtra um acionamento breve do intertravamento de material durante a subida.
	tonElevatorUpBlockedByBackstopAlarm : TON;
	
	// EN: Delay after brake release before motor movement.
	// PT: Atraso após liberar o freio antes de movimentar o motor.
	tonElevatorBrakeReleaseDelay        : TON;
	
	// EN: Keeps brake released for a short time after movement stops.
	// PT: Mantém o freio liberado por um tempo após parar o movimento.
	tonElevatorBrakeHoldDelay           : TON;

	// EN: Keeps the servo enabled while the quick-stop command is processed.
	// PT: Mantém o servo habilitado durante o processamento do comando de quick stop.
	tofElevatorDriveDisableDelay        : TOF;
	
	
	//==============================================================
	// Elevator speed ramp instance
	//==============================================================
	// EN: Ramp used for elevator vertical speed [mm/s].
	// PT: Rampa usada para velocidade vertical do elevador [mm/s].
	instRampElevator                    : FB_Gen_SRamp;
	

    //==============================================================
    // Backstop control calculation
    //==============================================================
    backstopAutoTargetPositionMm        : REAL;
    backstopRawSpeedRefMmps             : REAL;
    backstopAbsPositionErrorMm          : REAL;

    backstopHomeLimitReached            : BOOL;
    backstopOpenAllowed                 : BOOL;
    backstopCloseAllowed                : BOOL;

    rBackstopHome                       : BOOL;


	//==============================================================
	// Backstop homing edge detection
	//==============================================================
	backstopHomeLimitOld                 : BOOL;
	backstopHomeLimitFallingEdge         : BOOL;
	backstopHomeMoveAllowed              : BOOL;
	
	
	
	//==============================================================
	// Backstop timers
	//==============================================================
	tonBackstopHomeSettleDelay           : TON;



    //==============================================================
    // Backstop timers
    //==============================================================
    tonBackstopHomingTimeout            : TON;


    //==============================================================
    // Speed ramp instances
    //==============================================================
    instRampSheetConveyor1              : FB_Gen_SRamp;
    instRampSheetConveyor2              : FB_Gen_SRamp;
    instRampSheetConveyor3              : FB_Gen_SRamp;
    instRampSheetConveyor4              : FB_Gen_SRamp;


    //==============================================================
    // PLC scan time measurement
    //==============================================================
    instCycleTime                       : CYCLE_TIME;
    scanTimeS                           : REAL;
    scanTimeMs                          : REAL;

	backstopSignedSpeedRefMmps: REAL;
	
	//==============================================================
	// Sheet stack discharge state machine
	//==============================================================
	sheetStackDischargeControlState         : INT;
	
	
	//==============================================================
	// Sheet stack discharge request pulse
	//==============================================================
	// EN: Extends an accepted unload event for the external counter reset.
	// PT: Prolonga um evento de descarga aceito para resetar o contador externo.
	tpExternalCounterReset                  : TP;
	
	
	//==============================================================
	// Sheet stack discharge timers
	//==============================================================
	tonSheetStackDischarge                  : TON;
	tonSheetStackDischargePlatformClearTimeout : TON;
	elevatorPlatformClearDetected           : BOOL;
	elevatorStackPresentAtDischargeStart    : BOOL;
	
	
	//==============================================================
	// Sheet stack discharge internal conditions
	//==============================================================
	sheetStackDischargeFaultCondition       : BOOL;

	// EN: Remembers that the alignment brush was raised for the current
	//     automatic discharge cycle.
	// PT: Memoriza que a escova de alinhamento foi levantada para o ciclo
	//     atual de descarga automática.
	sheetStackAlignmentBrushLiftedForDischarge : BOOL;
	
	
	//==============================================================
	// Backstop target override
	//==============================================================
	backstopTargetOverrideActive            : BOOL;
	backstopTargetOverridePositionMm        : REAL;
	backstopRequiredForAutomaticOperation   : BOOL;
	
	
	//==============================================================
	// Elevator target override
	//==============================================================
	elevatorTargetOverrideActive     : BOOL;
	elevatorTargetOverridePositionMm : REAL;	
	
	
	sheetStackDischargeConveyorRunRequest: BOOL;
	instTONBackstopDownDelay: TON;
	
	//==============================================================
	// Sheet stack discharge step timeout
	//==============================================================
	tonSheetStackDischargeStepTimeout       : TON;
	
	sheetStackDischargeCycleHasManualSkip   : BOOL;
	sheetStackDischargeCycleHasTimeout      : BOOL;	
	
	
	//==============================================================
	// Elevator homing edge detection
	//==============================================================
	elevatorHomeLimitOld                 : BOOL;
	elevatorHomeLimitFallingEdge         : BOOL;	

	//==============================================================
	// System master run control
	//==============================================================
	systemRunEnable : BOOL;
	
	rStartCmd : BOOL;
	rStopCmd  : BOOL;
	
	//==============================================================
	// Automatic homing requests generated by master start
	//==============================================================
	backstopAutoHomeRequest        : BOOL;
	elevatorAutoHomeRequest : BOOL;

	// EN: Latched start requests awaiting valid homing permissives.
	// PT: Pedidos de partida memorizados aguardando permissivos válidos de homing.
	backstopAutoHomePending        : BOOL;
	elevatorAutoHomePending        : BOOL;
	
	//==============================================================
	// Elevator home request command control
	//==============================================================
	elevatorHomeRequestCombined    : BOOL;
	elevatorHomeRequestCombinedOld : BOOL;
	backstopHomeRunning: BOOL;
	//==============================================================
	// Backstop home request command control
	//==============================================================
	backstopHomeRequestCombined    : BOOL;
	backstopHomeRequestCombinedOld : BOOL;

	//==============================================================
	// EN: Stack buffer conveyor control
	// PT: Controle das esteiras buffer de pilhas
	//==============================================================
	stackBufferControlState                 : INT;
	stackBufferTargetConveyor               : INT;
	elevatorStackExitClearSensorOld         : BOOL;
	rElevatorStackExitClear                 : BOOL;
	tonStackBufferStopDelay                 : TON;
	tonStackBufferTransferTimeout           : TON;
	tonStackBufferFullSpeedReduction        : TON;
	stackBufferTransferTimeoutPulse         : BOOL;
	
	instTONPaperPressOff: TON;
	instTONPaperPressOn: TON;
	paperPressOnPhase: BOOL;

	// EN: Delays exhaust fan shutdown after line speed drops.
	// PT: Atrasa o desligamento do exaustor após a queda da velocidade da linha.
	instTONSheetConveyor1ExhaustFanStopDelay : TON;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[_SystemControl();

_SheetConveyorGroupControl();
_ConveyorSpeedControl();
_SheetConveyor1ExhaustFanControl();

_SheetStackDischargeControl();

_BackstopControl();
_ElevatorControl();
_SheetStackAlignmentBrushControl();
_SheetStackDischargeConveyorControl();
_StackBufferConveyorsControl();
_SheetBrushControl();
_paperPressControl();
_MachineAuxiliary();
_HmiStatus();
_AlarmControl();]]></ST>
    </Implementation>
    <Method Name="_AlarmControl" Id="{45013390-3a2e-451c-bcaa-d7957f4db2e9}">
      <Declaration><![CDATA[//==============================================================
// COMPLEX STACKER — ALARM CONTROL
// EN: Maps internal faults and status conditions to HMI alarm structure.
//==============================================================
METHOD _AlarmControl

VAR
	alarmCompareResult                         : DINT;
	elevatorHomeReleasePermissivesWithoutBackstop : BOOL;
	elevatorUpBlockedByBackstopCondition       : BOOL;
	elevatorUpPermissivesWithoutBackstop       : BOOL;
	elevatorUpRequestActive                    : BOOL;
	hmiAlarmsNotActive                         : hmiAlarmsComplexStacker_TypeStruct;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[//==============================================================
// HMI alarms reset / latch logic
//==============================================================

// EN: Detect an actual upward request before the backstop material sensor
//     is applied to the elevator movement permissive.
// PT: Detecta um pedido real de subida antes de aplicar o sensor de material
//     do backstop ao permissivo de movimento do elevador.
elevatorUpRequestActive :=
    (
        (elevatorControlState = 11) AND
        elevatorHomeLimitReached
    ) OR
    (
        (elevatorControlState = 14) AND
        elevatorHomeDischargeComplete AND
        NOT elevatorInPosition AND
        (elevatorRawSpeedRefMmps > 0.0)
    ) OR
    (
        (elevatorControlState = 20) AND
        elevatorManualCommandRequest AND
        elevatorUpCmd AND
        NOT elevatorDownCmd
    ) OR
    (
        (elevatorControlState = 40) AND
        elevatorTargetOverrideActive AND
        NOT elevatorInPosition AND
        (elevatorRawSpeedRefMmps > 0.0)
    );


elevatorUpPermissivesWithoutBackstop :=
    systemRunEnable AND
    safetyCircuitOk AND
    elevatorDriveOk AND
    NOT elevatorFault AND
    NOT elevatorUpperLimit AND
    NOT elevatorUpperSafetyLimit AND
    (
        NOT elevatorHomed OR
        (elevatorPositionMm < machineConfig.elevatorMaxPositionMm)
    );


elevatorHomeReleasePermissivesWithoutBackstop :=
    systemRunEnable AND
    safetyCircuitOk AND
    elevatorDriveOk AND
    NOT elevatorFault AND
    NOT elevatorUpperLimit AND
    NOT elevatorUpperSafetyLimit;


elevatorUpBlockedByBackstopCondition :=
    backstopMaterialInterlockSensor AND
    (
        (
            (elevatorControlState = 11) AND
            elevatorHomeLimitReached AND
            elevatorHomeReleasePermissivesWithoutBackstop
        ) OR
        (
            (elevatorControlState <> 11) AND
            elevatorUpRequestActive AND
            elevatorUpPermissivesWithoutBackstop
        )
    );


// EN: A short delay avoids latching the alarm because of sensor bounce.
// PT: Um pequeno atraso evita memorizar o alarme devido a repique do sensor.
tonElevatorUpBlockedByBackstopAlarm(
    IN := elevatorUpBlockedByBackstopCondition,
    PT := T#500MS
);

IF resetCmd THEN

    // Reset geral dos alarmes
    hmiAlarms := hmiAlarmsNotActive;

ELSE

    //==============================================================
    // 1) General / system alarms
    //==============================================================
    hmiAlarms.safetyCircuitNotOk :=
        hmiAlarms.safetyCircuitNotOk OR
        NOT safetyCircuitOk;

    hmiAlarms.systemFaultActive :=
        hmiAlarms.systemFaultActive OR
        faultActive OR
        (
            backstopRequiredForAutomaticOperation AND
            backstopFault
        ) OR
        elevatorFault OR
        sheetStackDischargeFault OR
        sheetStackDischargeConveyorFault OR
        NOT stackBufferConveyor1DriveOk OR
        NOT stackBufferConveyor2DriveOk OR
        NOT stackBufferConveyor3DriveOk OR
        stackBufferTransferTimeoutPulse;

    hmiAlarms.systemNotEnabled :=
        hmiAlarms.systemNotEnabled OR
        NOT systemRunEnable;

    // EN: These generic safety feedbacks are used only for diagnostics.
    // PT: Estes retornos genéricos de segurança são usados apenas para diagnóstico.
    hmiAlarms.safetyFeedback1NotOk := hmiAlarms.safetyFeedback1NotOk OR NOT safetyFeedBack1;
    hmiAlarms.safetyFeedback2NotOk := hmiAlarms.safetyFeedback2NotOk OR NOT safetyFeedBack2;
    hmiAlarms.safetyFeedback3NotOk := hmiAlarms.safetyFeedback3NotOk OR NOT safetyFeedBack3;
    hmiAlarms.safetyFeedback4NotOk := hmiAlarms.safetyFeedback4NotOk OR NOT safetyFeedBack4;
    hmiAlarms.safetyFeedback5NotOk := hmiAlarms.safetyFeedback5NotOk OR NOT safetyFeedBack5;
    hmiAlarms.safetyFeedback6NotOk := hmiAlarms.safetyFeedback6NotOk OR NOT safetyFeedBack6;
    hmiAlarms.safetyFeedback7NotOk := hmiAlarms.safetyFeedback7NotOk OR NOT safetyFeedBack7;
    hmiAlarms.safetyFeedback8NotOk := hmiAlarms.safetyFeedback8NotOk OR NOT safetyFeedBack8;


    //==============================================================
    // 2) Sheet conveyor group alarms
    //==============================================================
    hmiAlarms.sheetConveyor1DriveNotOk :=
        hmiAlarms.sheetConveyor1DriveNotOk OR
        NOT sheetConveyor1DriveOk;

    hmiAlarms.sheetConveyor2DriveNotOk :=
        hmiAlarms.sheetConveyor2DriveNotOk OR
        NOT sheetConveyor2DriveOk;

    hmiAlarms.sheetConveyor3DriveNotOk :=
        hmiAlarms.sheetConveyor3DriveNotOk OR
        NOT sheetConveyor3DriveOk;

    hmiAlarms.sheetConveyor4DriveNotOk :=
        hmiAlarms.sheetConveyor4DriveNotOk OR
        NOT sheetConveyor4DriveOk;

    hmiAlarms.sheetConveyorGroupFault :=
        hmiAlarms.sheetConveyorGroupFault OR
        NOT safetyCircuitOk OR
        NOT sheetConveyor1DriveOk OR
        NOT sheetConveyor2DriveOk OR
        NOT sheetConveyor3DriveOk OR
        NOT sheetConveyor4DriveOk;


    //==============================================================
    // 2.1) Stack buffer conveyor alarms
    // EN: Buffer drive faults are alarmed without stopping the main
    //     synchronized conveyor group automatically.
    // PT: Falhas dos drives do buffer geram alarme sem parar automaticamente
    //     o grupo principal de esteiras sincronizadas.
    //==============================================================
    hmiAlarms.stackBufferConveyor1DriveNotOk :=
        hmiAlarms.stackBufferConveyor1DriveNotOk OR
        NOT stackBufferConveyor1DriveOk;

    hmiAlarms.stackBufferConveyor2DriveNotOk :=
        hmiAlarms.stackBufferConveyor2DriveNotOk OR
        NOT stackBufferConveyor2DriveOk;

    hmiAlarms.stackBufferConveyor3DriveNotOk :=
        hmiAlarms.stackBufferConveyor3DriveNotOk OR
        NOT stackBufferConveyor3DriveOk;

    hmiAlarms.stackBufferConveyorGroupFault :=
        hmiAlarms.stackBufferConveyorGroupFault OR
        NOT safetyCircuitOk OR
        NOT stackBufferConveyor1DriveOk OR
        NOT stackBufferConveyor2DriveOk OR
        NOT stackBufferConveyor3DriveOk;

    hmiAlarms.stackBufferTransferTimeout :=
        hmiAlarms.stackBufferTransferTimeout OR
        stackBufferTransferTimeoutPulse;

    hmiAlarms.stackBufferFull :=
        hmiAlarms.stackBufferFull OR
        stackBufferFull;

    hmiAlarms.stackBufferSpeedReductionActive :=
        hmiAlarms.stackBufferSpeedReductionActive OR
        lineSpeedReductionRequest;

 //   hmiAlarms.synchronizedConveyorsNotRunning :=
 //       hmiAlarms.synchronizedConveyorsNotRunning OR
 //       (
 //           systemRunEnable AND
 //           NOT synchronizedConveyorsRunning
 //       );


    //==============================================================
    // 3) Sheet stack separation alarms / indications
    //==============================================================
    // Mantido comentado conforme lógica original.
    // Se quiser ativar como latch, use o mesmo padrão:
    //
    // hmiAlarms.sheetStackSeparationNotReady :=
    //     hmiAlarms.sheetStackSeparationNotReady OR
    //     (
    //         systemRunEnable AND
    //         synchronizedConveyorsRunning AND
    //         NOT sheetStackSeparationReady
    //     );
    //
    // hmiAlarms.sheetStackSeparationActive :=
    //     hmiAlarms.sheetStackSeparationActive OR
    //     sheetStackSeparationActive;
    //
    // hmiAlarms.sheetStackBrakeActive :=
    //     hmiAlarms.sheetStackBrakeActive OR
    //     sheetStackBrakeActive;


    //==============================================================
    // 4) Sheet stack discharge sequence alarms / indications
    //==============================================================
    hmiAlarms.sheetStackDischargeFault :=
        hmiAlarms.sheetStackDischargeFault OR
        sheetStackDischargeFault;

    hmiAlarms.sheetStackDischargeLastCycleNotOk :=
        hmiAlarms.sheetStackDischargeLastCycleNotOk OR
        (
            NOT sheetStackDischargeLastCycleOk AND
            sheetStackDischargeLastResultCode <> 0
        );

    hmiAlarms.sheetStackDischargeTimeout :=
        hmiAlarms.sheetStackDischargeTimeout OR
        (
            sheetStackDischargeFault AND
            (sheetStackDischargeLastResultCode = 3)
        );

    hmiAlarms.sheetStackDischargeManualSkip :=
        hmiAlarms.sheetStackDischargeManualSkip OR
        sheetStackDischargeLastResultCode = 2;

    hmiAlarms.sheetStackDischargeWaitSeparationTimeout :=
        hmiAlarms.sheetStackDischargeWaitSeparationTimeout OR
        (
            sheetStackDischargeFault AND
            (sheetStackDischargeLastFaultCode = 10)
        );

    hmiAlarms.sheetStackDischargePositioningTimeout :=
        hmiAlarms.sheetStackDischargePositioningTimeout OR
        (
            sheetStackDischargeFault AND
            (sheetStackDischargeLastFaultCode = 20)
        );

    hmiAlarms.sheetStackDischargeConveyorStartTimeout :=
        hmiAlarms.sheetStackDischargeConveyorStartTimeout OR
        (
            sheetStackDischargeFault AND
            (sheetStackDischargeLastFaultCode = 30)
        );

    hmiAlarms.sheetStackDischargePlatformClearTimeout :=
        hmiAlarms.sheetStackDischargePlatformClearTimeout OR
        (
            sheetStackDischargeFault AND
            (sheetStackDischargeLastFaultCode = 31)
        );

    hmiAlarms.sheetStackDischargeReturnTimeout :=
        hmiAlarms.sheetStackDischargeReturnTimeout OR
        (
            sheetStackDischargeFault AND
            (sheetStackDischargeLastFaultCode = 50)
        );


    //==============================================================
    // 5) Sheet stack discharge conveyor alarms
    //==============================================================
    hmiAlarms.sheetStackDischargeConveyorDriveNotOk :=
        hmiAlarms.sheetStackDischargeConveyorDriveNotOk OR
        NOT sheetStackDischargeConveyorDriveOk;

    hmiAlarms.sheetStackDischargeConveyorFault :=
        hmiAlarms.sheetStackDischargeConveyorFault OR
        sheetStackDischargeConveyorFault;


    //==============================================================
    // 6) Backstop alarms / indications
    //==============================================================
    hmiAlarms.backstopDriveNotOk :=
        hmiAlarms.backstopDriveNotOk OR
        NOT backstopDriveOk;

    hmiAlarms.backstopFault :=
        hmiAlarms.backstopFault OR
        backstopFault;

    hmiAlarms.backstopNotHomed :=
        hmiAlarms.backstopNotHomed OR
        (
            systemRunEnable AND
            backstopAutoCmd AND
            NOT backstopHomed AND
            NOT backstopAutoHomePending AND
            NOT (
                (backstopControlState >= 10) AND
                (backstopControlState <= 14)
            )
        );

    hmiAlarms.backstopHomingTimeout :=
        hmiAlarms.backstopHomingTimeout OR
        (
            backstopFault AND
            (backstopFaultCode = 3)
        );

    hmiAlarms.backstopInvalidHomeDirection :=
        hmiAlarms.backstopInvalidHomeDirection OR
        (
            backstopFault AND
            (backstopFaultCode = 5)
        );

    (*
    hmiAlarms.backstopNotInPosition :=
        hmiAlarms.backstopNotInPosition OR
        (
            systemRunEnable AND
            backstopAutoCmd AND
            backstopHomed AND
            NOT backstopInPosition AND
            NOT backstopTargetOverrideActive
        );
    *)

    hmiAlarms.backstopSafeMaxLimitActive :=
        hmiAlarms.backstopSafeMaxLimitActive OR
        backstopSafeMaxLimit;

    hmiAlarms.backstopSafeMinLimitActive :=
        hmiAlarms.backstopSafeMinLimitActive OR
        backstopSafeMinLimit;

    (*
    hmiAlarms.backstopMaxLimitActive :=
        hmiAlarms.backstopMaxLimitActive OR
        backstopMaxLimit;

    hmiAlarms.backstopMinLimitActive :=
        hmiAlarms.backstopMinLimitActive OR
        backstopMinLimit;

    hmiAlarms.backstopManualInterventionActive :=
        hmiAlarms.backstopManualInterventionActive OR
        backstopManualInterventionActive;
    *)


    //==============================================================
    // 7) Elevator alarms / indications
    //==============================================================
    hmiAlarms.elevatorDriveNotOk :=
        hmiAlarms.elevatorDriveNotOk OR
        NOT elevatorDriveOk;

    hmiAlarms.elevatorFault :=
        hmiAlarms.elevatorFault OR
        elevatorFault;

    hmiAlarms.elevatorNotHomed :=
        hmiAlarms.elevatorNotHomed OR
        (
            systemRunEnable AND
            elevatorAutoCmd AND
            NOT elevatorHomed AND
            NOT elevatorAutoHomePending AND
            NOT (
                (elevatorControlState >= 10) AND
                (elevatorControlState <= 14)
            )
        );

    hmiAlarms.elevatorHomingTimeout :=
        hmiAlarms.elevatorHomingTimeout OR
        (
            elevatorFault AND
            (elevatorFaultCode = 3)
        );

    hmiAlarms.elevatorUpBlockedByBackstopMaterialInterlock :=
        hmiAlarms.elevatorUpBlockedByBackstopMaterialInterlock OR
        tonElevatorUpBlockedByBackstopAlarm.Q;

//    hmiAlarms.elevatorNotInPosition :=
//        hmiAlarms.elevatorNotInPosition OR
//        (
//            systemRunEnable AND
//            elevatorAutoCmd AND
//            elevatorHomed AND
//            NOT elevatorInPosition
//        );

    hmiAlarms.elevatorUpperSafetyLimitActive :=
        hmiAlarms.elevatorUpperSafetyLimitActive OR
        elevatorUpperSafetyLimit;

    hmiAlarms.elevatorLowerSafetyLimitActive :=
        hmiAlarms.elevatorLowerSafetyLimitActive OR
        elevatorLowerSafetyLimit;

    (*
    hmiAlarms.elevatorUpperLimitActive :=
        hmiAlarms.elevatorUpperLimitActive OR
        elevatorUpperLimit;

    hmiAlarms.elevatorLowerLimitActive :=
        hmiAlarms.elevatorLowerLimitActive OR
        elevatorLowerLimit;
    *)

END_IF;


// EN: The general output follows every latched field in the alarm structure.
// PT: A saída geral acompanha qualquer campo memorizado na estrutura de alarmes.
alarmCompareResult := MEMCMP(
    pBuf1 := ADR(hmiAlarmsNotActive),
    pBuf2 := ADR(hmiAlarms),
    n := SIZEOF(hmiAlarms)
);

alarmActive := alarmCompareResult <> 0;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_BackstopControl" Id="{a8131784-f5c8-4a18-af8b-160d5c9efcab}">
      <Declaration><![CDATA[//==============================================================
// COMPLEX STACKER — BACKSTOP CONTROL
// EN: Controls the backstop axis with homing, manual movement,
//     automatic positioning, override positioning and protections.
//
// Signed speed convention:
// Positive = open
// Negative = close
//
// State code:
// 0  = STOP
// 10 = HOME_FAST_SEARCH
// 11 = HOME_SLOW_EXIT_SENSOR
// 12 = HOME_SET_ENCODER
// 13 = HOME_WAIT_AFTER_SET
// 14 = HOME_MOVE_TO_TARGET
// 20 = MANUAL
// 30 = AUTO_POSITION
// 40 = FAULT
//==============================================================
METHOD _BackstopControl]]></Declaration>
      <Implementation>
        <ST><![CDATA[


//==============================================================
// 1) Default internal commands
//==============================================================
// EN: Internal signed speed is reset every scan and set by the active state.
//     Positive = open, negative = close.
backstopSignedSpeedRefMmps := 0.0;

// EN: Internal trigger for encoder set pulse.
backstopSetEncoderPositionTrigger := FALSE;


//==============================================================
// 2) Edge detection
//==============================================================
// EN: Home can be requested manually by HMI or automatically by _SystemControl.
//     Automatic home is accepted only when backstopAutoCmd is enabled.
//     Movement is allowed only when master system run is enabled.
backstopHomeRequestCombined :=
    systemRunEnable AND
    (
        backstopHomeCmd OR
        (
            backstopAutoCmd AND
            backstopAutoHomeRequest
        )
    );

// EN: The automatic pulse is accepted directly so a maintained manual home
//     command cannot hide the mandatory start-triggered request.
// PT: O pulso automático é aceito diretamente para que um comando manual de
//     home mantido não esconda o pedido obrigatório gerado pela partida.
rBackstopHome :=
    (
        backstopHomeRequestCombined AND
        NOT backstopHomeRequestCombinedOld
    ) OR
    (
        systemRunEnable AND
        backstopAutoCmd AND
        backstopAutoHomeRequest
    );

backstopHomeRequestCombinedOld :=
    backstopHomeRequestCombined;


// EN: Execute positioning command edge.
//     This command only generates movement when system is enabled and backstop auto is enabled.
rBackstopExecutePositioning :=
    systemRunEnable AND
    backstopExecutePositioningCmd AND
    NOT backstopExecutePositioningCmdOld;

backstopExecutePositioningCmdOld := backstopExecutePositioningCmd;


// EN: Override falling edge.
//     Used as fallback to return to programmed position if override is released.
backstopTargetOverrideFallingEdge :=
    backstopTargetOverrideOld AND NOT backstopTargetOverrideActive;

backstopTargetOverrideOld := backstopTargetOverrideActive;


//==============================================================
// 3) Home limit selection and edge detection
//==============================================================
// EN: Home limit depends on configured homing direction.
IF machineConfig.backstopHomeDirection > 0 THEN

    backstopHomeLimitReached := backstopMaxLimit;

ELSIF machineConfig.backstopHomeDirection < 0 THEN

    backstopHomeLimitReached := backstopMinLimit;

ELSE

    backstopHomeLimitReached := FALSE;

END_IF;


// EN: Falling edge is used after the home limit has been reached.
backstopHomeLimitFallingEdge :=
    backstopHomeLimitOld AND NOT backstopHomeLimitReached;

backstopHomeLimitOld := backstopHomeLimitReached;


//==============================================================
// 4) Movement permissions
//==============================================================
backstopOpenAllowed :=
    systemRunEnable AND
    safetyCircuitOk AND
    backstopDriveOk AND
    NOT backstopMaxLimit AND
    NOT backstopSafeMaxLimit AND
    (
        (NOT backstopHomed) OR
        (backstopPositionMm < machineConfig.backstopMaxPositionMm)
    );

backstopCloseAllowed :=
    systemRunEnable AND
    safetyCircuitOk AND
    backstopDriveOk AND
    NOT backstopMinLimit AND
    NOT backstopSafeMinLimit AND
    (
        (NOT backstopHomed) OR
        (backstopPositionMm > machineConfig.backstopMinPositionMm)
    );


// EN: During homing, the normal home limit is allowed.
//     Only the safe limit blocks movement.
IF machineConfig.backstopHomeDirection > 0 THEN

    backstopHomeMoveAllowed :=
        systemRunEnable AND
        safetyCircuitOk AND
        backstopDriveOk AND
        NOT backstopSafeMaxLimit;

ELSIF machineConfig.backstopHomeDirection < 0 THEN

    backstopHomeMoveAllowed :=
        systemRunEnable AND
        safetyCircuitOk AND
        backstopDriveOk AND
        NOT backstopSafeMinLimit;

ELSE

    backstopHomeMoveAllowed := FALSE;

END_IF;


//==============================================================
// 5) Programmed / override target calculation
//==============================================================
// EN: Programmed target follows sheet length plus mechanical offset.
//     This value can change, but it does not move the backstop by itself.
backstopProgrammedTargetPositionMm :=
    LIMIT(
        machineConfig.backstopMinPositionMm,
        MAX(0.0, sheetLengthMm) + machineConfig.backstopSheetLengthOffsetMm,
        machineConfig.backstopMaxPositionMm
    );


// EN: Before homing, keep the latched target updated with programmed target.
//     This avoids an invalid old target after power-up.
IF NOT backstopHomed THEN

    backstopLatchedTargetPositionMm := backstopProgrammedTargetPositionMm;

END_IF;


//==============================================================
// 5.1) Automatic positioning request handling
//==============================================================
// EN: Auto mode only enables positioning. It does not execute positioning.
//     Normal positioning must be requested by backstopExecutePositioningCmd.
//     Override positioning is requested by the automatic cycle.
IF NOT systemRunEnable THEN

    backstopPositioningRequestActive := FALSE;


ELSIF NOT backstopAutoCmd THEN

    backstopPositioningRequestActive := FALSE;


ELSIF backstopTargetOverrideActive THEN

    // EN: Override has priority. Clear normal positioning request.
    backstopPositioningRequestActive := FALSE;


ELSIF rBackstopExecutePositioning THEN

    // EN: Latch current programmed target only when execute command is received.
    backstopLatchedTargetPositionMm := backstopProgrammedTargetPositionMm;
    backstopPositioningRequestActive := TRUE;


ELSIF backstopTargetOverrideFallingEdge THEN

    // EN: Fallback after override release.
    //     The discharge sequence should normally keep override active
    //     during return. If override is released unexpectedly, return to
    //     programmed position automatically.
    backstopLatchedTargetPositionMm := backstopProgrammedTargetPositionMm;
    backstopPositioningRequestActive := TRUE;

END_IF;


//==============================================================
// 5.2) Active target selection
//==============================================================
// EN: Discharge override is accepted only while the backstop is in automatic.
//     In manual mode the backstop is completely independent from the cycle.
// PT: O override de descarte é aceito somente com o backstop em automático.
//     No modo manual o backstop fica completamente independente do ciclo.
IF systemRunEnable AND
   backstopAutoCmd AND
   backstopTargetOverrideActive THEN

    backstopTargetPositionMm :=
        LIMIT(
            machineConfig.backstopMinPositionMm,
            backstopTargetOverridePositionMm,
            machineConfig.backstopMaxPositionMm
        );

ELSE

    backstopTargetPositionMm :=
        LIMIT(
            machineConfig.backstopMinPositionMm,
            backstopLatchedTargetPositionMm,
            machineConfig.backstopMaxPositionMm
        );

END_IF;


//==============================================================
// 5.4) Home running flag
//==============================================================
IF (backstopControlState = 10) OR
   (backstopControlState = 11) OR
   (backstopControlState = 12) OR
   (backstopControlState = 13) OR
   (backstopControlState = 14) THEN

    backstopHomeRunning := TRUE;

ELSE

    backstopHomeRunning := FALSE;

END_IF;


//==============================================================
// 6) Position error calculation
//==============================================================
backstopPositionErrorMm :=
    backstopTargetPositionMm - backstopPositionMm;

backstopAbsPositionErrorMm :=
    ABS(backstopPositionErrorMm);

backstopInPosition :=
    backstopHomed AND
    (backstopAbsPositionErrorMm <= machineConfig.backstopPositionToleranceMm);


//==============================================================
// 7) Reset fault command
//==============================================================
IF resetCmd THEN

    IF safetyCircuitOk AND
       backstopDriveOk AND
       NOT backstopSafeMaxLimit AND
       NOT backstopSafeMinLimit THEN

        backstopFault := FALSE;
        backstopFaultCode := 0;

        IF backstopControlState = 40 THEN
            backstopControlState := 0;
        END_IF

    END_IF

END_IF;


//==============================================================
// 8) General protection
//==============================================================
IF NOT safetyCircuitOk THEN

    backstopState := 'SAFETY_OFF';

    tonBackstopHomingTimeout(IN := FALSE);
    tonBackstopHomeSettleDelay(IN := FALSE);

    backstopFault := TRUE;
    backstopFaultCode := 2;
    backstopControlState := 40;


ELSIF NOT backstopDriveOk THEN

    backstopState := 'DRIVE_NOT_OK';

    tonBackstopHomingTimeout(IN := FALSE);
    tonBackstopHomeSettleDelay(IN := FALSE);

    backstopFault := TRUE;
    backstopFaultCode := 1;
    backstopControlState := 40;


ELSIF backstopSafeMaxLimit THEN

    backstopState := 'SAFE_MAX_LIMIT';

    tonBackstopHomingTimeout(IN := FALSE);
    tonBackstopHomeSettleDelay(IN := FALSE);

    backstopFault := TRUE;
    backstopFaultCode := 6;
    backstopControlState := 40;


ELSIF backstopSafeMinLimit THEN

    backstopState := 'SAFE_MIN_LIMIT';

    tonBackstopHomingTimeout(IN := FALSE);
    tonBackstopHomeSettleDelay(IN := FALSE);

    backstopFault := TRUE;
    backstopFaultCode := 7;
    backstopControlState := 40;


ELSIF machineConfig.backstopHomeDirection = 0 THEN

    backstopState := 'INVALID_HOME_DIR';

    tonBackstopHomingTimeout(IN := FALSE);
    tonBackstopHomeSettleDelay(IN := FALSE);

    backstopFault := TRUE;
    backstopFaultCode := 5;
    backstopControlState := 40;


ELSIF NOT systemRunEnable THEN

    // EN: Master stop disables movement without generating an axis fault.
    backstopState := 'SYSTEM_DISABLED';

    backstopSignedSpeedRefMmps := 0.0;

    tonBackstopHomingTimeout(IN := FALSE);
    tonBackstopHomeSettleDelay(IN := FALSE);

    backstopPositioningRequestActive := FALSE;

    IF backstopControlState <> 40 THEN
        backstopControlState := 0;
    END_IF


ELSE

    //==============================================================
    // 9) Mode selection
    //==============================================================
    // EN: Homing has priority over manual and automatic positioning.
    IF rBackstopHome AND NOT backstopFault THEN
        backstopControlState := 10;

        // EN: Consume the pending request only after homing is accepted.
        // PT: Consome o pedido pendente somente após o homing ser aceito.
        backstopAutoHomePending := FALSE;
    END_IF;


    //==============================================================
    // 10) Backstop state machine
    //==============================================================
    CASE backstopControlState OF

        0: // STOP
            backstopState := 'STOP';

            tonBackstopHomingTimeout(IN := FALSE);
            tonBackstopHomeSettleDelay(IN := FALSE);

            // EN: Manual is allowed even with auto enabled,
            //     but not during an automatic cycle override.
            IF (backstopOpenCmd OR backstopCloseCmd) AND
               NOT (
                   backstopAutoCmd AND
                   backstopTargetOverrideActive
               ) THEN

                backstopControlState := 20;


            ELSIF backstopAutoCmd AND
                  (
                      backstopTargetOverrideActive OR
                      backstopPositioningRequestActive
                  ) THEN

                backstopControlState := 30;

            END_IF


        10: // HOME_FAST_SEARCH
            backstopState := 'HOME_FAST';

            backstopHomed := FALSE;
            backstopInPosition := FALSE;

            tonBackstopHomeSettleDelay(IN := FALSE);

            tonBackstopHomingTimeout(
                IN := TRUE,
                PT := machineConfig.backstopHomingTimeout
            );

            IF tonBackstopHomingTimeout.Q THEN

                backstopSignedSpeedRefMmps := 0.0;

                tonBackstopHomingTimeout(IN := FALSE);

                backstopFault := TRUE;
                backstopFaultCode := 3;

                backstopState := 'HOME_TIMEOUT';
                backstopControlState := 40;


            ELSIF backstopHomeLimitReached THEN

                backstopSignedSpeedRefMmps := 0.0;

                backstopControlState := 11;


            ELSE

                IF backstopHomeMoveAllowed THEN

                    IF machineConfig.backstopHomeDirection > 0 THEN

                        backstopSignedSpeedRefMmps :=
                            ABS(machineConfig.backstopHomingSpeedMmps);

                    ELSE

                        backstopSignedSpeedRefMmps :=
                            -ABS(machineConfig.backstopHomingSpeedMmps);

                    END_IF

                ELSE

                    backstopSignedSpeedRefMmps := 0.0;

                END_IF

            END_IF


        11: // HOME_SLOW_EXIT_SENSOR
            backstopState := 'HOME_SLOW_EXIT';

            tonBackstopHomeSettleDelay(IN := FALSE);

            tonBackstopHomingTimeout(
                IN := TRUE,
                PT := machineConfig.backstopHomingTimeout
            );

            IF tonBackstopHomingTimeout.Q THEN

                backstopSignedSpeedRefMmps := 0.0;

                tonBackstopHomingTimeout(IN := FALSE);

                backstopFault := TRUE;
                backstopFaultCode := 3;

                backstopState := 'HOME_TIMEOUT';
                backstopControlState := 40;


            ELSIF backstopHomeLimitFallingEdge THEN

                backstopSignedSpeedRefMmps := 0.0;

                tonBackstopHomingTimeout(IN := FALSE);

                backstopControlState := 12;


            ELSE

                IF backstopHomeMoveAllowed THEN

                    IF machineConfig.backstopHomeDirection > 0 THEN

                        backstopSignedSpeedRefMmps :=
                            -ABS(machineConfig.backstopMinMoveSpeedMmps);

                    ELSE

                        backstopSignedSpeedRefMmps :=
                            ABS(machineConfig.backstopMinMoveSpeedMmps);

                    END_IF

                ELSE

                    backstopSignedSpeedRefMmps := 0.0;

                END_IF

            END_IF


        12: // HOME_SET_ENCODER
            backstopState := 'HOME_SET_ENCODER';

            backstopSignedSpeedRefMmps := 0.0;

            tonBackstopHomingTimeout(IN := FALSE);
            tonBackstopHomeSettleDelay(IN := FALSE);

            // EN: Set encoder to configured known home position.
            backstopSetEncoderPositionTrigger := TRUE;
            backstopSetEncoderPositionMm := machineConfig.backstopHomePositionMm;

            backstopHomed := TRUE;
            backstopFault := FALSE;
            backstopFaultCode := 0;

            // EN: After homing, latch current programmed target for home move.
            backstopLatchedTargetPositionMm := backstopProgrammedTargetPositionMm;
            backstopPositioningRequestActive := TRUE;

            // EN: Homing cancels previous manual intervention memory.
            backstopManualInterventionActive := FALSE;
            backstopManualInterventionPositionMm := 0.0;

            backstopControlState := 13;


        13: // HOME_WAIT_AFTER_SET
            backstopState := 'HOME_WAIT';

            backstopSignedSpeedRefMmps := 0.0;

            tonBackstopHomingTimeout(IN := FALSE);

            // EN: Fixed wait after encoder set.
            tonBackstopHomeSettleDelay(
                IN := TRUE,
                PT := T#5S
            );

            IF tonBackstopHomeSettleDelay.Q THEN

                tonBackstopHomeSettleDelay(IN := FALSE);

                backstopControlState := 14;

            END_IF


        14: // HOME_MOVE_TO_TARGET
            backstopState := 'HOME_TO_TARGET';

            tonBackstopHomingTimeout(IN := FALSE);
            tonBackstopHomeSettleDelay(IN := FALSE);

            // EN: Move to the latched programmed target after homing.
            IF backstopInPosition THEN

                backstopSignedSpeedRefMmps := 0.0;

                backstopPositioningRequestActive := FALSE;

                // EN: Home positioning completed, no manual intervention pending.
                backstopManualInterventionActive := FALSE;
                backstopManualInterventionPositionMm := 0.0;

                backstopControlState := 0;


            ELSE

                backstopRawSpeedRefMmps :=
                    backstopPositionErrorMm * machineConfig.backstopPositionKp;

                backstopRawSpeedRefMmps :=
                    LIMIT(
                        -ABS(machineConfig.backstopAutoMaxSpeedMmps),
                        backstopRawSpeedRefMmps,
                        ABS(machineConfig.backstopAutoMaxSpeedMmps)
                    );

                IF ABS(backstopRawSpeedRefMmps) <
                   ABS(machineConfig.backstopMinMoveSpeedMmps) THEN

                    IF backstopPositionErrorMm > 0.0 THEN

                        backstopRawSpeedRefMmps :=
                            ABS(machineConfig.backstopMinMoveSpeedMmps);

                    ELSE

                        backstopRawSpeedRefMmps :=
                            -ABS(machineConfig.backstopMinMoveSpeedMmps);

                    END_IF

                END_IF

                IF (backstopRawSpeedRefMmps > 0.0) AND backstopOpenAllowed THEN

                    backstopSignedSpeedRefMmps := backstopRawSpeedRefMmps;

                ELSIF (backstopRawSpeedRefMmps < 0.0) AND backstopCloseAllowed THEN

                    backstopSignedSpeedRefMmps := backstopRawSpeedRefMmps;

                ELSE

                    backstopSignedSpeedRefMmps := 0.0;

                END_IF

            END_IF


        20: // MANUAL
            backstopState := 'MANUAL';

            tonBackstopHomingTimeout(IN := FALSE);
            tonBackstopHomeSettleDelay(IN := FALSE);

            // EN: An automatic override cancels manual control only when
            //     the backstop itself is enabled in automatic mode.
            // PT: O override automático cancela o controle manual somente
            //     quando o próprio backstop está habilitado em automático.
            IF backstopAutoCmd AND
               backstopTargetOverrideActive THEN

                backstopSignedSpeedRefMmps := 0.0;
                backstopControlState := 30;


            ELSIF backstopOpenCmd AND backstopCloseCmd THEN

                backstopSignedSpeedRefMmps := 0.0;


            ELSIF backstopOpenCmd THEN

                IF backstopOpenAllowed THEN

                    backstopSignedSpeedRefMmps :=
                        ABS(machineConfig.backstopManualSpeedMmps);

                    // EN: Store last manual intervention position.
                    //     This is updated while the operator holds the manual command.
                    backstopManualInterventionActive := TRUE;
                    backstopManualInterventionPositionMm := backstopPositionMm;

                ELSE

                    backstopSignedSpeedRefMmps := 0.0;

                END_IF


            ELSIF backstopCloseCmd THEN

                IF backstopCloseAllowed THEN

                    backstopSignedSpeedRefMmps :=
                        -ABS(machineConfig.backstopManualSpeedMmps);

                    // EN: Store the last manual intervention position.
                    //     The discharge opening uses the greater value between the
                    //     current mechanical position and this stored position.
                    // PT: Memoriza a última posição de intervenção manual.
                    //     A abertura de descarga usa o maior valor entre a posição
                    //     mecânica atual e esta posição memorizada.
                    backstopManualInterventionActive := TRUE;
                    backstopManualInterventionPositionMm := backstopPositionMm;

                ELSE

                    backstopSignedSpeedRefMmps := 0.0;

                END_IF


            ELSE

                backstopSignedSpeedRefMmps := 0.0;

                // EN: After manual command release, do not automatically return
                //     to programmed position. Wait for execute positioning command.
                backstopPositioningRequestActive := FALSE;

                backstopControlState := 0;

            END_IF


        30: // AUTO_POSITION
            backstopState := 'AUTO_POSITION';

            tonBackstopHomingTimeout(IN := FALSE);
            tonBackstopHomeSettleDelay(IN := FALSE);

            // EN: Manual mode always cancels automatic positioning,
            //     regardless of any external override request.
            // PT: O modo manual sempre cancela o posicionamento automático,
            //     independentemente de qualquer pedido externo de override.
            IF NOT backstopAutoCmd THEN

                backstopSignedSpeedRefMmps := 0.0;
                backstopPositioningRequestActive := FALSE;
                backstopControlState := 0;


            ELSIF NOT backstopHomed THEN

                backstopSignedSpeedRefMmps := 0.0;
                backstopState := 'AUTO_NO_HOME';


            ELSIF (backstopOpenCmd OR backstopCloseCmd) AND
                  NOT backstopTargetOverrideActive THEN

                // EN: Manual has priority only outside automatic cycle override.
                backstopSignedSpeedRefMmps := 0.0;
                backstopPositioningRequestActive := FALSE;
                backstopControlState := 20;


            ELSIF NOT backstopTargetOverrideActive AND
                  NOT backstopPositioningRequestActive THEN

                // EN: Auto enabled but no positioning command active.
                backstopSignedSpeedRefMmps := 0.0;
                backstopControlState := 0;


            ELSIF backstopInPosition THEN

                backstopSignedSpeedRefMmps := 0.0;

                // EN: Normal positioning command ends when target is reached.
                //     Override remains controlled by the automatic cycle.
                IF NOT backstopTargetOverrideActive THEN

                    backstopPositioningRequestActive := FALSE;

                    // EN: If the backstop returned to programmed target,
                    //     clear previous manual intervention memory.
                    backstopManualInterventionActive := FALSE;
                    backstopManualInterventionPositionMm := 0.0;

                    backstopControlState := 0;

                END_IF


            ELSE

                backstopRawSpeedRefMmps :=
                    backstopPositionErrorMm * machineConfig.backstopPositionKp;

                backstopRawSpeedRefMmps :=
                    LIMIT(
                        -ABS(machineConfig.backstopAutoMaxSpeedMmps),
                        backstopRawSpeedRefMmps,
                        ABS(machineConfig.backstopAutoMaxSpeedMmps)
                    );

                IF ABS(backstopRawSpeedRefMmps) <
                   ABS(machineConfig.backstopMinMoveSpeedMmps) THEN

                    IF backstopPositionErrorMm > 0.0 THEN

                        backstopRawSpeedRefMmps :=
                            ABS(machineConfig.backstopMinMoveSpeedMmps);

                    ELSE

                        backstopRawSpeedRefMmps :=
                            -ABS(machineConfig.backstopMinMoveSpeedMmps);

                    END_IF

                END_IF

                IF (backstopRawSpeedRefMmps > 0.0) AND backstopOpenAllowed THEN

                    backstopSignedSpeedRefMmps := backstopRawSpeedRefMmps;

                ELSIF (backstopRawSpeedRefMmps < 0.0) AND backstopCloseAllowed THEN

                    backstopSignedSpeedRefMmps := backstopRawSpeedRefMmps;

                ELSE

                    backstopSignedSpeedRefMmps := 0.0;

                END_IF

            END_IF


        40: // FAULT
            backstopState := 'FAULT';

            backstopSignedSpeedRefMmps := 0.0;

            tonBackstopHomingTimeout(IN := FALSE);
            tonBackstopHomeSettleDelay(IN := FALSE);

            backstopPositioningRequestActive := FALSE;

            IF resetCmd AND
               safetyCircuitOk AND
               backstopDriveOk AND
               NOT backstopSafeMaxLimit AND
               NOT backstopSafeMinLimit THEN

                backstopFault := FALSE;
                backstopFaultCode := 0;
                backstopControlState := 0;

            END_IF


    ELSE

        backstopControlState := 0;

    END_CASE;

END_IF;


//==============================================================
// 11) Encoder set pulse
//==============================================================
// EN: Extend encoder set command to ensure the encoder block sees it.
tpBackstopSetEncoderPosition(
    IN := backstopSetEncoderPositionTrigger,
    PT := machineConfig.backstopSetEncoderPulseTime
);

backstopSetEncoderPosition := tpBackstopSetEncoderPosition.Q;


//==============================================================
// 12) Backstop drive direction and speed outputs
//==============================================================
// EN: Convert signed internal speed command into direction outputs
//     and positive speed reference.
IF systemRunEnable AND
   safetyCircuitOk AND
   backstopDriveOk AND
   NOT backstopFault AND
   (ABS(backstopSignedSpeedRefMmps) >= machineConfig.backstopRunMinSpeedMmps) THEN

    // EN: The servo receives the signed speed reference directly.
    // PT: O servo recebe diretamente a referência de velocidade com sinal.
    backstopSpeedRefMmps := backstopSignedSpeedRefMmps;

    backstopRunFw :=
        backstopSignedSpeedRefMmps > 0.0;

    backstopRunRev :=
        backstopSignedSpeedRefMmps < 0.0;

ELSE

    backstopSpeedRefMmps := 0.0;

    backstopRunFw := FALSE;
    backstopRunRev := FALSE;

END_IF;

// EN: Enable the servo with the stacker system; drive-ready feedback is not used here
//     because it would create a circular enable dependency.
// PT: Habilita o servo com o sistema do stacker; o retorno de drive pronto não é usado
//     aqui porque criaria uma dependência circular de habilitação.
backstopDriveEnable := systemRunEnable AND safetyCircuitOk;


//==============================================================
// 13) Backstop plate lift solenoid
//==============================================================
// EN: Lift the backstop plate during backstop movement and homing.
//     Discharge conveyor protection can be ORed after all methods are called.
IF systemRunEnable AND
   (
       backstopRunFw OR
       backstopRunRev OR
       sheetStackDischargeActive OR
       (backstopControlState = 10) OR
       (backstopControlState = 11) OR
       (backstopControlState = 12) OR
       (backstopControlState = 13) OR
       (backstopControlState = 14)
   ) THEN

    backstopPlateUpSolenoid := TRUE;
    instTONBackstopDownDelay.IN := FALSE;

ELSE

    instTONBackstopDownDelay.IN := TRUE;

    IF instTONBackstopDownDelay.Q THEN
        backstopPlateUpSolenoid := FALSE;
    END_IF

END_IF;

instTONBackstopDownDelay(PT := T#200MS);]]></ST>
      </Implementation>
    </Method>
    <Method Name="_ConveyorSpeedControl" Id="{b62cf8f8-3272-4eb3-b76e-d7c96032c01b}">
      <Declaration><![CDATA[//==============================================================
// COMPLEX STACKER — SPEED REFERENCE GENERATOR
// EN: Generates synchronized and sheet-stack separation speed references [m/min].
//==============================================================
METHOD _ConveyorSpeedControl
VAR
    packageGapReady                   : BOOL;
    validCycleTimeS                   : REAL;

    sheetConveyorsSpeedUpReferenceMPM : REAL;

    sheetConveyor1BaseSpeedMPM        : REAL;
    sheetConveyor2BaseSpeedMPM        : REAL;
    sheetConveyor3BaseSpeedMPM        : REAL;
    sheetConveyor4BaseSpeedMPM        : REAL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[

//==============================================================
// 1) Default event pulses
//==============================================================
sheetStackSeparationStarted         := FALSE;
sheetStackSeparationFinished        := FALSE;

sheetConveyor2SeparationStarted     := FALSE;
sheetConveyor2SeparationFinished    := FALSE;

sheetConveyor3SeparationStarted     := FALSE;
sheetConveyor3SeparationFinished    := FALSE;

sheetConveyor4SeparationStarted     := FALSE;
sheetConveyor4SeparationFinished    := FALSE;


//==============================================================
// 2) Accepted unload event
//==============================================================
// EN: The separation state machine is started only by
//     dischargeRequestAccepted, generated by the discharge controller.
// PT: A máquina de estados de separação é iniciada somente por
//     dischargeRequestAccepted, gerado pelo controle de descarga.


//==============================================================
// 3) Enable and scan time
//==============================================================
speedControlEnabled :=
    sheetConveyor1Run AND
    sheetConveyor2Run AND
    sheetConveyor3Run AND
    sheetConveyor4Run AND
    safetyCircuitOk
 	AND NOT blockConveyorCmd;

rampReset := NOT speedControlEnabled;


// EN: Read PLC scan time using OSCAT CYCLE_TIME.
instCycleTime(
    RST := resetCmd
);


// EN: Convert last cycle time from TIME/ms to seconds.
scanTimeMs := TIME_TO_REAL(instCycleTime.ct_last);

validCycleTimeS :=
    LIMIT(
        0.001,
        scanTimeMs / 1000.0,
        20.0
    );

scanTimeS := validCycleTimeS;


//==============================================================
// 4) Sheet length conversion
//==============================================================
// EN: Sheet length is kept converted for other calculations,
//     but it is no longer used as the separation tracking target.
sheetLengthM := MAX(0.0, sheetLengthMm) / 1000.0;


//==============================================================
// 5) Select effective line speed during package discharge
//==============================================================
effectiveLineSpeedMPM := MAX(0.0, lineSpeedMPM);

// EN: While package separation is active, a low line speed is replaced by
//     the configured threshold. Outside separation, the actual line speed is used.
// PT: Durante a separação da pilha, uma velocidade baixa da linha é substituída
//     pelo limite configurado. Fora da separação, usa-se a velocidade real da linha.
IF packageSeparationState <> 0 THEN

    effectiveLineSpeedMPM :=
        MAX(
            effectiveLineSpeedMPM,
            MAX(0.0, machineConfig.packageDischargeLineSpeedThresholdMPM)
        );

END_IF;


//==============================================================
// 6) Calculate normal stacker speed
//==============================================================
IF speedControlEnabled AND NOT blockConveyorCmd THEN

    normalStackerSpeedMPM :=
        LIMIT(
            machineConfig.minimumSpeedMPM,
            effectiveLineSpeedMPM *
                MAX(0.0, machineConfig.stackerSpeedRatio),
            machineConfig.maximumSpeedMPM
        );

ELSE

    normalStackerSpeedMPM := 0.0;

END_IF;


//==============================================================
// 7) Calculate normal speed for each conveyor
//==============================================================
sheetConveyor1NormalSpeedMPM :=
    normalStackerSpeedMPM *
    MAX(0.0, machineConfig.sheetConveyor1SpeedTrim);

sheetConveyor2NormalSpeedMPM :=
    normalStackerSpeedMPM *
    MAX(0.0, machineConfig.sheetConveyor2SpeedTrim);

sheetConveyor3NormalSpeedMPM :=
    normalStackerSpeedMPM *
    MAX(0.0, machineConfig.sheetConveyor3SpeedTrim);

sheetConveyor4NormalSpeedMPM :=
    normalStackerSpeedMPM *
    MAX(0.0, machineConfig.sheetConveyor4SpeedTrim);


//==============================================================
// 6.1) Sheet conveyors speed-up reference
//==============================================================
// EN: Speed-up is added directly to conveyors 1/2/3 references.
//     It can work even when line speed is zero, as long as the
//     conveyor group is enabled.
IF speedControlEnabled AND sheetConveyorsSpeedUpCmd THEN

    sheetConveyorsSpeedUpReferenceMPM :=
        MAX(0.0, machineConfig.sheetConveyorsSpeedUpMPM);

ELSE

    sheetConveyorsSpeedUpReferenceMPM := 0.0;

END_IF;


//==============================================================
// 6.2) Base speed references including speed-up
//==============================================================
// EN: Base speed is the synchronized conveyor speed plus operator speed-up.
//     Separation tracking must use this base speed as reference.
sheetConveyor1BaseSpeedMPM :=
    sheetConveyor1NormalSpeedMPM + sheetConveyorsSpeedUpReferenceMPM;

sheetConveyor2BaseSpeedMPM :=
    sheetConveyor2NormalSpeedMPM + sheetConveyorsSpeedUpReferenceMPM;

sheetConveyor3BaseSpeedMPM :=
    sheetConveyor3NormalSpeedMPM + sheetConveyorsSpeedUpReferenceMPM;

sheetConveyor4BaseSpeedMPM :=
    sheetConveyor4NormalSpeedMPM + sheetConveyorsSpeedUpReferenceMPM;


//==============================================================
// 7) Calculate separation high speed
//==============================================================
// EN: Gap speed also receives the same speed-up reference.
//     This preserves the real gap differential while allowing operator boost.
sheetConveyor1GapSpeedMPM :=
    (sheetConveyor1NormalSpeedMPM * MAX(0.0, machineConfig.packageGapSpeedRatio)) +
    machineConfig.packageGapSpeedOffsetMPM +
    sheetConveyorsSpeedUpReferenceMPM;

sheetConveyor2GapSpeedMPM :=
    (sheetConveyor2NormalSpeedMPM * MAX(0.0, machineConfig.packageGapSpeedRatio)) +
    machineConfig.packageGapSpeedOffsetMPM +
    sheetConveyorsSpeedUpReferenceMPM;

sheetConveyor3GapSpeedMPM :=
    (sheetConveyor3NormalSpeedMPM * MAX(0.0, machineConfig.packageGapSpeedRatio)) +
    machineConfig.packageGapSpeedOffsetMPM +
    sheetConveyorsSpeedUpReferenceMPM;

sheetConveyor4GapSpeedMPM :=
    (sheetConveyor4NormalSpeedMPM * MAX(0.0, machineConfig.packageGapSpeedRatio)) +
    machineConfig.packageGapSpeedOffsetMPM +
    sheetConveyorsSpeedUpReferenceMPM;


//==============================================================
// 8) Calculate separation tracking target distances
//==============================================================
// EN: Separation tracking target is based on each conveyor length.
sheetConveyor2TargetDistanceM :=
    MAX(0.0, machineConfig.sheetConveyor2LengthM);

sheetConveyor3TargetDistanceM :=
    MAX(0.0, machineConfig.sheetConveyor3LengthM);

sheetConveyor4TargetDistanceM :=
    MAX(0.0, machineConfig.sheetConveyor4LengthM);


//==============================================================
// 9) Check separation ready conditions
//==============================================================
// EN: Compare gap speed against base speed, not normal speed.
//     Otherwise operator speed-up would be incorrectly counted as gap opening.
packageGapReady :=
    speedControlEnabled AND
    (sheetConveyor2TargetDistanceM > 0.0) AND
    (sheetConveyor3TargetDistanceM > 0.0) AND
    (sheetConveyor4TargetDistanceM > 0.0) AND
    ((sheetConveyor2GapSpeedMPM - sheetConveyor2BaseSpeedMPM) >= machineConfig.minimumOpeningSpeedMPM) AND
    ((sheetConveyor3GapSpeedMPM - sheetConveyor3BaseSpeedMPM) >= machineConfig.minimumOpeningSpeedMPM) AND
    ((sheetConveyor4GapSpeedMPM - sheetConveyor4BaseSpeedMPM) >= machineConfig.minimumOpeningSpeedMPM);

sheetStackSeparationReady := packageGapReady;


//==============================================================
// 10) Sheet stack separation state machine
//==============================================================
IF NOT speedControlEnabled THEN

    sheetStackSeparationState      := 'DISABLED';
    sheetStackSeparationStateCode  := -1;

    packageSeparationState         := 0;

    sheetStackSeparationActive     := FALSE;
    sheetStackBrakeActive          := FALSE;
    brakeValve                     := FALSE;

    sheetConveyor2SeparationActive := FALSE;
    sheetConveyor3SeparationActive := FALSE;
    sheetConveyor4SeparationActive := FALSE;

    sheetConveyor2HighSpeedActive  := FALSE;
    sheetConveyor3HighSpeedActive  := FALSE;
    sheetConveyor4HighSpeedActive  := FALSE;

    sheetConveyor2OpeningDistanceM := 0.0;
    sheetConveyor3OpeningDistanceM := 0.0;
    sheetConveyor4OpeningDistanceM := 0.0;

    sheetConveyor1TargetSpeedMPM   := 0.0;
    sheetConveyor2TargetSpeedMPM   := 0.0;
    sheetConveyor3TargetSpeedMPM   := 0.0;
    sheetConveyor4TargetSpeedMPM   := 0.0;


ELSE

    CASE packageSeparationState OF

        0: // NORMAL
            sheetStackSeparationState     := 'NORMAL';
            sheetStackSeparationStateCode := 0;

            sheetStackSeparationActive    := FALSE;
            sheetStackBrakeActive         := FALSE;
            brakeValve                    := FALSE;

            sheetConveyor2SeparationActive := FALSE;
            sheetConveyor3SeparationActive := FALSE;
            sheetConveyor4SeparationActive := FALSE;

            sheetConveyor2HighSpeedActive  := FALSE;
            sheetConveyor3HighSpeedActive  := FALSE;
            sheetConveyor4HighSpeedActive  := FALSE;

            sheetConveyor2OpeningDistanceM := 0.0;
            sheetConveyor3OpeningDistanceM := 0.0;
            sheetConveyor4OpeningDistanceM := 0.0;

            sheetConveyor1TargetSpeedMPM  := sheetConveyor1BaseSpeedMPM;
            sheetConveyor2TargetSpeedMPM  := sheetConveyor2BaseSpeedMPM;
            sheetConveyor3TargetSpeedMPM  := sheetConveyor3BaseSpeedMPM;
            sheetConveyor4TargetSpeedMPM  := sheetConveyor4BaseSpeedMPM;

            // EN: Readiness is validated before the unload request is accepted.
            // PT: A prontidão é validada antes de o pedido de descarga ser aceito.
            IF dischargeRequestAccepted THEN
                packageSeparationState := 10;
            END_IF


        10: // START_SHEET_STACK_SEPARATION
            sheetStackSeparationState     := 'START_SEPARATION';
            sheetStackSeparationStateCode := 10;

            sheetStackSeparationActive    := TRUE;
            sheetStackSeparationStarted   := TRUE;

            sheetStackBrakeActive         := NOT changeBatchCycleActive;
            brakeValve                    := NOT changeBatchCycleActive;

            // EN: Conveyor 2 tracking starts immediately.
            sheetConveyor2SeparationStarted := TRUE;

            sheetConveyor2SeparationActive  := TRUE;
            sheetConveyor3SeparationActive  := FALSE;
            sheetConveyor4SeparationActive  := FALSE;

            // EN: Conveyor 2 and 3 accelerate together from the beginning.
            sheetConveyor2HighSpeedActive   := TRUE;
            sheetConveyor3HighSpeedActive   := TRUE;
            sheetConveyor4HighSpeedActive   := TRUE;

            sheetConveyor2OpeningDistanceM  := 0.0;
            sheetConveyor3OpeningDistanceM  := 0.0;
            sheetConveyor4OpeningDistanceM  := 0.0;

            IF changeBatchCycleActive THEN
                sheetConveyor1TargetSpeedMPM := sheetConveyor1GapSpeedMPM;
            ELSE
                sheetConveyor1TargetSpeedMPM := sheetConveyor1BaseSpeedMPM;
            END_IF;
            sheetConveyor2TargetSpeedMPM    := sheetConveyor2GapSpeedMPM;
            sheetConveyor3TargetSpeedMPM    := sheetConveyor3GapSpeedMPM;
            sheetConveyor4TargetSpeedMPM    := sheetConveyor4GapSpeedMPM;

            packageSeparationState := 20;


        20: // SHEET_CONVEYOR_2_SEPARATION_TRACKING
            sheetStackSeparationState     := 'CONV2_TRACKING';
            sheetStackSeparationStateCode := 20;

            sheetStackSeparationActive    := TRUE;

            sheetStackBrakeActive         := NOT changeBatchCycleActive;
            brakeValve                    := NOT changeBatchCycleActive;

            sheetConveyor2SeparationActive := TRUE;
            sheetConveyor3SeparationActive := FALSE;
            sheetConveyor4SeparationActive := FALSE;

            sheetConveyor2HighSpeedActive  := TRUE;
            sheetConveyor3HighSpeedActive  := TRUE;
            sheetConveyor4HighSpeedActive  := TRUE;

            IF changeBatchCycleActive THEN
                sheetConveyor1TargetSpeedMPM := sheetConveyor1GapSpeedMPM;
            ELSE
                sheetConveyor1TargetSpeedMPM := sheetConveyor1BaseSpeedMPM;
            END_IF;
            sheetConveyor2TargetSpeedMPM  := sheetConveyor2GapSpeedMPM;
            sheetConveyor3TargetSpeedMPM  := sheetConveyor3GapSpeedMPM;
            sheetConveyor4TargetSpeedMPM  := sheetConveyor4GapSpeedMPM;

            IF sheetConveyor2OpeningDistanceM >= sheetConveyor2TargetDistanceM THEN

                // EN: Conveyor 2 tracking finished. Conveyor 2 returns to base speed.
                sheetConveyor2SeparationFinished := TRUE;

                sheetConveyor2SeparationActive   := FALSE;
                sheetConveyor2HighSpeedActive    := FALSE;

                sheetStackBrakeActive            := FALSE;
                brakeValve                       := FALSE;

                sheetConveyor2TargetSpeedMPM     := sheetConveyor2BaseSpeedMPM;

                // EN: Conveyor 3 tracking starts after conveyor 2 returns to sync.
                sheetConveyor3SeparationStarted := TRUE;
                sheetConveyor3OpeningDistanceM  := 0.0;

                packageSeparationState := 30;

            END_IF


        30: // SHEET_CONVEYOR_3_SEPARATION_TRACKING
            sheetStackSeparationState     := 'CONV3_TRACKING';
            sheetStackSeparationStateCode := 30;

            sheetStackSeparationActive    := TRUE;

            sheetStackBrakeActive         := FALSE;
            brakeValve                    := FALSE;

            sheetConveyor2SeparationActive := FALSE;
            sheetConveyor3SeparationActive := TRUE;
            sheetConveyor4SeparationActive := FALSE;

            sheetConveyor2HighSpeedActive  := FALSE;
            sheetConveyor3HighSpeedActive  := TRUE;
            sheetConveyor4HighSpeedActive  := TRUE;

            sheetConveyor1TargetSpeedMPM  := sheetConveyor1BaseSpeedMPM;
            sheetConveyor2TargetSpeedMPM  := sheetConveyor2BaseSpeedMPM;
            sheetConveyor3TargetSpeedMPM  := sheetConveyor3GapSpeedMPM;
            sheetConveyor4TargetSpeedMPM  := sheetConveyor4GapSpeedMPM;

            IF sheetConveyor3OpeningDistanceM >= sheetConveyor3TargetDistanceM THEN

                // EN: Conveyor 3 returns to base synchronized speed.
                sheetConveyor3TargetSpeedMPM := sheetConveyor3BaseSpeedMPM;

                // EN: Conveyor 4 tracking starts after conveyor 3 returns to sync.
                // PT: O rastreamento da esteira 4 inicia após a esteira 3 retornar ao sincronismo.
                sheetConveyor4SeparationStarted := TRUE;
                sheetConveyor4OpeningDistanceM := 0.0;

                packageSeparationState := 40;

            END_IF


        40: // SHEET_CONVEYOR_4_SEPARATION_TRACKING
            sheetStackSeparationState     := 'CONV4_TRACKING';
            sheetStackSeparationStateCode := 40;

            sheetStackSeparationActive    := TRUE;
            sheetStackBrakeActive         := FALSE;
            brakeValve                    := FALSE;

            sheetConveyor2SeparationActive := FALSE;
            sheetConveyor3SeparationActive := FALSE;
            sheetConveyor4SeparationActive := TRUE;

            sheetConveyor2HighSpeedActive := FALSE;
            sheetConveyor3HighSpeedActive := FALSE;
            sheetConveyor4HighSpeedActive := TRUE;

            sheetConveyor1TargetSpeedMPM := sheetConveyor1BaseSpeedMPM;
            sheetConveyor2TargetSpeedMPM := sheetConveyor2BaseSpeedMPM;
            sheetConveyor3TargetSpeedMPM := sheetConveyor3BaseSpeedMPM;
            sheetConveyor4TargetSpeedMPM := sheetConveyor4GapSpeedMPM;

            IF sheetConveyor4OpeningDistanceM >= sheetConveyor4TargetDistanceM THEN
                sheetConveyor4TargetSpeedMPM := sheetConveyor4BaseSpeedMPM;
                packageSeparationState := 50;
            END_IF


        50: // FINISH_SHEET_STACK_SEPARATION
            sheetStackSeparationState     := 'FINISH_SEPARATION';
            sheetStackSeparationStateCode := 50;

            sheetStackSeparationActive    := FALSE;
            sheetStackSeparationFinished  := TRUE;

            sheetStackBrakeActive         := FALSE;
            brakeValve                    := FALSE;

            sheetConveyor2SeparationActive  := FALSE;
            sheetConveyor3SeparationActive  := FALSE;
            sheetConveyor4SeparationActive  := FALSE;

            sheetConveyor2HighSpeedActive   := FALSE;
            sheetConveyor3HighSpeedActive   := FALSE;
            sheetConveyor4HighSpeedActive   := FALSE;

            sheetConveyor3SeparationFinished := TRUE;
            sheetConveyor4SeparationFinished := TRUE;

            sheetConveyor1TargetSpeedMPM  := sheetConveyor1BaseSpeedMPM;
            sheetConveyor2TargetSpeedMPM  := sheetConveyor2BaseSpeedMPM;
            sheetConveyor3TargetSpeedMPM  := sheetConveyor3BaseSpeedMPM;
            sheetConveyor4TargetSpeedMPM  := sheetConveyor4BaseSpeedMPM;

            packageSeparationState := 0;


    ELSE

        packageSeparationState := 0;

    END_CASE;

END_IF;


//==============================================================
// 11) Limit speed targets
//==============================================================
sheetConveyor1TargetSpeedMPM := LIMIT(
    machineConfig.minimumSpeedMPM,
    sheetConveyor1TargetSpeedMPM,
    machineConfig.maximumSpeedMPM
);

sheetConveyor2TargetSpeedMPM := LIMIT(
    machineConfig.minimumSpeedMPM,
    sheetConveyor2TargetSpeedMPM,
    machineConfig.maximumSpeedMPM
);

sheetConveyor3TargetSpeedMPM := LIMIT(
    machineConfig.minimumSpeedMPM,
    sheetConveyor3TargetSpeedMPM,
    machineConfig.maximumSpeedMPM
);

sheetConveyor4TargetSpeedMPM := LIMIT(
    machineConfig.minimumSpeedMPM,
    sheetConveyor4TargetSpeedMPM,
    machineConfig.maximumSpeedMPM
);


//==============================================================
// 12) Ramp sheet conveyor 1 speed reference
//==============================================================
instRampSheetConveyor1(
    X          := sheetConveyor1TargetSpeedMPM,
    A_UP       := MAX(0.0, machineConfig.rampAccelerationUpMPMps2),
    A_DN       := -MAX(0.0, machineConfig.rampAccelerationDownMPMps2),
    VU_MAX     := MAX(0.0, machineConfig.rampVelocityUpMaxMPMps),
    VD_MAX     := -MAX(0.0, machineConfig.rampVelocityDownMaxMPMps),
    LIMIT_HIGH := machineConfig.maximumSpeedMPM,
    LIMIT_LOW  := machineConfig.minimumSpeedMPM,
    RST        := rampReset,
    Y          => sheetConveyor1SpeedRefMPM
);


//==============================================================
// 13) Ramp sheet conveyor 2 speed reference
//==============================================================
instRampSheetConveyor2(
    X          := sheetConveyor2TargetSpeedMPM,
    A_UP       := MAX(0.0, machineConfig.rampAccelerationUpMPMps2),
    A_DN       := -MAX(0.0, machineConfig.rampAccelerationDownMPMps2),
    VU_MAX     := MAX(0.0, machineConfig.rampVelocityUpMaxMPMps),
    VD_MAX     := -MAX(0.0, machineConfig.rampVelocityDownMaxMPMps),
    LIMIT_HIGH := machineConfig.maximumSpeedMPM,
    LIMIT_LOW  := machineConfig.minimumSpeedMPM,
    RST        := rampReset,
    Y          => sheetConveyor2SpeedRefMPM
);


//==============================================================
// 14) Ramp sheet conveyor 3 speed reference
//==============================================================
instRampSheetConveyor3(
    X          := sheetConveyor3TargetSpeedMPM,
    A_UP       := MAX(0.0, machineConfig.rampAccelerationUpMPMps2),
    A_DN       := -MAX(0.0, machineConfig.rampAccelerationDownMPMps2),
    VU_MAX     := MAX(0.0, machineConfig.rampVelocityUpMaxMPMps),
    VD_MAX     := -MAX(0.0, machineConfig.rampVelocityDownMaxMPMps),
    LIMIT_HIGH := machineConfig.maximumSpeedMPM,
    LIMIT_LOW  := machineConfig.minimumSpeedMPM,
    RST        := rampReset,
    Y          => sheetConveyor3SpeedRefMPM
);


//==============================================================
// 15) Ramp sheet conveyor 4 speed reference
//==============================================================
instRampSheetConveyor4(
    X          := sheetConveyor4TargetSpeedMPM,
    A_UP       := MAX(0.0, machineConfig.rampAccelerationUpMPMps2),
    A_DN       := -MAX(0.0, machineConfig.rampAccelerationDownMPMps2),
    VU_MAX     := MAX(0.0, machineConfig.rampVelocityUpMaxMPMps),
    VD_MAX     := -MAX(0.0, machineConfig.rampVelocityDownMaxMPMps),
    LIMIT_HIGH := machineConfig.maximumSpeedMPM,
    LIMIT_LOW  := machineConfig.minimumSpeedMPM,
    RST        := rampReset,
    Y          => sheetConveyor4SpeedRefMPM
);


//==============================================================
// 16) Calculate real separation tracking speed using ramped references
//==============================================================
// EN: Only the real speed differential above the base speed moves the
//     separation point through the conveyors.
//     Operator speed-up is already included in base speed, so it is not
//     counted as gap opening.
sheetConveyor2OpeningSpeedMPM :=
    MAX(0.0, sheetConveyor2SpeedRefMPM - sheetConveyor2BaseSpeedMPM);

sheetConveyor3OpeningSpeedMPM :=
    MAX(0.0, sheetConveyor3SpeedRefMPM - sheetConveyor3BaseSpeedMPM);

sheetConveyor4OpeningSpeedMPM :=
    MAX(0.0, sheetConveyor4SpeedRefMPM - sheetConveyor4BaseSpeedMPM);


//==============================================================
// 17) Integrate real separation tracking distance
//==============================================================
IF speedControlEnabled THEN

    IF packageSeparationState = 20 THEN

        IF sheetConveyor2OpeningSpeedMPM >= machineConfig.minimumOpeningSpeedMPM THEN

            sheetConveyor2OpeningDistanceM :=
                sheetConveyor2OpeningDistanceM +
                (sheetConveyor2OpeningSpeedMPM / 60.0) * scanTimeS;

        END_IF

    ELSIF packageSeparationState = 30 THEN

        IF sheetConveyor3OpeningSpeedMPM >= machineConfig.minimumOpeningSpeedMPM THEN

            sheetConveyor3OpeningDistanceM :=
                sheetConveyor3OpeningDistanceM +
                (sheetConveyor3OpeningSpeedMPM / 60.0) * scanTimeS;

        END_IF

    ELSIF packageSeparationState = 40 THEN

        IF sheetConveyor4OpeningSpeedMPM >= machineConfig.minimumOpeningSpeedMPM THEN

            sheetConveyor4OpeningDistanceM :=
                sheetConveyor4OpeningDistanceM +
                (sheetConveyor4OpeningSpeedMPM / 60.0) * scanTimeS;

        END_IF

    END_IF

END_IF;


//==============================================================
// 18) Publish tracking distances to outputs
//==============================================================
sheetConveyor2TrackingDistanceM := sheetConveyor2OpeningDistanceM;
sheetConveyor3TrackingDistanceM := sheetConveyor3OpeningDistanceM;
sheetConveyor4TrackingDistanceM := sheetConveyor4OpeningDistanceM;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_ElevatorControl" Id="{02ae8aac-d808-47f5-84f8-70101e7732c2}">
      <Declaration><![CDATA[//==============================================================
// COMPLEX STACKER - ELEVATOR CONTROL
// EN: Controls homing, manual movement, automatic leveling,
//     discharge positioning and magnetic brake timing.
// PT: Controla homing, movimento manual, nivelamento automático,
//     posicionamento de descarga e temporização do freio magnético.
//
// Signed speed: positive = up; negative = down.
// Velocidade com sinal: positivo = subir; negativo = descer.
//
// State code:
// 0  = STOP
// 10 = HOME_DOWN_SEARCH
// 11 = HOME_RELEASE_SENSOR
// 12 = HOME_SETTLE
// 13 = HOME_SET_ENCODER
// 14 = HOME_WAIT_CLEAR_AND_MOVE_TO_UPPER_POSITION
// 20 = MANUAL
// 30 = AUTO_LEVELING
// 40 = DISCHARGE_POSITIONING
// 90 = FAULT
//==============================================================
METHOD _ElevatorControl
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//==============================================================
// 1) Default internal commands
//==============================================================
elevatorSignedSpeedRefMmps := 0.0;
elevatorSetEncoderPositionTrigger := FALSE;
elevatorManualLowSpeedZoneActive := FALSE;
elevatorHomeDischargeConveyorRunRequest := FALSE;


//==============================================================
// 2) Homing request and lower sensor edge detection
//==============================================================
elevatorHomeRequestCombined :=
    systemRunEnable AND
    (
        elevatorHomeCmd OR
        (
            elevatorAutoCmd AND
            elevatorAutoHomeRequest
        )
    );

// EN: The automatic pulse is accepted directly so a maintained manual home
//     command cannot hide the mandatory start-triggered request.
// PT: O pulso automático é aceito diretamente para que um comando manual de
//     home mantido não esconda o pedido obrigatório gerado pela partida.
rElevatorHome :=
    (
        elevatorHomeRequestCombined AND
        NOT elevatorHomeRequestCombinedOld
    ) OR
    (
        systemRunEnable AND
        elevatorAutoCmd AND
        elevatorAutoHomeRequest
    );

elevatorHomeRequestCombinedOld := elevatorHomeRequestCombined;

elevatorHomeLimitReached := elevatorLowerLimit;

elevatorHomeLimitFallingEdge :=
    elevatorHomeLimitOld AND
    NOT elevatorHomeLimitReached;

elevatorHomeLimitOld := elevatorHomeLimitReached;


//==============================================================
// 2.1) Manual command rearm
//==============================================================
// EN: Manual commands held during homing or active discharge positioning
//     must be released before a new manual movement can start.
//     Waiting for stack separation keeps leveling and manual control active.
// PT: Comandos manuais mantidos durante homing ou posicionamento ativo de
//     descarte devem ser liberados antes que um novo movimento manual inicie.
//     A espera pela separação mantém o nivelamento e o controle manual ativos.
IF NOT systemRunEnable OR
   NOT safetyCircuitOk OR
   NOT elevatorDriveOk OR
   elevatorFault OR
   (
        (elevatorControlState >= 10) AND
        (elevatorControlState <= 14)
   ) OR
   (elevatorControlState = 40) OR
   (elevatorControlState = 90) OR
   elevatorTargetOverrideActive OR
   sheetStackDischargeActive THEN

    elevatorManualCommandArmed := FALSE;

ELSIF NOT elevatorUpCmd AND
      NOT elevatorDownCmd THEN

    elevatorManualCommandArmed := TRUE;

END_IF;

elevatorManualCommandRequest :=
    elevatorManualCommandArmed AND
    (elevatorUpCmd OR elevatorDownCmd);


//==============================================================
// 3) Movement permissions
//==============================================================
elevatorUpAllowed :=
    systemRunEnable AND
    safetyCircuitOk AND
    elevatorDriveOk AND
    NOT elevatorUpperLimit AND
    NOT elevatorUpperSafetyLimit AND
    NOT backstopMaterialInterlockSensor AND
    (
        (NOT elevatorHomed) OR
        (elevatorPositionMm < machineConfig.elevatorMaxPositionMm)
    );

elevatorDownAllowed :=
    systemRunEnable AND
    safetyCircuitOk AND
    elevatorDriveOk AND
    NOT elevatorLowerLimit AND
    NOT elevatorLowerSafetyLimit AND
    (
        (NOT elevatorHomed) OR
        (elevatorPositionMm > machineConfig.elevatorMinPositionMm)
    );

// EN: Homing search ignores the normal lower limit until it is detected.
// PT: A busca de home ignora o limite inferior normal até detectá-lo.
elevatorHomeDownAllowed :=
    systemRunEnable AND
    safetyCircuitOk AND
    elevatorDriveOk AND
    NOT elevatorLowerSafetyLimit;

// EN: Upward release respects the backstop material interlock.
// PT: A liberação para cima respeita o intertravamento de material do backstop.
elevatorHomeReleaseAllowed :=
    systemRunEnable AND
    safetyCircuitOk AND
    elevatorDriveOk AND
    NOT elevatorUpperLimit AND
    NOT elevatorUpperSafetyLimit AND
    NOT backstopMaterialInterlockSensor;

//==============================================================
// 4) Target and position feedback
//==============================================================
IF elevatorControlState = 14 THEN

    elevatorTargetPositionMm := machineConfig.elevatorMaxPositionMm;

ELSIF elevatorTargetOverrideActive THEN

    elevatorTargetPositionMm :=
        LIMIT(
            machineConfig.elevatorMinPositionMm,
            elevatorTargetOverridePositionMm,
            machineConfig.elevatorMaxPositionMm
        );

ELSE

    elevatorTargetPositionMm :=
        LIMIT(
            machineConfig.elevatorMinPositionMm,
            elevatorPositionMm,
            machineConfig.elevatorMaxPositionMm
        );

END_IF;

elevatorPositionErrorMm :=
    elevatorTargetPositionMm - elevatorPositionMm;

elevatorAbsPositionErrorMm := ABS(elevatorPositionErrorMm);

// EN: Proportional position control with independent directional limits.
//     No minimum speed is forced; the servo may receive zero near the target.
// PT: Controle proporcional de posição com limites independentes por sentido.
//     Não força velocidade mínima; o servo pode receber zero próximo ao alvo.
elevatorRawSpeedRefMmps :=
    elevatorPositionErrorMm * MAX(0.0, machineConfig.elevatorPositionKp);

elevatorRawSpeedRefMmps :=
    LIMIT(
        -ABS(machineConfig.elevatorAutomaticDownSpeedMmps),
        elevatorRawSpeedRefMmps,
        ABS(machineConfig.elevatorAutomaticUpSpeedMmps)
    );

// EN: Endpoint flags depend on actual feedback and remain valid
//     independently of the active automatic target.
// PT: As flags de extremidade dependem do feedback real e permanecem
//     válidas independentemente do alvo automático ativo.
elevatorAtMinPosition :=
    elevatorHomed AND
    (
        elevatorLowerLimit OR
        (
            elevatorPositionMm <=
            (
                machineConfig.elevatorMinPositionMm +
                MAX(0.0, machineConfig.elevatorPositionToleranceMm)
            )
        )
    );

elevatorAtMaxPosition :=
    elevatorHomed AND
    (
        elevatorUpperLimit OR
        (
            elevatorPositionMm >=
            (
                machineConfig.elevatorMaxPositionMm -
                MAX(0.0, machineConfig.elevatorPositionToleranceMm)
            )
        )
    );

elevatorInPosition :=
    elevatorHomed AND
    (
        (elevatorAbsPositionErrorMm <= machineConfig.elevatorPositionToleranceMm)
        OR
        (
            elevatorUpperLimit AND
            (elevatorTargetPositionMm >= machineConfig.elevatorMaxPositionMm)
        )
        OR
        (
            elevatorLowerLimit AND
            (elevatorTargetPositionMm <= machineConfig.elevatorMinPositionMm)
        )
    );


//==============================================================
// 5) Fault reset
//==============================================================
IF resetCmd AND
   safetyCircuitOk AND
   elevatorDriveOk AND
   NOT elevatorUpperSafetyLimit AND
   NOT elevatorLowerSafetyLimit THEN

    elevatorFault := FALSE;
    elevatorFaultCode := 0;

    IF elevatorControlState = 90 THEN
        elevatorControlState := 0;
    END_IF

END_IF;


//==============================================================
// 6) Invalidate an interrupted homing sequence
//==============================================================
// EN: If homing or its final upward movement is interrupted by a
//     protection/system stop, a new homing cycle is required.
// PT: Se o homing ou sua subida final for interrompido por proteção/parada,
//     um novo ciclo de homing será obrigatório.
IF (elevatorControlState >= 10) AND
   (elevatorControlState <= 14) AND
   (
       NOT systemRunEnable OR
       NOT safetyCircuitOk OR
       NOT elevatorDriveOk OR
       elevatorUpperSafetyLimit OR
       elevatorLowerSafetyLimit
   ) THEN

    elevatorHomed := FALSE;
    elevatorReadyForAutomaticCycle := FALSE;

END_IF;


//==============================================================
// 7) General protection
//==============================================================
IF NOT safetyCircuitOk THEN

    elevatorState := 'SAFETY_OFF';
    elevatorFault := TRUE;
    elevatorFaultCode := 2;
    elevatorControlState := 90;

    tonElevatorHomingTimeout(IN := FALSE);
    tonElevatorHomeSettleDelay(IN := FALSE);
    tonElevatorLevelingSpeed2Delay(IN := FALSE);


ELSIF NOT elevatorDriveOk THEN

    elevatorState := 'DRIVE_NOT_OK';
    elevatorFault := TRUE;
    elevatorFaultCode := 1;
    elevatorControlState := 90;

    tonElevatorHomingTimeout(IN := FALSE);
    tonElevatorHomeSettleDelay(IN := FALSE);
    tonElevatorLevelingSpeed2Delay(IN := FALSE);


ELSIF elevatorUpperSafetyLimit THEN

    elevatorState := 'UPPER_SAFE_LIMIT';
    elevatorFault := TRUE;
    elevatorFaultCode := 4;
    elevatorControlState := 90;

    tonElevatorHomingTimeout(IN := FALSE);
    tonElevatorHomeSettleDelay(IN := FALSE);
    tonElevatorLevelingSpeed2Delay(IN := FALSE);


ELSIF elevatorLowerSafetyLimit THEN

    elevatorState := 'LOWER_SAFE_LIMIT';
    elevatorFault := TRUE;
    elevatorFaultCode := 5;
    elevatorControlState := 90;

    tonElevatorHomingTimeout(IN := FALSE);
    tonElevatorHomeSettleDelay(IN := FALSE);
    tonElevatorLevelingSpeed2Delay(IN := FALSE);


ELSIF NOT systemRunEnable THEN

    elevatorState := 'SYSTEM_DISABLED';
    elevatorSignedSpeedRefMmps := 0.0;

    tonElevatorHomingTimeout(IN := FALSE);
    tonElevatorHomeSettleDelay(IN := FALSE);
    tonElevatorLevelingSpeed2Delay(IN := FALSE);

    IF elevatorControlState <> 90 THEN
        elevatorControlState := 0;
    END_IF


ELSE

    //==========================================================
    // 8) Mode selection
    //==========================================================
    // EN: A new home command is ignored while discharge is active/pending.
    // PT: Novo comando de home é ignorado durante descarte ativo/pendente.
    IF rElevatorHome AND
       NOT elevatorFault AND
       NOT sheetStackDischargeActive AND
       NOT sheetStackDischargePending THEN

        elevatorControlState := 10;

        // EN: Consume the pending request only after homing is accepted.
        // PT: Consome o pedido pendente somente após o homing ser aceito.
        elevatorAutoHomePending := FALSE;

    END_IF;

    // EN: Discharge override blocks manual and leveling commands.
    // PT: Override de descarte bloqueia comandos manuais e nivelamento.
    IF elevatorTargetOverrideActive AND
       elevatorHomed AND
       (elevatorControlState <> 10) AND
       (elevatorControlState <> 11) AND
       (elevatorControlState <> 12) AND
       (elevatorControlState <> 13) AND
       (elevatorControlState <> 14) AND
       (elevatorControlState <> 90) THEN

        elevatorControlState := 40;

    END_IF;


    //==========================================================
    // 9) Elevator state machine
    //==========================================================
    CASE elevatorControlState OF

        0: // STOP
            elevatorState := 'STOP';

            tonElevatorHomingTimeout(IN := FALSE);
            tonElevatorHomeSettleDelay(IN := FALSE);
            tonElevatorLevelingSpeed2Delay(IN := FALSE);

            // EN: Manual movement is available with automatic mode off.
            //     With automatic mode on, it is available only after homing
            //     and completion of the upper home positioning.
            // PT: O movimento manual fica disponível com o automático desligado.
            //     Com o automático ligado, fica disponível somente após o homing
            //     e a conclusão do posicionamento superior.
            IF elevatorManualCommandRequest AND
               (
                   NOT elevatorAutoCmd OR
                   (
                       elevatorHomed AND
                       elevatorReadyForAutomaticCycle
                   )
               ) THEN

                elevatorControlState := 20;

            ELSIF elevatorAutoCmd AND
                  elevatorHomed AND
                  elevatorReadyForAutomaticCycle THEN

                elevatorControlState := 30;

            END_IF


        10: // HOME_DOWN_SEARCH
            elevatorState := 'HOME_DOWN';
            elevatorHomed := FALSE;
            elevatorReadyForAutomaticCycle := FALSE;
            elevatorInPosition := FALSE;
            elevatorHomeDischargeComplete := FALSE;

            tonElevatorHomingTimeout(
                IN := TRUE,
                PT := machineConfig.elevatorHomingTimeout
            );

            IF tonElevatorHomingTimeout.Q THEN

                elevatorSignedSpeedRefMmps := 0.0;
                tonElevatorHomingTimeout(IN := FALSE);

                elevatorFault := TRUE;
                elevatorFaultCode := 3;
                elevatorState := 'HOME_TIMEOUT';
                elevatorControlState := 90;

            ELSIF elevatorHomeLimitReached THEN

                elevatorSignedSpeedRefMmps := 0.0;
                tonElevatorHomingTimeout(IN := FALSE);

                // EN: Start clearing the platform as soon as the lower home
                //     limit is reached. Homing continues through encoder reset.
                // PT: Inicia a limpeza da plataforma assim que o limite inferior
                //     do home é atingido. O homing continua até zerar o encoder.
                elevatorHomeDischargeConveyorRunRequest := TRUE;
                elevatorControlState := 11;

            ELSIF elevatorHomeDownAllowed THEN

                elevatorSignedSpeedRefMmps :=
                    -ABS(machineConfig.elevatorHomingSpeedMmps);

            END_IF


        11: // HOME_RELEASE_SENSOR
            elevatorState := 'HOME_RELEASE';
            elevatorHomeDischargeConveyorRunRequest := TRUE;

            tonElevatorHomingTimeout(
                IN := TRUE,
                PT := machineConfig.elevatorHomingTimeout
            );

            IF tonElevatorHomingTimeout.Q THEN

                elevatorSignedSpeedRefMmps := 0.0;
                tonElevatorHomingTimeout(IN := FALSE);

                elevatorFault := TRUE;
                elevatorFaultCode := 3;
                elevatorState := 'HOME_TIMEOUT';
                elevatorControlState := 90;

            ELSIF elevatorHomeLimitFallingEdge THEN

                elevatorSignedSpeedRefMmps := 0.0;
                tonElevatorHomingTimeout(IN := FALSE);
                tonElevatorHomeSettleDelay(IN := FALSE);
                elevatorControlState := 12;

            ELSIF elevatorHomeReleaseAllowed THEN

                elevatorSignedSpeedRefMmps :=
                    ABS(machineConfig.elevatorHomingReleaseSpeedMmps);

            END_IF


        12: // HOME_SETTLE
            elevatorState := 'HOME_SETTLE';
            elevatorSignedSpeedRefMmps := 0.0;
            elevatorHomeDischargeConveyorRunRequest := TRUE;

            // EN: Encoder reset is allowed only while the lower sensor
            //     remains released throughout the settle time.
            // PT: Reset do encoder é permitido somente se o sensor inferior
            //     permanecer livre durante todo o tempo de estabilização.
            IF elevatorHomeLimitReached THEN

                tonElevatorHomeSettleDelay(IN := FALSE);
                elevatorControlState := 11;

            ELSE

                tonElevatorHomeSettleDelay(
                    IN := TRUE,
                    PT := machineConfig.elevatorHomeSettleDelay
                );

                IF tonElevatorHomeSettleDelay.Q THEN
                    tonElevatorHomeSettleDelay(IN := FALSE);
                    elevatorControlState := 13;
                END_IF

            END_IF


        13: // HOME_SET_ENCODER
            elevatorState := 'HOME_SET_ENCODER';
            elevatorSignedSpeedRefMmps := 0.0;
            elevatorHomeDischargeConveyorRunRequest := TRUE;

            elevatorSetEncoderPositionTrigger := TRUE;
            elevatorSetEncoderPositionMm := machineConfig.elevatorHomePositionMm;

            elevatorHomed := TRUE;
            elevatorFault := FALSE;
            elevatorFaultCode := 0;

            tonElevatorHomingTimeout(IN := FALSE);
            elevatorControlState := 14;


        14: // HOME_MOVE_TO_UPPER_POSITION
            tonElevatorHomingTimeout(
                IN := TRUE,
                PT := machineConfig.elevatorHomingTimeout
            );

            // EN: Keep the conveyor running after the encoder is set. The final
            //     upward movement is released only after the actual run time and
            //     both platform-clear conditions are confirmed.
            // PT: Mantém a esteira ligada após zerar o encoder. A subida final é
            //     liberada somente após confirmar o tempo real de giro e as duas
            //     condições de plataforma livre.
            IF NOT elevatorHomeDischargeComplete THEN

                elevatorState := 'HOME_WAIT_CLEAR';
                elevatorHomeDischargeConveyorRunRequest := TRUE;

                IF tonElevatorHomeDischargeMinimumRun.Q AND
                   elevatorStackExitClearSensor AND
						elevatorStackPresentSensor THEN

                    elevatorHomeDischargeComplete := TRUE;
                    elevatorHomeDischargeConveyorRunRequest := FALSE;
                    elevatorState := 'HOME_MOVE_UP';

                END_IF

            ELSE

                elevatorState := 'HOME_MOVE_UP';

            END_IF;


            IF elevatorInPosition AND
               elevatorHomeDischargeComplete THEN

                elevatorSignedSpeedRefMmps := 0.0;
                tonElevatorHomingTimeout(IN := FALSE);
                elevatorReadyForAutomaticCycle := TRUE;

                IF elevatorAutoCmd THEN
                    elevatorControlState := 30;
                ELSE
                    elevatorControlState := 0;
                END_IF

            ELSIF tonElevatorHomingTimeout.Q THEN

                elevatorSignedSpeedRefMmps := 0.0;
                tonElevatorHomingTimeout(IN := FALSE);

                elevatorHomed := FALSE;
                elevatorReadyForAutomaticCycle := FALSE;
                elevatorFault := TRUE;
                elevatorFaultCode := 3;
                elevatorState := 'HOME_UP_TIMEOUT';
                elevatorControlState := 90;

            ELSIF elevatorHomeDischargeComplete AND
                  (elevatorRawSpeedRefMmps > 0.0) AND
                  elevatorUpAllowed THEN

                elevatorSignedSpeedRefMmps :=
                    elevatorRawSpeedRefMmps;

            ELSIF elevatorHomeDischargeComplete AND
                  (elevatorRawSpeedRefMmps < 0.0) AND
                  elevatorDownAllowed THEN

                elevatorSignedSpeedRefMmps :=
                    elevatorRawSpeedRefMmps;

            END_IF


        20: // MANUAL
            elevatorState := 'MANUAL';

            tonElevatorHomingTimeout(IN := FALSE);
            tonElevatorHomeSettleDelay(IN := FALSE);
            tonElevatorLevelingSpeed2Delay(IN := FALSE);

            // EN: Waiting for stack separation does not cancel manual operation.
            //     Active positioning or an elevator override cancels it.
            // PT: A espera pela separação da pilha não cancela a operação manual.
            //     O posicionamento ativo ou um override do elevador a cancela.
            IF sheetStackDischargeActive OR
               elevatorTargetOverrideActive THEN

                elevatorSignedSpeedRefMmps := 0.0;

                IF elevatorAutoCmd AND
                   elevatorHomed AND
                   elevatorReadyForAutomaticCycle THEN

                    elevatorControlState := 30;

                ELSE

                    elevatorControlState := 0;

                END_IF


            ELSIF elevatorAutoCmd AND
                  (
                      NOT elevatorHomed OR
                      NOT elevatorReadyForAutomaticCycle
                  ) THEN

                elevatorSignedSpeedRefMmps := 0.0;
                elevatorState := 'AUTO_NO_HOME';
                elevatorControlState := 0;

            ELSIF elevatorUpCmd AND elevatorDownCmd THEN

                elevatorSignedSpeedRefMmps := 0.0;

            ELSIF elevatorUpCmd THEN

                IF elevatorUpAllowed THEN

                    // EN: Reduce manual upward speed only while approaching
                    //     the configured maximum position.
                    // PT: Reduz a velocidade manual de subida somente durante
                    //     a aproximação da posição máxima configurada.
                    elevatorManualLowSpeedZoneActive :=
                        elevatorHomed AND
                        (
                            LIMIT(
                                0.0,
                                machineConfig.elevatorManualLowSpeedFactor,
                                1.0
                            ) < 1.0
                        ) AND
                        (
                            elevatorPositionMm >=
                            (
                                machineConfig.elevatorMaxPositionMm -
                                MAX(
                                    0.0,
                                    machineConfig.elevatorManualLowSpeedZoneMm
                                )
                            )
                        );

                    IF elevatorManualLowSpeedZoneActive THEN

                        elevatorSignedSpeedRefMmps :=
                            ABS(machineConfig.elevatorManualSpeedMmps) *
                            LIMIT(
                                0.0,
                                machineConfig.elevatorManualLowSpeedFactor,
                                1.0
                            );

                    ELSE

                        elevatorSignedSpeedRefMmps :=
                            ABS(machineConfig.elevatorManualSpeedMmps);

                    END_IF

                ELSE
                    elevatorSignedSpeedRefMmps := 0.0;
                END_IF

            ELSIF elevatorDownCmd THEN

                IF elevatorDownAllowed THEN

                    // EN: Reduce manual downward speed only while approaching
                    //     the configured minimum position.
                    // PT: Reduz a velocidade manual de descida somente durante
                    //     a aproximação da posição mínima configurada.
                    elevatorManualLowSpeedZoneActive :=
                        elevatorHomed AND
                        (
                            LIMIT(
                                0.0,
                                machineConfig.elevatorManualLowSpeedFactor,
                                1.0
                            ) < 1.0
                        ) AND
                        (
                            elevatorPositionMm <=
                            (
                                machineConfig.elevatorMinPositionMm +
                                MAX(
                                    0.0,
                                    machineConfig.elevatorManualLowSpeedZoneMm
                                )
                            )
                        );

                    IF elevatorManualLowSpeedZoneActive THEN

                        elevatorSignedSpeedRefMmps :=
                            -ABS(machineConfig.elevatorManualSpeedMmps) *
                            LIMIT(
                                0.0,
                                machineConfig.elevatorManualLowSpeedFactor,
                                1.0
                            );

                    ELSE

                        elevatorSignedSpeedRefMmps :=
                            -ABS(machineConfig.elevatorManualSpeedMmps);

                    END_IF

                ELSE
                    elevatorSignedSpeedRefMmps := 0.0;
                END_IF

            ELSE

                elevatorSignedSpeedRefMmps := 0.0;

                // EN: When manual intervention ends, automatic leveling
                //     may immediately evaluate the current level sensor.
                // PT: Ao terminar a intervenção manual, o nivelamento
                //     automático pode avaliar imediatamente o sensor atual.
                IF elevatorAutoCmd AND
                   elevatorHomed AND
                   elevatorReadyForAutomaticCycle THEN

                    elevatorControlState := 30;

                ELSE

                    elevatorControlState := 0;

                END_IF

            END_IF


        30: // AUTO_LEVELING
            elevatorState := 'AUTO_LEVELING';

            tonElevatorHomingTimeout(IN := FALSE);
            tonElevatorHomeSettleDelay(IN := FALSE);

            IF NOT elevatorAutoCmd THEN

                elevatorSignedSpeedRefMmps := 0.0;
                tonElevatorLevelingSpeed2Delay(IN := FALSE);
                elevatorControlState := 0;

            ELSIF NOT elevatorHomed OR
                  NOT elevatorReadyForAutomaticCycle THEN

                elevatorSignedSpeedRefMmps := 0.0;
                tonElevatorLevelingSpeed2Delay(IN := FALSE);
                elevatorState := 'AUTO_NO_HOME';

            ELSIF (elevatorUpCmd OR elevatorDownCmd) AND
                  NOT elevatorManualCommandArmed THEN

                // EN: A command held from homing or discharge inhibits
                //     leveling but cannot start a manual movement.
                // PT: Um comando mantido desde o homing ou descarte bloqueia
                //     o nivelamento, mas não pode iniciar movimento manual.
                elevatorSignedSpeedRefMmps := 0.0;
                tonElevatorLevelingSpeed2Delay(IN := FALSE);

            // EN: Manual correction remains available while the discharge
            //     sequence is waiting for stack separation.
            // PT: A correção manual permanece disponível enquanto a sequência
            //     de descarte aguarda a separação da pilha.
            ELSIF elevatorManualCommandRequest AND
                  NOT sheetStackDischargeActive AND
                  NOT elevatorTargetOverrideActive THEN

                // EN: Manual commands have priority over the level sensor.
                //     The speed-2 delay restarts after manual intervention.
                // PT: Os comandos manuais têm prioridade sobre o sensor de nível.
                //     O atraso da velocidade 2 reinicia após a intervenção manual.
                elevatorSignedSpeedRefMmps := 0.0;
                tonElevatorLevelingSpeed2Delay(IN := FALSE);
                elevatorControlState := 20;

            ELSIF backstopStackLevelSensor AND
                  elevatorDownAllowed THEN

                tonElevatorLevelingSpeed2Delay(
                    IN := TRUE,
                    PT := machineConfig.elevatorLevelingSpeed2Delay
                );

                IF tonElevatorLevelingSpeed2Delay.Q THEN
                    elevatorSignedSpeedRefMmps :=
                        -ABS(machineConfig.elevatorLevelingSpeed2Mmps);
                ELSE
                    elevatorSignedSpeedRefMmps :=
                        -ABS(machineConfig.elevatorLevelingSpeed1Mmps);
                END_IF

            ELSE

                elevatorSignedSpeedRefMmps := 0.0;
                tonElevatorLevelingSpeed2Delay(IN := FALSE);

            END_IF


        40: // DISCHARGE_POSITIONING
            elevatorState := 'DISCHARGE_POSITION';

            tonElevatorLevelingSpeed2Delay(IN := FALSE);

            IF NOT elevatorTargetOverrideActive THEN

                elevatorSignedSpeedRefMmps := 0.0;

                IF elevatorAutoCmd AND
                   elevatorHomed AND
                   elevatorReadyForAutomaticCycle THEN

                    elevatorControlState := 30;

                ELSE

                    elevatorControlState := 0;

                END_IF

            ELSIF elevatorInPosition THEN

                elevatorSignedSpeedRefMmps := 0.0;

            ELSIF (elevatorRawSpeedRefMmps > 0.0) AND elevatorUpAllowed THEN

                elevatorSignedSpeedRefMmps :=
                    elevatorRawSpeedRefMmps;

            ELSIF (elevatorRawSpeedRefMmps < 0.0) AND elevatorDownAllowed THEN

                elevatorSignedSpeedRefMmps :=
                    elevatorRawSpeedRefMmps;

            END_IF


        90: // FAULT
            elevatorState := 'FAULT';
            elevatorSignedSpeedRefMmps := 0.0;

            tonElevatorHomingTimeout(IN := FALSE);
            tonElevatorHomeSettleDelay(IN := FALSE);
            tonElevatorLevelingSpeed2Delay(IN := FALSE);


        ELSE
            elevatorControlState := 0;

    END_CASE;

END_IF;


// EN: Any transition outside the homing states cancels its conveyor request
//     in the same scan, including stop, fault and completed homing.
// PT: Qualquer transição para fora dos estados de homing cancela o pedido da
//     esteira no mesmo scan, incluindo parada, falha e homing concluído.
IF (elevatorControlState < 10) OR
   (elevatorControlState > 14) THEN

    elevatorHomeDischargeConveyorRunRequest := FALSE;
    elevatorHomeDischargeComplete := FALSE;

END_IF;


//==============================================================
// 10) Elevator home discharge conveyor minimum run time
//==============================================================
// EN: Count only while the homing request is active and the conveyor run output
//     was commanded TRUE. Reading the previous scan adds a conservative delay.
// PT: Conta somente enquanto o pedido do homing estiver ativo e a saída de giro
//     da esteira tiver sido comandada. A leitura do scan anterior adiciona atraso.
tonElevatorHomeDischargeMinimumRun(
    IN :=
        elevatorHomeDischargeConveyorRunRequest AND
        sheetStackDischargeConveyorRun,
    PT := machineConfig.sheetStackDischargeTime
);


//==============================================================
// 11) Encoder set pulse
//==============================================================
tpElevatorSetEncoderPosition(
    IN := elevatorSetEncoderPositionTrigger,
    PT := machineConfig.elevatorSetEncoderPulseTime
);

elevatorSetEncoderPosition := tpElevatorSetEncoderPosition.Q;


//==============================================================
// 12) Servo enable and magnetic brake control
//==============================================================
// EN: Zero the movement request immediately, command quick stop and keep the
//     servo enabled only for the configured shutdown delay.
//     Drive-ready feedback is not used to avoid a circular enable dependency.
// PT: Zera a solicitação de movimento imediatamente, comanda o quick stop e
//     mantém o servo habilitado apenas durante o atraso configurado de desligamento.
//     O retorno de drive pronto não é usado para evitar dependência circular.
elevatorDriveEnableRequest :=
    systemRunEnable AND
    safetyCircuitOk;

tofElevatorDriveDisableDelay(
    IN := elevatorDriveEnableRequest,
    PT := machineConfig.elevatorDriveDisableDelay
);

elevatorDriveEnable :=
    tofElevatorDriveDisableDelay.Q;

elevatorQuickStop :=
    NOT elevatorDriveEnableRequest AND
    tofElevatorDriveDisableDelay.Q;

elevatorMoveRequest :=
    systemRunEnable AND
    safetyCircuitOk AND
    elevatorDriveOk AND
    NOT elevatorFault AND
    (ABS(elevatorSignedSpeedRefMmps) > 0.0);

IF elevatorMoveRequest THEN

    elevatorBrakeReleaseRequest := TRUE;
    tonElevatorBrakeHoldDelay(IN := FALSE);

ELSE

    IF elevatorBrakeRelease THEN

        tonElevatorBrakeHoldDelay(
            IN := TRUE,
            PT := machineConfig.elevatorBrakeHoldTime
        );

        elevatorBrakeReleaseRequest :=
            NOT tonElevatorBrakeHoldDelay.Q;

    ELSE

        tonElevatorBrakeHoldDelay(IN := FALSE);
        elevatorBrakeReleaseRequest := FALSE;

    END_IF

END_IF;

elevatorBrakeRelease :=
    systemRunEnable AND
    safetyCircuitOk AND
    elevatorDriveOk AND
    NOT elevatorFault AND
    elevatorBrakeReleaseRequest;

tonElevatorBrakeReleaseDelay(
    IN := elevatorMoveRequest AND elevatorBrakeRelease,
    PT := machineConfig.elevatorBrakeReleaseDelay
);


//==============================================================
// 12) Direction and speed outputs
//==============================================================
IF elevatorMoveRequest AND
   elevatorBrakeRelease AND
   tonElevatorBrakeReleaseDelay.Q THEN

    elevatorSpeedRefMmps := elevatorSignedSpeedRefMmps;
    elevatorRunUp := elevatorSignedSpeedRefMmps > 0.0;
    elevatorRunDown := elevatorSignedSpeedRefMmps < 0.0;

ELSE

    elevatorSpeedRefMmps := 0.0;
    elevatorRunUp := FALSE;
    elevatorRunDown := FALSE;

END_IF;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_ExternalCommands" Id="{2305ba90-1f64-48e0-803d-b7af95d3af82}">
      <Declaration><![CDATA[METHOD _ExternalCommands : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
    <Method Name="_HmiStatus" Id="{9f9c3433-b925-4b5b-a55b-93a1136a64ce}">
      <Declaration><![CDATA[//==============================================================
// COMPLEX STACKER — HMI STATUS
// EN: Maps internal status, outputs, positions and diagnostics
//     to the HMI status structure.
//==============================================================
METHOD _HmiStatus

]]></Declaration>
      <Implementation>
        <ST><![CDATA[


//==============================================================
// 1) System general status
//==============================================================
hmiStatus.systemRunEnable :=
    systemRunEnable;

hmiStatus.safetyCircuitOk :=
    safetyCircuitOk;

hmiStatus.faultActive :=
    faultActive OR
    (
        backstopRequiredForAutomaticOperation AND
        backstopFault
    ) OR
    elevatorFault OR
    sheetStackDischargeFault OR
    sheetStackDischargeConveyorFault;

hmiStatus.deviceState :=
    deviceState;


//==============================================================
// 2) Sheet conveyor group status
//==============================================================
hmiStatus.synchronizedConveyorsRunning :=
    synchronizedConveyorsRunning;

hmiStatus.sheetConveyor1Run :=
    sheetConveyor1Run;

hmiStatus.sheetConveyor2Run :=
    sheetConveyor2Run;

hmiStatus.sheetConveyor3Run :=
    sheetConveyor3Run;

hmiStatus.sheetConveyor4Run :=
    sheetConveyor4Run;

hmiStatus.sheetConveyor1SpeedRefMPM :=
    sheetConveyor1SpeedRefMPM;

hmiStatus.sheetConveyor2SpeedRefMPM :=
    sheetConveyor2SpeedRefMPM;

hmiStatus.sheetConveyor3SpeedRefMPM :=
    sheetConveyor3SpeedRefMPM;

hmiStatus.sheetConveyor4SpeedRefMPM :=
    sheetConveyor4SpeedRefMPM;

hmiStatus.syncConveyorsState :=
    syncConveyorsState;


//==============================================================
// 3) Sheet stack separation status
//==============================================================
hmiStatus.sheetStackSeparationReady :=
    sheetStackSeparationReady;

hmiStatus.sheetStackSeparationActive :=
    sheetStackSeparationActive;

hmiStatus.sheetStackBrakeActive :=
    sheetStackBrakeActive;


//==============================================================
// 4) Sheet stack discharge sequence status
//==============================================================
hmiStatus.sheetStackDischargeState :=
    sheetStackDischargeState;

hmiStatus.sheetStackDischargeStateCode :=
    sheetStackDischargeStateCode;

hmiStatus.sheetStackDischargePending :=
    sheetStackDischargePending;

hmiStatus.sheetStackDischargeActive :=
    sheetStackDischargeActive;

hmiStatus.sheetStackDischargeStarted :=
    sheetStackDischargeStarted;

hmiStatus.sheetStackDischargeFinished :=
    sheetStackDischargeFinished;

hmiStatus.sheetStackDischargeFault :=
    sheetStackDischargeFault;

hmiStatus.sheetStackDischargeFaultCode :=
    sheetStackDischargeFaultCode;

hmiStatus.sheetStackDischargeLastCycleOk :=
    sheetStackDischargeLastCycleOk;

hmiStatus.sheetStackDischargeLastResultCode :=
    sheetStackDischargeLastResultCode;

hmiStatus.sheetStackDischargeLastFaultStepCode :=
    sheetStackDischargeLastFaultStepCode;

hmiStatus.sheetStackDischargeLastFaultCode :=
    sheetStackDischargeLastFaultCode;


//==============================================================
// 5) Sheet stack discharge conveyor status
//==============================================================
hmiStatus.sheetStackDischargeConveyorState :=
    sheetStackDischargeConveyorState;

hmiStatus.sheetStackDischargeConveyorRun :=
    sheetStackDischargeConveyorRun;

hmiStatus.sheetStackDischargeConveyorSpeedRefMPM :=
    sheetStackDischargeConveyorSpeedRefMPM;

hmiStatus.sheetStackDischargeConveyorFault :=
    sheetStackDischargeConveyorFault;

hmiStatus.sheetStackDischargeConveyorFaultCode :=
    sheetStackDischargeConveyorFaultCode;


//==============================================================
// 6) Backstop status
//==============================================================
hmiStatus.backstopState :=
    backstopState;

hmiStatus.backstopHomed :=
    backstopHomed;

hmiStatus.backstopHomeRunning :=
    backstopHomeRunning;

hmiStatus.backstopInPosition :=
    backstopInPosition;

hmiStatus.backstopPositionMm :=
    backstopPositionMm;

hmiStatus.backstopTargetPositionMm :=
    backstopTargetPositionMm;

hmiStatus.backstopPositionErrorMm :=
    backstopPositionErrorMm;

hmiStatus.backstopRunFw :=
    backstopRunFw;

hmiStatus.backstopRunRev :=
    backstopRunRev;

hmiStatus.backstopSpeedRefMmps :=
    backstopSpeedRefMmps;

hmiStatus.backstopPlateUpSolenoid :=
    backstopPlateUpSolenoid;

hmiStatus.backstopSetEncoderPosition :=
    backstopSetEncoderPosition;

hmiStatus.backstopSetEncoderPositionMm :=
    backstopSetEncoderPositionMm;

hmiStatus.backstopManualInterventionActive :=
    backstopManualInterventionActive;

hmiStatus.backstopManualInterventionPositionMm :=
    backstopManualInterventionPositionMm;

hmiStatus.backstopFault :=
    backstopFault;

hmiStatus.backstopFaultCode :=
    backstopFaultCode;


//==============================================================
// 7) Elevator status
//==============================================================
hmiStatus.elevatorState :=
    elevatorState;

hmiStatus.elevatorHomed :=
    elevatorHomed;

hmiStatus.elevatorInPosition :=
    elevatorInPosition;

hmiStatus.elevatorPositionMm :=
    elevatorPositionMm;

hmiStatus.elevatorTargetPositionMm :=
    elevatorTargetPositionMm;

hmiStatus.elevatorPositionErrorMm :=
    elevatorPositionErrorMm;

hmiStatus.elevatorRunUp :=
    elevatorRunUp;

hmiStatus.elevatorRunDown :=
    elevatorRunDown;

hmiStatus.elevatorBrakeRelease :=
    elevatorBrakeRelease;

hmiStatus.elevatorDriveEnable :=
    elevatorDriveEnable;

hmiStatus.elevatorQuickStop :=
    elevatorQuickStop;

hmiStatus.elevatorSpeedRefMmps :=
    elevatorSpeedRefMmps;

hmiStatus.elevatorSetEncoderPosition :=
    elevatorSetEncoderPosition;

hmiStatus.elevatorSetEncoderPositionMm :=
    elevatorSetEncoderPositionMm;

hmiStatus.elevatorFault :=
    elevatorFault;

hmiStatus.elevatorFaultCode :=
    elevatorFaultCode;


//==============================================================
// 8) Auxiliary pneumatic output status
// EN: Mirror the commanded pneumatic outputs for HMI diagnostics.
// PT: Espelha as saídas pneumáticas comandadas para diagnóstico na HMI.
//==============================================================
hmiStatus.paperPressSolenoid :=
    paperPressSolenoid;

hmiStatus.sheetBrush1Valve :=
    sheetBrush1Valve;

hmiStatus.sheetBrush2Valve :=
    sheetBrush2Valve;

hmiStatus.sheetBrush3Valve :=
    sheetBrush3Valve;

hmiStatus.sheetBrush4Valve :=
    sheetBrush4Valve;


//==============================================================
// 9) Process values
//==============================================================
hmiStatus.lineSpeedMPM :=
    lineSpeedMPM;

hmiStatus.sheetLengthMm :=
    sheetLengthMm;

hmiStatus.stackHeightMm :=
    stackHeightMm;


//==============================================================
// 10) Input / drive status mirror
//==============================================================
hmiStatus.sheetConveyor1DriveOk :=
    sheetConveyor1DriveOk;

hmiStatus.sheetConveyor2DriveOk :=
    sheetConveyor2DriveOk;

hmiStatus.sheetConveyor3DriveOk :=
    sheetConveyor3DriveOk;

hmiStatus.sheetConveyor4DriveOk :=
    sheetConveyor4DriveOk;

hmiStatus.backstopDriveOk :=
    backstopDriveOk;

hmiStatus.elevatorDriveOk :=
    elevatorDriveOk;

hmiStatus.sheetStackDischargeConveyorDriveOk :=
    sheetStackDischargeConveyorDriveOk;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_MachineAuxiliary" Id="{737ee558-6100-438a-96e5-47721d84e85a}">
      <Declaration><![CDATA[//==============================================================
// COMPLEX STACKER — MACHINE AUXILIARY CONTROL
// EN: Maps auxiliary outputs and generates external event pulses.
// PT: Mapeia saídas auxiliares e gera pulsos de eventos externos.
//==============================================================
METHOD _MachineAuxiliary
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
//==============================================================
// 1) Auxiliary pneumatic outputs
// EN: Maps the operator command to the no-crush roller valve.
// PT: Mapeia o comando do operador para a válvula dos rolos no-crush.
//==============================================================
noCrushRollersUpDownValve := noCrushRollersDownCmd;


//==============================================================
// 2) General status and command mirrors
// EN: Exposes the internal run and reset states to the parent controller.
// PT: Expõe os estados internos de operação e reset ao controlador pai.
//==============================================================
stackerRunning := systemRunEnable;
reset := resetCmd;


//==============================================================
// 3) Active unload and homing warning status
// EN: Includes pending separation so the warning starts in the acceptance
//     scan. Homing is detected from the current axis states so the siren
//     remains active throughout each complete homing sequence.
// PT: Inclui a separação pendente para o aviso iniciar no scan do aceite.
//     O homing é detectado pelos estados atuais dos eixos para manter a
//     sirene ativa durante toda a sequência de referenciamento.
//==============================================================
stackerBuzzer1 :=
    sheetStackDischargePending OR
    sheetStackDischargeActive OR
    (
        (backstopControlState >= 10) AND
        (backstopControlState <= 14)
    ) OR
    (
        (elevatorControlState >= 10) AND
        (elevatorControlState <= 14)
    );

stackerBuzzer2 :=
    sheetStackDischargePending OR
    sheetStackDischargeActive OR
    (
        (backstopControlState >= 10) AND
        (backstopControlState <= 14)
    ) OR
    (
        (elevatorControlState >= 10) AND
        (elevatorControlState <= 14)
    );

//==============================================================
// 4) External stack counter reset
// EN: Every accepted unload generates a fixed 20 ms reset pulse.
// PT: Cada descarga aceita gera um pulso fixo de reset de 20 ms.
//==============================================================
tpExternalCounterReset(
    IN := dischargeRequestAccepted,
    PT := T#20MS
);

externalCounterReset := tpExternalCounterReset.Q;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_paperPressControl" Id="{1fbd1c65-1604-42f7-a275-e6e0d18a6746}">
      <Declaration><![CDATA[METHOD _paperPressControl
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
// EN: When disabled, immediately switch off and reset the cycle.
// PT: Quando desabilitado, desliga imediatamente e reinicia o ciclo.
IF NOT paperPressAutoManCmd THEN

    paperPressSolenoid := FALSE;
    paperPressOnPhase := TRUE;


    instTONPaperPressOn(IN := FALSE);

    instTONPaperPressOff(IN := FALSE);


ELSE

	IF elevatorControlState = 30 THEN
		//==========================================================
		// ON phase / Fase ligada (Only when auto leveling)
		//==========================================================
		IF paperPressOnPhase THEN
	
			paperPressSolenoid := TRUE;
	
			instTONPaperPressOff(IN := FALSE);
	
			instTONPaperPressOn(
				IN := TRUE,
				PT := machineConfig.paperPressOnTime
			);
	
			IF instTONPaperPressOn.Q THEN
	
				instTONPaperPressOn(IN := FALSE);
	
				paperPressSolenoid := FALSE;
				paperPressOnPhase := FALSE;
	
			END_IF;
	
		//==========================================================
		// OFF phase / Fase desligada
		//==========================================================
		ELSE
	
			paperPressSolenoid := FALSE;
	
			instTONPaperPressOn(IN := FALSE);
	
			instTONPaperPressOff(
				IN := TRUE,
				PT := machineConfig.paperPressOffTime
			);
	
			IF instTONPaperPressOff.Q THEN
	
				instTONPaperPressOff(IN := FALSE);
	
				paperPressSolenoid := TRUE;
				paperPressOnPhase := TRUE;
	
			END_IF;
	
		END_IF;
		
	ELSE
		
		paperPressSolenoid := FALSE;
		paperPressOnPhase := TRUE;
	
	
		instTONPaperPressOn(IN := FALSE);
	
		instTONPaperPressOff(IN := FALSE);
	
	END_IF

END_IF;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_SheetBrushControl" Id="{4c70e1e1-ef21-4e46-8f8d-e8536cb72918}">
      <Declaration><![CDATA[//==============================================================
// COMPLEX STACKER - SHEET BRUSH CONTROL
// EN: Controls the four independent sheet brushes from manual commands.
// PT: Controla as quatro escovas independentes pelos comandos manuais.
//==============================================================
METHOD _SheetBrushControl
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
// EN: The master command only enables the individual brush commands.
//     This function is intentionally independent of the stacker run state.
// PT: O comando mestre apenas habilita os comandos individuais das escovas.
//     Esta função é intencionalmente independente do estado ligado do stacker.
sheetBrush1Valve := sheetBrushAutoManCmd AND sheetBrush1Cmd;
sheetBrush2Valve := sheetBrushAutoManCmd AND sheetBrush2Cmd;
sheetBrush3Valve := sheetBrushAutoManCmd AND sheetBrush3Cmd;
sheetBrush4Valve := sheetBrushAutoManCmd AND sheetBrush4Cmd;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_SheetConveyor1ExhaustFanControl" Id="{b9cdd732-6a51-4c82-9cde-4db85e632a17}">
      <Declaration><![CDATA[//==============================================================
// COMPLEX STACKER - SHEET CONVEYOR 1 EXHAUST FAN CONTROL
// EN: Controls the exhaust fan according to stacker enable,
//     operator command and line speed.
// PT: Controla o exaustor conforme a habilitação do stacker,
//     o comando do operador e a velocidade da linha.
//==============================================================
METHOD _SheetConveyor1ExhaustFanControl
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
// EN: Operator disable or stacker shutdown switches the fan off immediately.
// PT: A desabilitação pelo operador ou o desligamento do stacker desliga
//     o exaustor imediatamente.
IF NOT systemRunEnable OR
   NOT sheetConveyor1ExhaustFanCmd THEN

    sheetConveyor1ExhaustFanRun := FALSE;
    instTONSheetConveyor1ExhaustFanStopDelay(IN := FALSE);

// EN: Above the configured threshold, run the fan and reset the stop delay.
// PT: Acima do limite configurado, liga o exaustor e reinicia o atraso.
ELSIF lineSpeedMPM > machineConfig.sheetConveyor1ExhaustFanLineSpeedThresholdMPM THEN

    sheetConveyor1ExhaustFanRun := TRUE;
    instTONSheetConveyor1ExhaustFanStopDelay(IN := FALSE);

// EN: When speed drops, keep an already running fan on until the delay expires.
//     Enabling the command at low speed does not start the fan.
// PT: Quando a velocidade cai, mantém o exaustor que já estava ligado até
//     o fim do atraso. Habilitar o comando em baixa velocidade não liga o exaustor.
ELSIF sheetConveyor1ExhaustFanRun THEN

    instTONSheetConveyor1ExhaustFanStopDelay(
        IN := TRUE,
        PT := machineConfig.sheetConveyor1ExhaustFanStopDelay
    );

    IF instTONSheetConveyor1ExhaustFanStopDelay.Q THEN

        sheetConveyor1ExhaustFanRun := FALSE;

    END_IF;

ELSE

    sheetConveyor1ExhaustFanRun := FALSE;
    instTONSheetConveyor1ExhaustFanStopDelay(IN := FALSE);

END_IF;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_SheetConveyorGroupControl" Id="{f14f5fe3-bf14-462b-8073-c7cc7907504e}">
      <Declaration><![CDATA[//==============================================================
// COMPLEX STACKER — SHEET CONVEYOR GROUP CONTROL
// EN: Controls the synchronized sheet conveyor group.
//     Start/stop command latch is handled by _SystemControl().
//==============================================================
METHOD _SheetConveyorGroupControl

]]></Declaration>
      <Implementation>
        <ST><![CDATA[
//==============================================================
// 1) Conditions
//==============================================================
// EN: Only synchronized sheet conveyor drives are considered here.
// PT: Apenas os inversores das esteiras sincronizadas são considerados aqui.
allSynchronizedDrivesOk :=
    sheetConveyor1DriveOk AND
    sheetConveyor2DriveOk AND
    sheetConveyor3DriveOk AND
    sheetConveyor4DriveOk;


// EN: Synchronized conveyor group fault.
// PT: Falha do grupo de esteiras sincronizadas.
anyFault :=
    NOT safetyCircuitOk OR
    NOT allSynchronizedDrivesOk;

faultActive := anyFault;


//==============================================================
// 2) State machine
//==============================================================
CASE syncConveyorsState OF

    0: // IDLE
        deviceState := 'IDLE';

        sheetConveyor1Run := FALSE;
        sheetConveyor2Run := FALSE;
        sheetConveyor3Run := FALSE;
        sheetConveyor4Run := FALSE;

        synchronizedConveyorsRunning := FALSE;

        // EN: The group starts only when the master system is enabled
        //     and no conveyor group fault is active.
        IF systemRunEnable AND NOT anyFault THEN

            syncConveyorsState := 1;

        ELSIF systemRunEnable AND anyFault THEN

            syncConveyorsState := 10;

        END_IF


    1: // RUN
        deviceState := 'RUN';

        // EN: Outputs are also directly conditioned by systemRunEnable
        //     to avoid one-scan movement after a stop command.
        sheetConveyor1Run :=
            systemRunEnable AND
            safetyCircuitOk AND
            sheetConveyor1DriveOk;

        sheetConveyor2Run :=
            systemRunEnable AND
            safetyCircuitOk AND
            sheetConveyor2DriveOk;

        sheetConveyor3Run :=
            systemRunEnable AND
            safetyCircuitOk AND
            sheetConveyor3DriveOk;

        sheetConveyor4Run :=
            systemRunEnable AND
            safetyCircuitOk AND
            sheetConveyor4DriveOk;

        synchronizedConveyorsRunning :=
            sheetConveyor1Run AND
            sheetConveyor2Run AND
            sheetConveyor3Run AND
            sheetConveyor4Run;

        IF anyFault THEN

            syncConveyorsState := 10;

        ELSIF NOT systemRunEnable THEN

            syncConveyorsState := 0;

        END_IF


    10: // FAULT
        deviceState := 'FAULT';

        sheetConveyor1Run := FALSE;
        sheetConveyor2Run := FALSE;
        sheetConveyor3Run := FALSE;
        sheetConveyor4Run := FALSE;

        synchronizedConveyorsRunning := FALSE;

        // EN: Fault state is released only by reset and with all faults cleared.
        //     If systemRunEnable is still TRUE after reset, the group can start
        //     again from IDLE on the next scan.
        IF resetCmd AND NOT anyFault THEN

            syncConveyorsState := 0;

        END_IF


ELSE

    syncConveyorsState := 0;

END_CASE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_SheetStackAlignmentBrushControl" Id="{966d350f-61ef-49c8-96fe-30e2c63c014f}">
      <Declaration><![CDATA[//==============================================================
// COMPLEX STACKER - SHEET STACK ALIGNMENT BRUSH CONTROL
// EN: Keeps the alignment brush engaged during production and raises
//     it only while the elevator executes an automatic discharge cycle.
// PT: Mantém a escova de alinhamento acionada durante a produção e a
//     levanta somente durante o ciclo automático de descarga do elevador.
//==============================================================
METHOD _SheetStackAlignmentBrushControl
VAR
	// EN: Relevant fault condition that forces the enabled brush down.
	// PT: Condição de falha relevante que força a escova habilitada para baixo.
	brushFaultActive : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[

//==============================================================
// 2) Automatic discharge memory / Memória da descarga automática
//==============================================================
// EN: Manual operation and faults force the brush down and cancel the
//     memory of a previously active automatic discharge.
// PT: A operação manual e as falhas forçam a escova para baixo e cancelam
//     a memória de uma descarga automática anteriormente ativa.

    // EN: WAIT_SEPARATION (state 5) is intentionally excluded so the brush
    //     remains down until elevator discharge positioning actually starts.
    // PT: WAIT_SEPARATION (estado 5) é intencionalmente excluído para que a
    //     escova permaneça abaixada até iniciar o posicionamento de descarga.
    IF (sheetStackDischargeControlState = 10) OR
       (sheetStackDischargeControlState = 20) OR
       (sheetStackDischargeControlState = 30) OR
       (sheetStackDischargeControlState = 40) OR
       (sheetStackDischargeControlState = 50) THEN

        sheetStackAlignmentBrushLiftedForDischarge := TRUE;

    // EN: Lower the brush only after discharge has completely finished and
    //     automatic elevator leveling is active again.
    // PT: Abaixa a escova somente após o descarte terminar completamente e
    //     o nivelamento automático do elevador estar ativo novamente.
    ELSIF (sheetStackDischargeControlState = 0) AND
          NOT sheetStackDischargePending AND
          NOT sheetStackDischargeActive AND
          (elevatorControlState = 30) THEN

        sheetStackAlignmentBrushLiftedForDischarge := FALSE;

    END_IF


IF noCrushRollersDownCmd AND NOT sheetStackAlignmentBrushLiftedForDischarge THEN

	sheetStackAlignmentBrush := TRUE;

ELSE

	sheetStackAlignmentBrush := FALSE;

END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="_SheetStackDischargeControl" Id="{6a21452b-a00c-4dc6-803c-d98058ed2a21}">
      <Declaration><![CDATA[//==============================================================
// COMPLEX STACKER — SHEET STACK DISCHARGE CONTROL
// EN: Controls the sheet stack discharge sequence after the sheet
//     conveyor separation cycle is completed.
//
// State code
// 0  = IDLE
// 5  = WAIT_SEPARATION
// 10 = START_DISCHARGE_POSITIONING
// 20 = WAIT_DISCHARGE_POSITION
// 30 = RUN_DISCHARGE_CONVEYOR_AND_WAIT_CLEAR
// 40 = START_RETURN_POSITIONING
// 50 = WAIT_RETURN_POSITION
// 60 = FINISH
// 90 = FAULT_HOLD
//
// Last result code
// 0 = No cycle executed yet
// 1 = Last cycle completed successfully
// 2 = Last cycle completed with manual backstop skip
// 3 = Last cycle completed/aborted by timeout
// 4 = Last cycle aborted by fault
//
// Fault code
// 0  = No fault
// 1  = Safety circuit not OK
// 2  = Sheet conveyor drive not OK
// 3  = Discharge conveyor drive/control fault
// 4  = Backstop drive/control fault
// 5  = Elevator drive/control fault
// 6  = Stacker stopped during cycle
// 10 = Wait separation timeout
// 20 = Discharge positioning timeout
// 30 = Discharge conveyor did not start timeout
// 31 = Elevator platform clear timeout
// 50 = Return positioning timeout
//==============================================================
METHOD _SheetStackDischargeControl
VAR
    abortCycle : BOOL;
    automaticUnloadRequest : BOOL;
    changeBatchRequest : BOOL;
    backstopDischargeReady : BOOL;
    backstopAutomaticCycleEnabled : BOOL;
    elevatorPlatformClear : BOOL;
    restartFaultRecovery : BOOL;
    unloadRequestAvailable : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[

//==============================================================
// 1) Default event pulses
//==============================================================
stackerUnloadAccepted       := FALSE;
dischargeRequestAccepted    := FALSE;
sheetStackDischargeStarted  := FALSE;
sheetStackDischargeFinished := FALSE;

// EN: An empty platform is accepted even when no stack was present
//     at the beginning of the discharge cycle.
// PT: Plataforma vazia é aceita mesmo quando não havia pilha
//     no início do ciclo de descarte.
elevatorPlatformClear :=
    NOT elevatorStackPresentAtDischargeStart OR
    (
        elevatorStackExitClearSensor AND
         elevatorStackPresentSensor
    );


//==============================================================
// 2) Default internal requests / overrides
//==============================================================
// EN: The sequence does not write the physical discharge conveyor outputs.
//     It only generates an internal request to the conveyor control method.
sheetStackDischargeConveyorRunRequest := FALSE;

backstopTargetOverrideActive := FALSE;
backstopTargetOverridePositionMm := 0.0;

elevatorTargetOverrideActive := FALSE;
elevatorTargetOverridePositionMm := 0.0;


//==============================================================
// 3) Unload request handling
//==============================================================
// EN: The local request is accepted only on its rising edge.
// PT: O pedido local é aceito somente na sua borda de subida.
rStackerUnloadCmd :=
    stackerUnloadCmd AND NOT stackerUnloadCmdOld;

stackerUnloadCmdOld := stackerUnloadCmd;


// EN: The maintained automatic request is rearmed only after going FALSE.
//     If it remains TRUE, it cannot be accepted for a second cycle.
// PT: O pedido automático mantido é rearmado somente após ficar FALSE.
//     Se permanecer TRUE, não pode ser aceito para um segundo ciclo.
IF NOT packageCompleteCmd THEN
    packageCompleteCmdAcceptedLatch := FALSE;
END_IF;

automaticUnloadRequest :=
    packageCompleteCmd AND
    NOT packageCompleteCmdAcceptedLatch;

// EN: Preserve a batch-change rising edge until the cycle can be accepted.
// PT: Preserva a borda de subida da troca de lote até o ciclo poder ser aceito.
IF changeBatchCmd AND
   NOT changeBatchCmdOld AND
   NOT automaticUnloadRequest THEN
    changeBatchRequestPending := TRUE;
END_IF;

changeBatchCmdOld := changeBatchCmd;
changeBatchRequest := changeBatchRequestPending;


// EN: The automatic request has priority when both requests arrive together.
// PT: O pedido automático tem prioridade quando os dois pedidos chegam juntos.
unloadRequestAvailable := FALSE;

IF automaticUnloadRequest THEN
    unloadRequestAvailable := TRUE;
    changeBatchRequest := FALSE;
ELSIF changeBatchRequest THEN
    unloadRequestAvailable := TRUE;
ELSIF rStackerUnloadCmd THEN
    unloadRequestAvailable := TRUE;
END_IF;


//==============================================================
// 3.1) Backstop participation in the current cycle
//==============================================================
// EN: Once manual mode is detected during an accepted cycle, keep the
//     backstop bypassed until that cycle finishes. Returning the selector
//     to automatic cannot restart an old backstop movement.
// PT: Depois que o modo manual for detectado durante um ciclo aceito,
//     mantém o backstop ignorado até o fim desse ciclo. Retornar o seletor
//     para automático não reinicia um movimento antigo do backstop.
IF (
       sheetStackDischargeActive OR
       sheetStackDischargePending OR
       (sheetStackDischargeControlState <> 0)
   ) AND
   NOT backstopAutoCmd THEN

    sheetStackDischargeCycleHasManualSkip := TRUE;

END_IF;


IF sheetStackDischargeActive OR
   sheetStackDischargePending OR
   (sheetStackDischargeControlState <> 0) THEN

    backstopAutomaticCycleEnabled :=
        backstopAutoCmd AND
        NOT sheetStackDischargeCycleHasManualSkip;

ELSE

    // EN: Before accepting a new cycle, use the current selector position.
    // PT: Antes de aceitar um novo ciclo, usa a posição atual do seletor.
    backstopAutomaticCycleEnabled := backstopAutoCmd;

END_IF;


//==============================================================
// 4) Fault condition
//==============================================================
// EN: Elevator drive, homing and position feedback are required
//     for safe discharge sequence progress.
// PT: Drive, homing e posição do elevador são obrigatórios
//     para o avanço seguro da sequência de descarte.
sheetStackDischargeFaultCondition :=
    NOT safetyCircuitOk OR
    NOT sheetConveyor1DriveOk OR
    NOT sheetConveyor2DriveOk OR
    NOT sheetConveyor3DriveOk OR
    NOT sheetConveyor4DriveOk OR
    NOT sheetStackDischargeConveyorDriveOk OR
    sheetStackDischargeConveyorFault OR
    (
        backstopAutomaticCycleEnabled AND
        (
            NOT backstopDriveOk OR
            NOT backstopHomed OR
            backstopFault
        )
    ) OR
    NOT elevatorDriveOk OR
    NOT elevatorHomed OR
    NOT elevatorReadyForAutomaticCycle OR
    elevatorFault;


//==============================================================
// 5) Fault code priority
//==============================================================
IF NOT safetyCircuitOk THEN

    sheetStackDischargeFaultCode := 1;

ELSIF NOT sheetConveyor1DriveOk OR
      NOT sheetConveyor2DriveOk OR
      NOT sheetConveyor3DriveOk OR
      NOT sheetConveyor4DriveOk THEN

    sheetStackDischargeFaultCode := 2;

ELSIF NOT sheetStackDischargeConveyorDriveOk OR
      sheetStackDischargeConveyorFault THEN

    sheetStackDischargeFaultCode := 3;

ELSIF backstopAutomaticCycleEnabled AND
      (
          NOT backstopDriveOk OR
          NOT backstopHomed OR
          backstopFault
      ) THEN

    sheetStackDischargeFaultCode := 4;

ELSIF NOT elevatorDriveOk OR
      NOT elevatorHomed OR
      NOT elevatorReadyForAutomaticCycle OR
      elevatorFault THEN

    sheetStackDischargeFaultCode := 5;

ELSIF NOT synchronizedConveyorsRunning THEN

    sheetStackDischargeFaultCode := 6;

END_IF;


//==============================================================
// 6) Optional reset of current sequence fault display
//==============================================================
// EN: Reset clears the current sequence fault flag,
//     but does not erase last cycle diagnostic codes.
IF resetCmd AND (sheetStackDischargeControlState = 0) THEN

    sheetStackDischargeFault := FALSE;
    sheetStackDischargeFaultCode := 0;
    changeBatchRequestPending := FALSE;
    changeBatchCycleActive := FALSE;

END_IF;


//==============================================================
// 7) Accept and arm the discharge sequence
//==============================================================
// EN: The request is accepted only when separation can start and every
//     discharge permissive is valid. A start-triggered homing request must
//     finish before a new discharge can be accepted.
// PT: O pedido é aceito somente quando a separação pode iniciar e todas as
//     permissões de descarga são válidas. Um homing solicitado pela partida
//     deve terminar antes que um novo descarte seja aceito.
IF unloadRequestAvailable AND
   sheetStackSeparationReady AND
   (packageSeparationState = 0) AND
   elevatorAutoCmd AND
   NOT elevatorAutoHomePending AND
   NOT (
       (elevatorControlState >= 10) AND
       (elevatorControlState <= 14)
   ) AND
   (
       NOT backstopAutoCmd OR
       (
           NOT backstopAutoHomePending AND
           NOT (
               (backstopControlState >= 10) AND
               (backstopControlState <= 14)
           )
       )
   ) AND
   synchronizedConveyorsRunning AND
   NOT sheetStackDischargeFaultCondition AND
   NOT sheetStackDischargeFault AND
   NOT sheetStackDischargeActive AND
   NOT sheetStackDischargePending THEN

    sheetStackDischargePending := TRUE;
    dischargeRequestAccepted := TRUE;

    // EN: Consume the automatic request until packageCompleteCmd turns FALSE.
    //     This branch also implements automatic priority over the local edge.
    // PT: Consome o pedido automático até packageCompleteCmd ficar FALSE.
    //     Este ramo também implementa a prioridade do automático sobre a borda local.
    IF automaticUnloadRequest THEN
        packageCompleteCmdAcceptedLatch := TRUE;
        changeBatchCycleActive := FALSE;
    ELSIF changeBatchRequest THEN
        changeBatchRequestPending := FALSE;
        changeBatchCycleActive := TRUE;
    ELSE
        changeBatchCycleActive := FALSE;
        stackerUnloadAccepted := TRUE;
    END_IF;

    // EN: Clear current-cycle flags when a new cycle is accepted.
    sheetStackDischargeFault := FALSE;
    sheetStackDischargeFaultCode := 0;

    // EN: Manual is a valid bypass. It remains latched for this whole cycle.
    // PT: Manual é um bypass válido. Permanece memorizado por todo o ciclo.
    sheetStackDischargeCycleHasManualSkip := NOT backstopAutoCmd;
    sheetStackDischargeCycleHasTimeout := FALSE;

END_IF;


//==============================================================
// 8) Start-triggered recovery from fault hold
//==============================================================
// EN: A new machine start safely abandons the failed discharge cycle before
//     the mandatory automatic homing requests are released on the next scan.
//     Last-cycle diagnostic codes and the accepted package latch are preserved.
// PT: Uma nova partida da máquina abandona com segurança o ciclo de descarte
//     com falha antes de liberar os pedidos obrigatórios de homing no próximo scan.
//     Os diagnósticos do último ciclo e o latch do pacote aceito são preservados.
restartFaultRecovery :=
    rStartCmd AND
    systemRunEnable AND
    (sheetStackDischargeControlState = 90);


IF restartFaultRecovery THEN

    sheetStackDischargeActive := FALSE;
    sheetStackDischargePending := FALSE;
    sheetStackDischargeControlState := 0;

    sheetStackDischargeFault := FALSE;
    sheetStackDischargeFaultCode := 0;
    changeBatchCycleActive := FALSE;

    sheetStackDischargeConveyorRunRequest := FALSE;

    backstopTargetOverrideActive := FALSE;
    elevatorTargetOverrideActive := FALSE;

    tonSheetStackDischarge(IN := FALSE);
    tonSheetStackDischargeStepTimeout(IN := FALSE);
    tonSheetStackDischargePlatformClearTimeout(IN := FALSE);

    elevatorPlatformClearDetected := FALSE;
    elevatorStackPresentAtDischargeStart := FALSE;

END_IF;


//==============================================================
// 9) Immediate abort condition
//==============================================================
// EN: Faults before discharge positioning cancel the request. Faults after
//     positioning starts hold safe targets until operator acknowledgement.
// PT: Falhas antes do posicionamento cancelam o pedido. Após o início,
//     mantêm os alvos seguros até o reconhecimento do operador.
abortCycle :=
    (
        sheetStackDischargeActive OR
        sheetStackDischargePending OR
        (sheetStackDischargeControlState <> 0)
    )
    AND
    (
        sheetStackDischargeFaultCondition OR
        NOT synchronizedConveyorsRunning
    );


IF abortCycle THEN

    sheetStackDischargeConveyorRunRequest := FALSE;
    sheetStackDischargePending := FALSE;
    changeBatchCycleActive := FALSE;

    tonSheetStackDischarge(IN := FALSE);
    tonSheetStackDischargeStepTimeout(IN := FALSE);
    tonSheetStackDischargePlatformClearTimeout(IN := FALSE);

    sheetStackDischargeFault := TRUE;

    sheetStackDischargeLastCycleOk := FALSE;
    sheetStackDischargeLastResultCode := 4;
    sheetStackDischargeLastFaultCode := sheetStackDischargeFaultCode;

    // EN: Do not clear backstopManualInterventionActive here.
    //     If the cycle aborted before return, keeping the memory is safer
    //     for the next cycle.

    IF sheetStackDischargeControlState <= 5 THEN

        // EN: No discharge movement has started yet.
        // PT: Nenhum movimento de descarte foi iniciado.
        sheetStackDischargeActive := FALSE;

        backstopTargetOverrideActive := FALSE;
        elevatorTargetOverrideActive := FALSE;

        elevatorPlatformClearDetected := FALSE;
        elevatorStackPresentAtDischargeStart := FALSE;

        sheetStackDischargeLastFaultStepCode :=
            sheetStackDischargeControlState;

        sheetStackDischargeState := 'ABORTED';
        sheetStackDischargeStateCode := 90;
        sheetStackDischargeControlState := 0;

    ELSE

        // EN: Preserve the original failed step while the external
        //     fault condition remains active in FAULT_HOLD.
        // PT: Preserva o passo original da falha enquanto a condição
        //     externa permanecer ativa no FAULT_HOLD.
        IF sheetStackDischargeControlState <> 90 THEN
            sheetStackDischargeLastFaultStepCode :=
                sheetStackDischargeControlState;
        END_IF;

        sheetStackDischargeActive := TRUE;
        sheetStackDischargeState := 'FAULT_HOLD';
        sheetStackDischargeStateCode := 90;

        IF sheetStackDischargeLastFaultStepCode < 40 THEN

            IF backstopAutomaticCycleEnabled THEN

                backstopTargetOverrideActive := TRUE;
                backstopTargetOverridePositionMm :=
                    backstopDischargeOpenTargetMm;

            END_IF;

            elevatorTargetOverrideActive := TRUE;
            elevatorTargetOverridePositionMm :=
                machineConfig.elevatorMinPositionMm;

        ELSE

            IF backstopAutomaticCycleEnabled THEN

                backstopTargetOverrideActive := TRUE;
                backstopTargetOverridePositionMm :=
                    backstopProgrammedDischargeTargetMm;

            END_IF;

            elevatorTargetOverrideActive := TRUE;
            elevatorTargetOverridePositionMm :=
                machineConfig.elevatorMaxPositionMm;

        END_IF;

        sheetStackDischargeControlState := 90;

    END_IF


ELSE

    //==============================================================
    // 10) Sheet stack discharge state machine
    //==============================================================
    CASE sheetStackDischargeControlState OF

        0: // IDLE
            sheetStackDischargeState := 'IDLE';
            sheetStackDischargeStateCode := 0;

            sheetStackDischargeActive := FALSE;

            sheetStackDischargeConveyorRunRequest := FALSE;

            backstopTargetOverrideActive := FALSE;
            elevatorTargetOverrideActive := FALSE;

            tonSheetStackDischarge(IN := FALSE);
            tonSheetStackDischargeStepTimeout(IN := FALSE);
            tonSheetStackDischargePlatformClearTimeout(IN := FALSE);
            elevatorPlatformClearDetected := FALSE;
            elevatorStackPresentAtDischargeStart := FALSE;

            IF sheetStackDischargePending THEN

                tonSheetStackDischarge(IN := FALSE);
                tonSheetStackDischargeStepTimeout(IN := FALSE);

                sheetStackDischargeControlState := 5;

            END_IF


        5: // WAIT_SEPARATION
            sheetStackDischargeState := 'WAIT_SEPARATION';
            sheetStackDischargeStateCode := 5;

            sheetStackDischargeActive := FALSE;

            sheetStackDischargeConveyorRunRequest := FALSE;

            backstopTargetOverrideActive := FALSE;
            elevatorTargetOverrideActive := FALSE;

            tonSheetStackDischarge(IN := FALSE);

            // EN: Wait for conveyor speed control to finish sheet stack separation.
            tonSheetStackDischargeStepTimeout(
                IN := TRUE,
                PT := machineConfig.sheetStackDischargeWaitSeparationTimeout
            );

            // EN: Complex stacker discharge starts only after conveyor 4
            //     completes the package separation sequence.
            // PT: O descarte do stacker complexo inicia somente depois que
            //     a esteira 4 concluir a sequência de separação do pacote.
            IF sheetStackSeparationFinished AND
               sheetConveyor4SeparationFinished THEN

                tonSheetStackDischargeStepTimeout(IN := FALSE);

                sheetStackDischargeControlState := 10;


            ELSIF tonSheetStackDischargeStepTimeout.Q THEN

                // EN: Separation did not finish. Do not discharge.
                tonSheetStackDischargeStepTimeout(IN := FALSE);

                sheetStackDischargePending := FALSE;
                sheetStackDischargeActive := FALSE;
                changeBatchCycleActive := FALSE;

                sheetStackDischargeFault := TRUE;
                sheetStackDischargeFaultCode := 10;

                sheetStackDischargeLastCycleOk := FALSE;
                sheetStackDischargeLastResultCode := 3;
                sheetStackDischargeLastFaultStepCode := 5;
                sheetStackDischargeLastFaultCode := 10;

                sheetStackDischargeControlState := 0;

            END_IF


        10: // START_DISCHARGE_POSITIONING
            sheetStackDischargeState := 'START_POSITIONING';
            sheetStackDischargeStateCode := 10;

            sheetStackDischargePending := FALSE;
            sheetStackDischargeActive := TRUE;
            sheetStackDischargeStarted := TRUE;

            elevatorPlatformClearDetected := FALSE;
            tonSheetStackDischargePlatformClearTimeout(IN := FALSE);
            elevatorStackPresentAtDischargeStart :=
                elevatorStackPresentSensor;

            tonSheetStackDischarge(IN := FALSE);
            tonSheetStackDischargeStepTimeout(IN := FALSE);

            //======================================================
            // EN: Latch programmed backstop target for this cycle.
            //     This is the normal position based on sheet length.
            //======================================================
            backstopProgrammedDischargeTargetMm :=
                LIMIT(
                    machineConfig.backstopMinPositionMm,
                    MAX(0.0, sheetLengthMm) +
                        machineConfig.backstopSheetLengthOffsetMm,
                    machineConfig.backstopMaxPositionMm
                );

            //======================================================
            // EN: Define safe opening base position.
            //     The opening starts from the actual mechanical position,
            //     independently of a new, smaller programmed sheet length.
            // PT: Define a posição base segura para abertura.
            //     A abertura parte da posição mecânica atual, independente
            //     de uma nova medida programada menor para a chapa.
            //======================================================
            backstopDischargeOpenBasePositionMm :=
                backstopPositionMm;

            IF backstopManualInterventionActive THEN

                backstopDischargeOpenBasePositionMm :=
                    MAX(
                        backstopDischargeOpenBasePositionMm,
                        backstopManualInterventionPositionMm
                    );

            END_IF;

            //======================================================
            // EN: Latch safe discharge open target.
            //     Only a non-negative offset is accepted.
            // PT: Memoriza o alvo seguro de abertura para descarga.
            //     Somente um offset não negativo é aceito.
            //======================================================
            backstopDischargeOpenTargetMm :=
                LIMIT(
                    machineConfig.backstopMinPositionMm,
                    backstopDischargeOpenBasePositionMm +
                        MAX(
                            0.0,
                            machineConfig.backstopDischargeOpenOffsetMm
                        ),
                    machineConfig.backstopMaxPositionMm
                );

            // EN: Request safe backstop opening only when it participates
            //     in the current automatic cycle. Manual mode is bypassed.
            // PT: Solicita a abertura segura do backstop somente quando ele
            //     participa do ciclo automático atual. O modo manual é ignorado.
            IF backstopAutomaticCycleEnabled THEN

                backstopTargetOverrideActive := TRUE;
                backstopTargetOverridePositionMm :=
                    backstopDischargeOpenTargetMm;

            END_IF;

            // EN: Request the elevator lower discharge position.
            // PT: Solicita a posição inferior de descarte do elevador.
            elevatorTargetOverrideActive := TRUE;
            elevatorTargetOverridePositionMm :=
                machineConfig.elevatorMinPositionMm;

            sheetStackDischargeControlState := 20;


        20: // WAIT_DISCHARGE_POSITION
            sheetStackDischargeState := 'WAIT_DISCHARGE_POS';
            sheetStackDischargeStateCode := 20;

            sheetStackDischargeActive := TRUE;

            // EN: In manual mode do not command or wait for the backstop.
            // PT: No modo manual não comanda nem aguarda o backstop.
            IF backstopAutomaticCycleEnabled THEN

                backstopTargetOverrideActive := TRUE;
                backstopTargetOverridePositionMm :=
                    backstopDischargeOpenTargetMm;

                backstopDischargeReady := backstopInPosition;

            ELSE

                backstopTargetOverrideActive := FALSE;
                backstopDischargeReady := TRUE;

            END_IF;

            // EN: Keep the lower discharge target active and wait for feedback.
            // PT: Mantém o alvo inferior de descarte e aguarda o feedback.
            elevatorTargetOverrideActive := TRUE;
            elevatorTargetOverridePositionMm :=
                machineConfig.elevatorMinPositionMm;

            IF backstopDischargeReady AND elevatorInPosition THEN

                tonSheetStackDischargeStepTimeout(IN := FALSE);
                sheetStackDischargeControlState := 30;

            ELSE

                tonSheetStackDischargeStepTimeout(
                    IN := TRUE,
                    PT := machineConfig.sheetStackDischargePositioningTimeout
                );

                IF tonSheetStackDischargeStepTimeout.Q THEN

                    tonSheetStackDischargeStepTimeout(IN := FALSE);

                    sheetStackDischargeCycleHasTimeout := TRUE;
                    sheetStackDischargeFault := TRUE;
                    sheetStackDischargeFaultCode := 20;

                    sheetStackDischargeLastCycleOk := FALSE;
                    sheetStackDischargeLastResultCode := 3;
                    sheetStackDischargeLastFaultStepCode := 20;
                    sheetStackDischargeLastFaultCode := 20;

                    // EN: Do not start the discharge conveyor without
                    //     confirmed elevator positioning.
                    // PT: Não inicia a esteira de descarte sem confirmar
                    //     o posicionamento do elevador.
                    sheetStackDischargeControlState := 90;
                    sheetStackDischargeActive := TRUE;
                    sheetStackDischargePending := FALSE;

                END_IF

            END_IF


        30: // RUN_DISCHARGE_CONVEYOR
            sheetStackDischargeState := 'DISCHARGING';
            sheetStackDischargeStateCode := 30;

            sheetStackDischargeActive := TRUE;

            // EN: Keep the backstop open only if it participates in this cycle.
            // PT: Mantém o backstop aberto somente se ele participa deste ciclo.
            IF backstopAutomaticCycleEnabled THEN

                backstopTargetOverrideActive := TRUE;
                backstopTargetOverridePositionMm :=
                    backstopDischargeOpenTargetMm;

            END_IF;

            // EN: Keep elevator at the lower discharge position.
            // PT: Mantém o elevador na posição inferior de descarte.
            elevatorTargetOverrideActive := TRUE;
            elevatorTargetOverridePositionMm :=
                machineConfig.elevatorMinPositionMm;

            // EN: Request discharge conveyor run.
            //     Physical output is controlled by _SheetStackDischargeConveyorControl.
            sheetStackDischargeConveyorRunRequest := TRUE;

            // EN: If conveyor is not actually running, use start timeout.
            IF NOT sheetStackDischargeConveyorRun THEN

                tonSheetStackDischarge(IN := FALSE);
                tonSheetStackDischargePlatformClearTimeout(IN := FALSE);

                tonSheetStackDischargeStepTimeout(
                    IN := TRUE,
                    PT := machineConfig.sheetStackDischargeConveyorStartTimeout
                );

                IF tonSheetStackDischargeStepTimeout.Q THEN

                    // EN: Conveyor did not start. Do not stay trapped.
                    tonSheetStackDischargeStepTimeout(IN := FALSE);

                    sheetStackDischargeConveyorRunRequest := FALSE;

                    sheetStackDischargeCycleHasTimeout := TRUE;

                    sheetStackDischargeFault := TRUE;
                    sheetStackDischargeFaultCode := 30;

                    sheetStackDischargeLastCycleOk := FALSE;
                    sheetStackDischargeLastResultCode := 3;
                    sheetStackDischargeLastFaultStepCode := 30;
                    sheetStackDischargeLastFaultCode := 30;

                    sheetStackDischargeControlState := 90;

                END_IF


            ELSE

                // EN: Conveyor is running. Count minimum discharge time
                //     and wait for a clean elevator platform.
                // PT: A esteira está em movimento. Conta o tempo mínimo
                //     e aguarda a plataforma do elevador ficar livre.
                tonSheetStackDischargeStepTimeout(IN := FALSE);

                tonSheetStackDischarge(
                    IN := TRUE,
                    PT := machineConfig.sheetStackDischargeTime
                );

                IF elevatorPlatformClear THEN
                    elevatorPlatformClearDetected := TRUE;
                END_IF;

                tonSheetStackDischargePlatformClearTimeout(
                    IN := NOT elevatorPlatformClearDetected,
                    PT := machineConfig.sheetStackDischargePlatformClearTimeout
                );

                IF tonSheetStackDischarge.Q AND
                   elevatorPlatformClearDetected THEN

                    tonSheetStackDischarge(IN := FALSE);
                    tonSheetStackDischargePlatformClearTimeout(IN := FALSE);

                    sheetStackDischargeConveyorRunRequest := FALSE;

                    sheetStackDischargeControlState := 40;

                ELSIF tonSheetStackDischargePlatformClearTimeout.Q THEN

                    tonSheetStackDischarge(IN := FALSE);
                    tonSheetStackDischargePlatformClearTimeout(IN := FALSE);

                    sheetStackDischargeConveyorRunRequest := FALSE;

                    sheetStackDischargeCycleHasTimeout := TRUE;
                    sheetStackDischargeFault := TRUE;
                    sheetStackDischargeFaultCode := 31;

                    sheetStackDischargeLastCycleOk := FALSE;
                    sheetStackDischargeLastResultCode := 3;
                    sheetStackDischargeLastFaultStepCode := 30;
                    sheetStackDischargeLastFaultCode := 31;

                    // EN: Keep the elevator down and backstop open until reset.
                    // PT: Mantém o elevador embaixo e o backstop aberto até o reset.
                    sheetStackDischargeControlState := 90;

                END_IF

            END_IF


        40: // START_RETURN_POSITIONING
            sheetStackDischargeState := 'START_RETURN';
            sheetStackDischargeStateCode := 40;

            sheetStackDischargeActive := TRUE;

            sheetStackDischargeConveyorRunRequest := FALSE;

            tonSheetStackDischarge(IN := FALSE);
            tonSheetStackDischargeStepTimeout(IN := FALSE);

            // EN: Return the backstop only if it participates in this cycle.
            // PT: Retorna o backstop somente se ele participa deste ciclo.
            IF backstopAutomaticCycleEnabled THEN

                backstopTargetOverrideActive := TRUE;
                backstopTargetOverridePositionMm :=
                    backstopProgrammedDischargeTargetMm;

            END_IF;

            // EN: Request elevator return to the upper production position.
            // PT: Solicita o retorno do elevador à posição superior de produção.
            elevatorTargetOverrideActive := TRUE;
            elevatorTargetOverridePositionMm :=
                machineConfig.elevatorMaxPositionMm;

            sheetStackDischargeControlState := 50;


        50: // WAIT_RETURN_POSITION
            sheetStackDischargeState := 'WAIT_RETURN_POS';
            sheetStackDischargeStateCode := 50;

            sheetStackDischargeActive := TRUE;

            sheetStackDischargeConveyorRunRequest := FALSE;

            // EN: In manual mode do not command or wait for backstop return.
            // PT: No modo manual não comanda nem aguarda o retorno do backstop.
            IF backstopAutomaticCycleEnabled THEN

                backstopTargetOverrideActive := TRUE;
                backstopTargetOverridePositionMm :=
                    backstopProgrammedDischargeTargetMm;

                backstopDischargeReady := backstopInPosition;

            ELSE

                backstopTargetOverrideActive := FALSE;
                backstopDischargeReady := TRUE;

            END_IF;

            // EN: Keep the upper elevator target active and wait for feedback.
            // PT: Mantém o alvo superior do elevador e aguarda o feedback.
            elevatorTargetOverrideActive := TRUE;
            elevatorTargetOverridePositionMm :=
                machineConfig.elevatorMaxPositionMm;

            IF backstopDischargeReady AND elevatorInPosition THEN

                tonSheetStackDischargeStepTimeout(IN := FALSE);
                sheetStackDischargeControlState := 60;

            ELSE

                tonSheetStackDischargeStepTimeout(
                    IN := TRUE,
                    PT := machineConfig.sheetStackDischargeReturnTimeout
                );

                IF tonSheetStackDischargeStepTimeout.Q THEN

                    tonSheetStackDischargeStepTimeout(IN := FALSE);

                    sheetStackDischargeCycleHasTimeout := TRUE;
                    sheetStackDischargeFault := TRUE;
                    sheetStackDischargeFaultCode := 50;

                    sheetStackDischargeLastCycleOk := FALSE;
                    sheetStackDischargeLastResultCode := 3;
                    sheetStackDischargeLastFaultStepCode := 50;
                    sheetStackDischargeLastFaultCode := 50;

                    // EN: Do not report a completed cycle without confirmed
                    //     return positioning.
                    // PT: Não confirma o ciclo sem o posicionamento de retorno.
                    sheetStackDischargeActive := TRUE;
                    sheetStackDischargePending := FALSE;
                    sheetStackDischargeControlState := 90;

                END_IF

            END_IF


        90: // FAULT_HOLD
            sheetStackDischargeState := 'FAULT_HOLD';
            sheetStackDischargeStateCode := 90;

            sheetStackDischargeActive := TRUE;
            sheetStackDischargePending := FALSE;
            sheetStackDischargeConveyorRunRequest := FALSE;

            tonSheetStackDischarge(IN := FALSE);
            tonSheetStackDischargeStepTimeout(IN := FALSE);
            tonSheetStackDischargePlatformClearTimeout(IN := FALSE);

            // EN: Before platform clearance, keep the safe discharge
            //     positions: backstop open and elevator down.
            // PT: Antes da confirmação de plataforma livre, mantém as
            //     posições seguras: backstop aberto e elevador embaixo.
            IF sheetStackDischargeLastFaultStepCode < 40 THEN

                IF backstopAutomaticCycleEnabled THEN

                    backstopTargetOverrideActive := TRUE;
                    backstopTargetOverridePositionMm :=
                        backstopDischargeOpenTargetMm;

                END_IF;

                elevatorTargetOverrideActive := TRUE;
                elevatorTargetOverridePositionMm :=
                    machineConfig.elevatorMinPositionMm;

            ELSE

                // EN: A return-position timeout occurs only after the
                //     platform was confirmed clear. Keep the return targets.
                // PT: Timeout de retorno ocorre somente após confirmar a
                //     plataforma livre. Mantém os alvos de retorno.
                IF backstopAutomaticCycleEnabled THEN

                    backstopTargetOverrideActive := TRUE;
                    backstopTargetOverridePositionMm :=
                        backstopProgrammedDischargeTargetMm;

                END_IF;

                elevatorTargetOverrideActive := TRUE;
                elevatorTargetOverridePositionMm :=
                    machineConfig.elevatorMaxPositionMm;

            END_IF;

            // EN: Reset is an explicit operator acknowledgement.
            // PT: Reset é uma confirmação explícita do operador.
            IF resetCmd AND
               safetyCircuitOk AND
               (
                   NOT backstopAutomaticCycleEnabled OR
                   backstopDriveOk
               ) AND
               elevatorDriveOk AND
               (
                   elevatorPlatformClear OR
                   elevatorPlatformClearDetected OR
                   (sheetStackDischargeLastFaultStepCode >= 40)
               ) THEN

                sheetStackDischargeFault := FALSE;
                sheetStackDischargeFaultCode := 0;

                // EN: After acknowledgement, complete the automatic return
                //     instead of releasing production immediately.
                // PT: Após o reconhecimento, conclui o retorno automático
                //     antes de liberar novamente a produção.
                sheetStackDischargeControlState := 40;

            END_IF


        60: // FINISH
            sheetStackDischargeState := 'FINISH';
            sheetStackDischargeStateCode := 60;

            sheetStackDischargeActive := FALSE;
            sheetStackDischargePending := FALSE;
            sheetStackDischargeFinished := TRUE;
            changeBatchCycleActive := FALSE;

            sheetStackDischargeConveyorRunRequest := FALSE;

            backstopTargetOverrideActive := FALSE;
            elevatorTargetOverrideActive := FALSE;

            tonSheetStackDischarge(IN := FALSE);
            tonSheetStackDischargeStepTimeout(IN := FALSE);
            tonSheetStackDischargePlatformClearTimeout(IN := FALSE);
            elevatorPlatformClearDetected := FALSE;
            elevatorStackPresentAtDischargeStart := FALSE;

            IF sheetStackDischargeCycleHasTimeout THEN

                sheetStackDischargeLastCycleOk := FALSE;
                sheetStackDischargeLastResultCode := 3;

                // EN: Keep manual intervention memory after timeout.
                //     The backstop may not have returned correctly.

            ELSIF sheetStackDischargeCycleHasManualSkip THEN

                sheetStackDischargeLastCycleOk := FALSE;
                sheetStackDischargeLastResultCode := 2;
                sheetStackDischargeLastFaultStepCode := 0;
                sheetStackDischargeLastFaultCode := 0;

                sheetStackDischargeFault := FALSE;
                sheetStackDischargeFaultCode := 0;

                // EN: Keep manual intervention memory because the backstop
                //     was not controlled automatically.


            ELSE

                sheetStackDischargeLastCycleOk := TRUE;
                sheetStackDischargeLastResultCode := 1;
                sheetStackDischargeLastFaultStepCode := 0;
                sheetStackDischargeLastFaultCode := 0;

                sheetStackDischargeFault := FALSE;
                sheetStackDischargeFaultCode := 0;

                // EN: Cycle completed correctly and backstop returned to
                //     programmed target. Clear manual intervention memory.
                backstopManualInterventionActive := FALSE;
                backstopManualInterventionPositionMm := 0.0;

            END_IF

            // EN: Always return to IDLE automatically.
            sheetStackDischargeControlState := 0;


    ELSE

        changeBatchCycleActive := FALSE;
        sheetStackDischargeControlState := 0;

    END_CASE;

END_IF;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_SheetStackDischargeConveyorControl" Id="{596c6d49-7c22-4b2d-ab6c-e3bef636eaa1}">
      <Declaration><![CDATA[//==============================================================
// COMPLEX STACKER — SHEET STACK DISCHARGE CONVEYOR CONTROL
// EN: Controls the sheet stack discharge conveyor.
//     Conveyor runs while manual button is pressed or while
//     automatic request is active and conveyor automatic mode is enabled.
//
// Fault code
// 0 = No fault
// 1 = Safety circuit not OK
// 2 = Discharge conveyor drive not OK
//==============================================================
METHOD _SheetStackDischargeConveyorControl
VAR
    manualRunRequest   : BOOL;
    automaticRunRequest: BOOL;
    finalRunRequest    : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//==============================================================
// COMPLEX STACKER — SHEET STACK DISCHARGE CONVEYOR CONTROL
// EN: Controls the sheet stack discharge conveyor in manual pulse
//     or automatic sequence request.
//==============================================================


//==============================================================
// 1) Default outputs
//==============================================================
sheetStackDischargeConveyorRun := FALSE;
sheetStackDischargeConveyorSpeedRefMPM := 0.0;


//==============================================================
// 2) Run request selection
//==============================================================
// EN: Manual command is momentary. The conveyor runs while its dedicated
//     button is pressed or while a valid, rearmed elevator down command remains
//     pressed after the elevator reaches the configured minimum position.
// PT: O comando manual é momentâneo. A esteira gira enquanto seu botão
//     dedicado estiver pressionado ou enquanto um comando de descida válido e
//     rearmado permanecer pressionado após atingir a posição mínima configurada.
manualRunRequest :=
    sheetStackDischargeConveyorManualRunCmd OR
    (
        elevatorManualCommandRequest AND
        elevatorDownCmd AND
        NOT elevatorUpCmd AND
        elevatorAtMinPosition AND
        (sheetStackDischargeControlState = 0) AND
        NOT elevatorFault AND
        NOT elevatorLowerSafetyLimit
    );


// EN: Automatic request is generated by the discharge sequence or by the
//     elevator homing platform-clear step.
// PT: O pedido automático é gerado pela sequência de descarga ou pela etapa
//     de limpeza da plataforma durante o homing do elevador.
automaticRunRequest :=
    sheetStackDischargeConveyorRunRequest OR
    elevatorHomeDischargeConveyorRunRequest;


// EN: Master system enable blocks both manual and automatic movement.
finalRunRequest :=
    systemRunEnable AND
    (
        manualRunRequest OR
        automaticRunRequest
    );


//==============================================================
// 3) Fault detection
//==============================================================
IF NOT safetyCircuitOk THEN

    sheetStackDischargeConveyorState := 'SAFETY_OFF';

    sheetStackDischargeConveyorFault := TRUE;
    sheetStackDischargeConveyorFaultCode := 1;


ELSIF NOT sheetStackDischargeConveyorDriveOk THEN

    sheetStackDischargeConveyorState := 'DRIVE_NOT_OK';

    sheetStackDischargeConveyorFault := TRUE;
    sheetStackDischargeConveyorFaultCode := 2;


ELSE

    //==============================================================
    // 4) Fault reset
    //==============================================================
    IF resetCmd THEN

        sheetStackDischargeConveyorFault := FALSE;
        sheetStackDischargeConveyorFaultCode := 0;

    END_IF;


    //==============================================================
    // 5) Conveyor output control
    //==============================================================
    IF sheetStackDischargeConveyorFault THEN

        sheetStackDischargeConveyorState := 'FAULT';

        sheetStackDischargeConveyorRun := FALSE;
        sheetStackDischargeConveyorSpeedRefMPM := 0.0;


    ELSIF NOT systemRunEnable THEN

        // EN: Master stop disables movement without generating a conveyor fault.
        sheetStackDischargeConveyorState := 'SYSTEM_DISABLED';

        sheetStackDischargeConveyorRun := FALSE;
        sheetStackDischargeConveyorSpeedRefMPM := 0.0;


    ELSIF finalRunRequest THEN

        IF automaticRunRequest THEN

            sheetStackDischargeConveyorState := 'AUTO_RUN';

        ELSE

            sheetStackDischargeConveyorState := 'MANUAL_RUN';

        END_IF;

        sheetStackDischargeConveyorRun := TRUE;

        sheetStackDischargeConveyorSpeedRefMPM :=
            LIMIT(
                0.0,
                machineConfig.sheetStackDischargeConveyorSpeedMPM,
                machineConfig.maximumSpeedMPM
            );


    ELSE

        sheetStackDischargeConveyorState := 'STOP';

        sheetStackDischargeConveyorRun := FALSE;
        sheetStackDischargeConveyorSpeedRefMPM := 0.0;

    END_IF

END_IF;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_StackBufferConveyorsControl" Id="{63bd4e07-85e3-4f24-8234-299460111c67}">
      <Declaration><![CDATA[//==============================================================
// COMPLEX STACKER - STACK BUFFER CONVEYOR CONTROL
// EN: Transfers finished stacks to the furthest available buffer.
// PT: Transfere as pilhas prontas para o buffer livre mais distante.
//==============================================================
METHOD _StackBufferConveyorsControl
VAR
    allBufferDrivesOk : BOOL;
    automaticTransferActive : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//==============================================================
// 1) Common conditions and edge detection
//==============================================================
// EN: Default one-scan timeout event.
// PT: Evento padrão de timeout com duração de um scan.
stackBufferTransferTimeoutPulse := FALSE;


allBufferDrivesOk :=
    stackBufferConveyor1DriveOk AND
    stackBufferConveyor2DriveOk AND
    stackBufferConveyor3DriveOk;

stackBufferFull :=
    stackBufferConveyor1StackPresentSensor AND
    stackBufferConveyor2StackPresentSensor AND
    stackBufferConveyor3StackPresentSensor;

rElevatorStackExitClear :=
    elevatorStackExitClearSensor AND elevatorAtMinPosition AND
    NOT elevatorStackExitClearSensorOld;

elevatorStackExitClearSensorOld := elevatorStackExitClearSensor;

tonStackBufferFullSpeedReduction(
    IN := stackBufferFull,
    PT := machineConfig.stackBufferFullSpeedReductionDelay
);

lineSpeedReductionRequest := tonStackBufferFullSpeedReduction.Q;


//==============================================================
// 2) Default outputs
//==============================================================
stackBufferConveyor1Run := FALSE;
stackBufferConveyor2Run := FALSE;
stackBufferConveyor3Run := FALSE;

stackBufferConveyor1SpeedRefMPM := 0.0;
stackBufferConveyor2SpeedRefMPM := 0.0;
stackBufferConveyor3SpeedRefMPM := 0.0;


//==============================================================
// 3) Manual operation
// EN: Manual command ignores the stack presence sensors, but continues
//     to respect the master enable, safety circuit and drive status.
// PT: O comando manual ignora os sensores de presença, mas continua
//     respeitando a habilitação geral, segurança e estado dos drives.
//==============================================================
IF stackBufferConveyorsRunCmd THEN

    stackBufferControlState := 0;
    stackBufferTargetConveyor := 0;

    tonStackBufferStopDelay(IN := FALSE);
    tonStackBufferTransferTimeout(IN := FALSE);

    IF systemRunEnable AND safetyCircuitOk AND allBufferDrivesOk THEN

        stackBufferConveyor1Run := TRUE;
        stackBufferConveyor2Run := TRUE;
        stackBufferConveyor3Run := TRUE;

    END_IF


//==============================================================
// 4) Automatic accumulation
//==============================================================
ELSE

    // EN: A full buffer blocks automatic transfer and stops all conveyors.
    // PT: Buffer cheio bloqueia a transferência automática e para as esteiras.
    IF stackBufferFull OR
       NOT systemRunEnable OR
       NOT safetyCircuitOk OR
       NOT allBufferDrivesOk THEN

        stackBufferControlState := 0;
        stackBufferTargetConveyor := 0;

        tonStackBufferStopDelay(IN := FALSE);
        tonStackBufferTransferTimeout(IN := FALSE);

    ELSE

        CASE stackBufferControlState OF

            0: // IDLE
                tonStackBufferStopDelay(IN := FALSE);
                tonStackBufferTransferTimeout(IN := FALSE);

                IF rElevatorStackExitClear THEN

                    // EN: Always select the furthest available position.
                    // PT: Seleciona sempre a posição livre mais distante.
                    IF NOT stackBufferConveyor3StackPresentSensor THEN
                        stackBufferTargetConveyor := 3;
                        stackBufferControlState := 30;

                    ELSIF NOT stackBufferConveyor2StackPresentSensor THEN
                        stackBufferTargetConveyor := 2;
                        stackBufferControlState := 20;

                    ELSIF NOT stackBufferConveyor1StackPresentSensor THEN
                        stackBufferTargetConveyor := 1;
                        stackBufferControlState := 10;

                    END_IF

                END_IF


            10: // TRANSFER TO BUFFER 1
                stackBufferConveyor1Run := TRUE;

                IF stackBufferConveyor1StackPresentSensor THEN
                    tonStackBufferStopDelay(IN := FALSE);
                    stackBufferControlState := 11;
                END_IF


            11: // BUFFER 1 STOP DELAY
                stackBufferConveyor1Run := TRUE;

                tonStackBufferStopDelay(
                    IN := TRUE,
                    PT := machineConfig.stackBufferConveyorsStopDelay
                );

                IF tonStackBufferStopDelay.Q THEN
                    tonStackBufferStopDelay(IN := FALSE);
                    stackBufferControlState := 0;
                    stackBufferTargetConveyor := 0;
                END_IF


            20: // TRANSFER TO BUFFER 2
                stackBufferConveyor1Run := TRUE;
                stackBufferConveyor2Run := TRUE;

                IF stackBufferConveyor2StackPresentSensor THEN
                    tonStackBufferStopDelay(IN := FALSE);
                    stackBufferControlState := 21;
                END_IF


            21: // BUFFER 2 STOP DELAY
                stackBufferConveyor1Run := TRUE;
                stackBufferConveyor2Run := TRUE;

                tonStackBufferStopDelay(
                    IN := TRUE,
                    PT := machineConfig.stackBufferConveyorsStopDelay
                );

                IF tonStackBufferStopDelay.Q THEN
                    tonStackBufferStopDelay(IN := FALSE);
                    stackBufferControlState := 0;
                    stackBufferTargetConveyor := 0;
                END_IF


            30: // TRANSFER TO BUFFER 3
                stackBufferConveyor1Run := TRUE;
                stackBufferConveyor2Run := TRUE;
                stackBufferConveyor3Run := TRUE;

                // EN: Conveyor 3 stops immediately when its sensor is active.
                // PT: A esteira 3 para imediatamente quando seu sensor é acionado.
                IF stackBufferConveyor3StackPresentSensor THEN
                    stackBufferConveyor1Run := FALSE;
                    stackBufferConveyor2Run := FALSE;
                    stackBufferConveyor3Run := FALSE;

                    stackBufferControlState := 0;
                    stackBufferTargetConveyor := 0;
                END_IF


            ELSE
                stackBufferControlState := 0;
                stackBufferTargetConveyor := 0;

        END_CASE


        //==========================================================
        // 5) Automatic transfer timeout
        //==========================================================
        automaticTransferActive :=
            (stackBufferControlState <> 0);

        tonStackBufferTransferTimeout(
            IN := automaticTransferActive,
            PT := machineConfig.stackBufferTransferTimeout
        );

        IF tonStackBufferTransferTimeout.Q THEN
            stackBufferTransferTimeoutPulse := TRUE;

            tonStackBufferTransferTimeout(IN := FALSE);
            tonStackBufferStopDelay(IN := FALSE);

            stackBufferControlState := 0;
            stackBufferTargetConveyor := 0;

            stackBufferConveyor1Run := FALSE;
            stackBufferConveyor2Run := FALSE;
            stackBufferConveyor3Run := FALSE;
        END_IF

    END_IF

END_IF


//==============================================================
// 6) Sheet stack discharge conveyor coupling
// EN: Run buffer conveyor 1 together with the sheet stack discharge
//     conveyor so the stack is transferred continuously out of the elevator.
//     The existing master, safety and drive interlocks remain active.
// PT: Aciona a esteira buffer 1 junto com a esteira de descarga da pilha
//     para transferir a pilha continuamente para fora do elevador.
//     Os intertravamentos gerais, de segurança e dos drives são mantidos.
//==============================================================
IF sheetStackDischargeConveyorRun AND
   systemRunEnable AND
   safetyCircuitOk AND
   allBufferDrivesOk THEN

    stackBufferConveyor1Run := TRUE;

END_IF;


//==============================================================
// 7) Apply the common fixed speed reference
//==============================================================
IF stackBufferConveyor1Run THEN
    stackBufferConveyor1SpeedRefMPM :=
        machineConfig.stackBufferConveyorsSpeedMPM;
END_IF;

IF stackBufferConveyor2Run THEN
    stackBufferConveyor2SpeedRefMPM :=
        machineConfig.stackBufferConveyorsSpeedMPM;
END_IF;

IF stackBufferConveyor3Run THEN
    stackBufferConveyor3SpeedRefMPM :=
        machineConfig.stackBufferConveyorsSpeedMPM;
END_IF;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_SystemControl" Id="{f2b38b6a-adbc-4897-aa71-724486624911}">
      <Declaration><![CDATA[//==============================================================
// COMPLEX STACKER — SYSTEM CONTROL
// EN: Master system run enable and automatic homing requests.
//==============================================================
METHOD _SystemControl

]]></Declaration>
      <Implementation>
        <ST><![CDATA[
//==============================================================
// 1) Edge detection
//==============================================================
rStartCmd := startCmd AND NOT startCmdOld;
startCmdOld := startCmd;

rStopCmd := stopCmd AND NOT stopCmdOld;
stopCmdOld := stopCmd;



//==============================================================
// 2) Stop machine pulse on critical fault
//==============================================================
// EN: A backstop bypassed in manual remains ignored until the current
//     discharge cycle finishes, even if the selector returns to automatic.
// PT: Um backstop ignorado em manual permanece fora do ciclo até o descarte
//     atual terminar, mesmo que o seletor retorne para automático.
backstopRequiredForAutomaticOperation :=
    backstopAutoCmd AND
    NOT (
        sheetStackDischargeCycleHasManualSkip AND
        (
            sheetStackDischargeActive OR
            sheetStackDischargePending OR
            (sheetStackDischargeControlState <> 0)
        )
    );


stopMachineFaultCondition :=
    NOT safetyCircuitOk OR
    NOT sheetConveyor1DriveOk OR
    NOT sheetConveyor2DriveOk OR
    NOT sheetConveyor3DriveOk OR
    NOT sheetConveyor4DriveOk OR
    (
        backstopRequiredForAutomaticOperation AND
        NOT backstopDriveOk
    ) OR
    NOT elevatorDriveOk OR
    NOT sheetStackDischargeConveyorDriveOk;

rStopMachineFaultCondition :=
    stopMachineFaultCondition AND
    NOT stopMachineFaultConditionOld;

stopMachineFaultConditionOld :=
    stopMachineFaultCondition;

tpStopMachinePulse(
    IN := rStopMachineFaultCondition,
    PT := T#500MS
);

stopMachinePulse :=
    tpStopMachinePulse.Q;


//==============================================================
// 2) Default one-scan requests
//==============================================================
backstopAutoHomeRequest := FALSE;
elevatorAutoHomeRequest := FALSE;


//==============================================================
// 3) Master system run enable
//==============================================================
IF NOT safetyCircuitOk THEN

    systemRunEnable := FALSE;

ELSIF rStopCmd THEN

    systemRunEnable := FALSE;

ELSIF rStartCmd THEN

    systemRunEnable := TRUE;

END_IF;


//==============================================================
// 4) Mandatory reference renewal on every system start
//==============================================================
// EN: A stopped or safety-disabled system cancels pending automatic requests.
//     A new rising edge of startCmd is required before automatic homing.
// PT: O sistema parado ou sem segurança cancela pedidos automáticos pendentes.
//     Uma nova borda de startCmd será necessária antes do homing automático.
IF NOT systemRunEnable THEN

    backstopAutoHomePending := FALSE;
    elevatorAutoHomePending := FALSE;

END_IF;


// EN: Every valid start invalidates the previous position references.
//     An axis already executing homing continues its current cycle.
//     Automatic movement is armed only for axes selected in automatic mode.
// PT: Toda partida válida invalida as referências de posição anteriores.
//     Um eixo que já executa homing continua seu ciclo atual.
//     O movimento automático é armado somente para eixos em modo automático.
IF rStartCmd AND systemRunEnable THEN

    IF NOT (
        (backstopControlState >= 10) AND
        (backstopControlState <= 14)
    ) THEN

        backstopHomed := FALSE;
        backstopInPosition := FALSE;
        backstopAutoHomePending := backstopAutoCmd;

    ELSE

        backstopAutoHomePending := FALSE;

    END_IF;


    IF NOT (
        (elevatorControlState >= 10) AND
        (elevatorControlState <= 14)
    ) THEN

        elevatorHomed := FALSE;
        elevatorReadyForAutomaticCycle := FALSE;
        elevatorInPosition := FALSE;
        elevatorAutoHomePending := elevatorAutoCmd;

    ELSE

        elevatorAutoHomePending := FALSE;

    END_IF;

END_IF;


// EN: Leaving automatic mode cancels automatic movement. The invalidated
//     reference remains invalid until a manual home or a new automatic start.
// PT: Sair do modo automático cancela o movimento automático. A referência
//     invalidada permanece inválida até um home manual ou nova partida automática.
IF NOT backstopAutoCmd THEN
    backstopAutoHomePending := FALSE;
END_IF;

IF NOT elevatorAutoCmd THEN
    elevatorAutoHomePending := FALSE;
END_IF;


//==============================================================
// 5) Release pending homing requests when every permissive is valid
//==============================================================
// EN: The pending memory prevents the start request from being lost while
//     drive-ready, reset or discharge permissives are not yet available.
// PT: A memória pendente evita perder o pedido de partida enquanto os
//     permissivos de drive pronto, reset ou descarte ainda não estão disponíveis.
IF backstopAutoHomePending AND
   systemRunEnable AND
   safetyCircuitOk AND
   backstopAutoCmd AND
   backstopDriveOk AND
   NOT backstopFault AND
   NOT backstopSafeMaxLimit AND
   NOT backstopSafeMinLimit AND
   NOT sheetStackDischargePending AND
   NOT sheetStackDischargeActive AND
   (sheetStackDischargeControlState = 0) THEN

    backstopAutoHomeRequest := TRUE;

END_IF;


IF elevatorAutoHomePending AND
   systemRunEnable AND
   safetyCircuitOk AND
   elevatorAutoCmd AND
   elevatorDriveOk AND
   NOT elevatorFault AND
   NOT elevatorUpperSafetyLimit AND
   NOT elevatorLowerSafetyLimit AND
   NOT sheetStackDischargePending AND
   NOT sheetStackDischargeActive AND
   (sheetStackDischargeControlState = 0) THEN

    elevatorAutoHomeRequest := TRUE;

END_IF;]]></ST>
      </Implementation>
    </Method>
