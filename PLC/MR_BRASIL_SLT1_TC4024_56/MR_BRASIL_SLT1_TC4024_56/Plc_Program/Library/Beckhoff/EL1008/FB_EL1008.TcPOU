<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_EL1008" Id="{7e47741e-6ad9-4ceb-9dd9-a42507be85cb}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_EL1008
VAR_INPUT
    // EN: Input forcing configuration used for commissioning.
    // PT: Configuração de force das entradas usada no comissionamento.
    deviceConfig : EL1008_DEV_CONFIG;
END_VAR

VAR_OUTPUT
    digitalInput_01 : BOOL;
    digitalInput_02 : BOOL;
    digitalInput_03 : BOOL;
    digitalInput_04 : BOOL;
    digitalInput_05 : BOOL;
    digitalInput_06 : BOOL;
    digitalInput_07 : BOOL;
    digitalInput_08 : BOOL;
END_VAR

VAR
    // EN: Process data mapped directly to the EL1008 input PDOs.
    // PT: Dados de processo mapeados diretamente nos PDOs de entrada do EL1008.
    PDOS : EL1008_HWTOPLC_PDOS;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[inputState();]]></ST>
    </Implementation>
    <Method Name="inputState" Id="{9cc72413-4d29-44a8-ae42-b81beff27c90}">
      <Declaration><![CDATA[METHOD PRIVATE inputState
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// EN: Map physical inputs and optional forced states to public outputs.
// PT: Mapeia as entradas físicas e os estados forçados opcionais para as saídas públicas.
digitalInput_01 := PDOS.digitalInput_00 OR (deviceConfig.enableForce AND deviceConfig.forceDigitalInput_00);
digitalInput_02 := PDOS.digitalInput_01 OR (deviceConfig.enableForce AND deviceConfig.forceDigitalInput_01);
digitalInput_03 := PDOS.digitalInput_02 OR (deviceConfig.enableForce AND deviceConfig.forceDigitalInput_02);
digitalInput_04 := PDOS.digitalInput_03 OR (deviceConfig.enableForce AND deviceConfig.forceDigitalInput_03);
digitalInput_05 := PDOS.digitalInput_04 OR (deviceConfig.enableForce AND deviceConfig.forceDigitalInput_04);
digitalInput_06 := PDOS.digitalInput_05 OR (deviceConfig.enableForce AND deviceConfig.forceDigitalInput_05);
digitalInput_07 := PDOS.digitalInput_06 OR (deviceConfig.enableForce AND deviceConfig.forceDigitalInput_06);
digitalInput_08 := PDOS.digitalInput_07 OR (deviceConfig.enableForce AND deviceConfig.forceDigitalInput_07);]]></ST>
      </Implementation>
    </Method>
    <LineIds Name="FB_EL1008">
      <LineId Id="1" Count="0" />
    </LineIds>
    <LineIds Name="FB_EL1008.inputState">
      <LineId Id="1" Count="9" />
    </LineIds>
  </POU>
</TcPlcObject>
